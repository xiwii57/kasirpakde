document.getElementById('btn-simpan').addEventListener('click',async function(){
  var id=document.getElementById('edit-id').value.trim();
  var nama=document.getElementById('f-nama').value.trim();
  var beli=parseInt(document.getElementById('f-beli').value)||0;
  var jual=parseInt(document.getElementById('f-jual').value)||0;
  var kat=document.getElementById('f-kat').value;
  var qc=document.getElementById('f-quick').checked;
  if(!nama){toast('Nama produk wajib diisi',false);document.getElementById('f-nama').focus();return;}
  if(jual<=0){toast('Harga jual harus > 0',false);document.getElementById('f-jual').focus();return;}
  this.disabled=true; this.textContent='Menyimpan…';
  try{
    var payload={nama_produk:nama,harga_beli:beli,harga_jual:jual,kategori:kat,quick_cash:qc};
    var savedId=id;
    if(id){ await api('PATCH','/api/produk/produk?id='+encodeURIComponent(id),payload); }
    else { var res=await api('POST','/api/produk/produk',payload); savedId=String(res.id); }
    var uploadedUrl=null;
    if(_pendingFotoBlob&&savedId){
      this.textContent='Mengupload foto…';
      var fd=new FormData();
      fd.append('id',savedId);
      fd.append('file',new File([_pendingFotoBlob],'foto.webp',{type:'image/webp'}));
      var fr=await fetch('/api/produk/foto',{method:'POST',body:fd,credentials:'same-origin'});
      var frd=await fr.json().catch(function(){return{};});
      if(!fr.ok) throw new Error(frd.error||'Upload foto gagal');
      uploadedUrl = String(frd.url);
    }
    if(_fotoHapus&&id){
      fetch('/api/produk/foto?id='+encodeURIComponent(id),{method:'DELETE',credentials:'same-origin'}).catch(function(){});
      uploadedUrl='';
    }
    if(uploadedUrl!==null&&savedId){
      var selectors=['tr.data-row[data-id="'+savedId+'"] .prod-thumb','.prod-card[data-id="'+savedId+'"] .card-prod-img'];
      selectors.forEach(function(sel){
        var el=document.querySelector(sel); if(!el)return;
        if(uploadedUrl){ el.src=uploadedUrl; el.style.display=''; var ph=el.parentElement&&el.parentElement.querySelector('.prod-thumb-placeholder,.card-img-placeholder'); if(ph) ph.style.display='none'; }
        else { el.style.display='none'; var ph2=el.parentElement&&el.parentElement.querySelector('.prod-thumb-placeholder,.card-img-placeholder'); if(ph2){ ph2.style.display='flex'; } }
      });
      var row=document.querySelector('tr.data-row[data-id="'+savedId+'"]'); if(row) row.dataset.img=uploadedUrl||'';
      var card=document.querySelector('.prod-card[data-id="'+savedId+'"]'); if(card) card.dataset.img=uploadedUrl||'';
    }
    toast(id?'Produk diupdate':'Produk ditambahkan');
    closeM('tambah');
    setTimeout(function(){location.reload();},600);
  }catch(e){ toast('Error: '+e.message,false); }
  finally{ this.disabled=false; this.textContent='Simpan'; }
});
