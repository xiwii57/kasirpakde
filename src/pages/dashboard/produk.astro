---
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import "../../styles/produk.css";
import { createServiceClient, KATEGORI_LIST } from "../../lib/supabase";

const accessToken = Astro.cookies.get("sb-access-token");
if (!accessToken?.value) return Astro.redirect("/");

Astro.response.headers.set('Cache-Control', 's-maxage=60, stale-while-revalidate=300');

const nonce = (Astro.locals as App.Locals).nonce ?? "";
const sb    = createServiceClient();

const { data: produkRaw } = await sb
  .from("produk")
  .select("id, nama_produk, harga_beli, harga_jual, kategori, quick_cash, created_at, updated_at")
  .order("nama_produk");
const produk = produkRaw ?? [];

const PUBLIC_SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL;
const STORAGE_BUCKET = "produk-foto";

function rp(n: number) {
  return new Intl.NumberFormat("id-ID", { style: "currency", currency: "IDR", minimumFractionDigits: 0 }).format(n);
}
function margin(beli: number, jual: number) {
  if (!beli) return null;
  return Math.round(((jual - beli) / beli) * 100);
}
function fmtDate(s: string) {
  if (!s) return "—";
  return new Date(s).toLocaleDateString("id-ID", { day: "numeric", month: "short", year: "numeric" });
}
---

<Layout title="Daftar Produk" active="produk" nonce={nonce}>

  <a href="#main" class="skip">Lewati navigasi</a>

  <!-- ── TOP BAR ── -->
  <div class="topbar">
    <div class="topbar-title">

      <!-- Hamburger — hanya mobile, tidak fixed, tidak menimpa apapun -->
      <button
        type="button"
        onclick="window.openSidebar && window.openSidebar()"
        class="lg:hidden flex-shrink-0 w-8 h-8 flex items-center justify-center rounded-[4px] text-gray-500 hover:text-gray-800 hover:bg-gray-100 transition-colors"
        aria-label="Buka menu navigasi"
      >
        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>

      <div>
        <h1 style="font-family:'DM Serif Display',serif">Daftar Produk</h1>
        <p><span id="count-lbl" aria-live="polite">{produk.length} produk</span></p>
      </div>
    </div>

    <div class="topbar-actions">
      <button type="button" id="btn-import" class="btn btn-ghost btn-sm" aria-haspopup="dialog">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
        <span class="btn-label">Import</span>
      </button>
      <button type="button" id="btn-mass" class="btn btn-ghost btn-sm" aria-haspopup="dialog">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
        <span class="btn-label">Sesuaikan Harga</span>
      </button>
      <!-- ★ TOMBOL HAPUS MASSAL ★ -->
      <button type="button" id="btn-hapus-massal" class="btn btn-ghost btn-sm" aria-haspopup="dialog"
        style="color:#dc2626;border-color:#fecaca">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
          stroke-linecap="round" stroke-linejoin="round">
          <polyline points="3 6 5 6 21 6"/>
          <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
          <path d="M10 11v6"/><path d="M14 11v6"/>
          <path d="M9 6V4h6v2"/>
        </svg>
        <span class="btn-label">Hapus Massal</span>
      </button>
      <button type="button" id="btn-tambah" class="btn btn-dark" aria-haspopup="dialog">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Tambah
      </button>
    </div>
  </div>

  <!-- ── SEARCH + FILTER ── -->
  <div class="searchbar">
    <div class="search-wrap">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input id="q" type="search" placeholder="Cari nama produk…" autocomplete="off" aria-label="Cari produk" />
    </div>
    <div class="kat-pills" role="group" aria-label="Filter kategori" id="kat-pills">
      <button type="button" class="kat-pill active" data-kat="">Semua</button>
      {KATEGORI_LIST.map(k => (
        <button type="button" class="kat-pill" data-kat={k}>{k}</button>
      ))}
    </div>
    <div style="margin-left:auto" class="view-toggle" role="group" aria-label="Tampilan">
      <button type="button" class="view-btn active" id="btn-table" aria-label="Tampilan tabel" aria-pressed="true">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
      </button>
      <button type="button" class="view-btn" id="btn-card" aria-label="Tampilan kartu" aria-pressed="false">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="15" x2="21" y2="15"/><line x1="9" y1="9" x2="9" y2="21"/></svg>
      </button>
    </div>
  </div>

  <!-- ── TABLE VIEW ── -->
  <div id="view-table">
    <div class="table-wrap">
      <table>
        <caption class="sr-only">{produk.length} produk tersedia</caption>
        <thead>
          <tr>
            <th style="width:44px"></th>
            <th>Nama Produk</th>
            <th>Kategori</th>
            <th class="r">Harga Beli</th>
            <th class="r">Harga Jual</th>
            <th class="r">Untung</th>
            <th class="r">Margin</th>
            <th class="c">Quick&nbsp;Cash</th>
            <th></th>
          </tr>
        </thead>
        <tbody id="tbody">
          {produk.length === 0 ? (
            <tr>
              <td colspan="9">
                <div class="empty">
                  <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
                  <h3>Belum ada produk</h3>
                  <p>Klik <strong>Tambah</strong> atau <strong>Import CSV</strong> untuk mulai.</p>
                </div>
              </td>
            </tr>
          ) : produk.map(p => {
            const m = margin(p.harga_beli, p.harga_jual);
            const u = p.harga_jual - p.harga_beli;
            const bCls = m === null ? 'badge-k' : m >= 20 ? 'badge-g' : m >= 10 ? 'badge-y' : 'badge-r';
            const imgUrl = `${PUBLIC_SUPABASE_URL}/storage/v1/object/public/${STORAGE_BUCKET}/${p.id}.webp`;
            return (
              <tr class="data-row"
                  data-id={p.id}
                  data-nama={p.nama_produk.toLowerCase()}
                  data-kat={p.kategori}
                  data-nama-asli={p.nama_produk}
                  data-beli={p.harga_beli}
                  data-jual={p.harga_jual}
                  data-quick={p.quick_cash}
                  data-created={p.created_at}
                  data-updated={p.updated_at}
                  data-img={imgUrl}>
                <td style="padding:.5rem .75rem .5rem 1rem">
                  <div class="thumb-wrap" data-id={p.id} title="Klik untuk ganti foto" tabindex="0" role="button" aria-label={`Ganti foto ${p.nama_produk}`}>
                    <img
                      class="prod-thumb"
                      src={imgUrl}
                      alt={p.nama_produk}
                      loading="lazy"
                      decoding="async"
                      onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
                    />
                    <div class="prod-thumb-placeholder" style="display:none">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="m3 9 4-4 4 4 4-5 6 7"/></svg>
                    </div>
                    <div class="thumb-overlay" aria-hidden="true">
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
                    </div>
                  </div>
                </td>
                <td class="name name-clickable" tabindex="0" role="button" aria-label={`Lihat detail ${p.nama_produk}`} title="Klik untuk detail">
                  <span>{p.nama_produk}</span>
                  {p.quick_cash && <span class="badge badge-qc" style="margin-left:.4rem;font-size:.58rem">QC</span>}
                </td>
                <td><span class="badge badge-k">{p.kategori}</span></td>
                <td class="r" style="font-variant-numeric:tabular-nums;color:var(--muted);font-size:.77rem">{rp(p.harga_beli)}</td>
                <td class="r" style="font-variant-numeric:tabular-nums;font-weight:700;font-size:.82rem">{rp(p.harga_jual)}</td>
                <td class="r" style="font-variant-numeric:tabular-nums;color:var(--muted);font-size:.77rem">{rp(u)}</td>
                <td class="r">
                  <span class={`badge ${bCls}`}>{m !== null ? `${m}%` : '—'}</span>
                </td>
                <td class="c">
                  <button type="button"
                    class={`toggle ${p.quick_cash ? 'bg-rust' : ''}`}
                    style={`background:${p.quick_cash ? '#c84b1f' : '#d1d5db'}`}
                    data-id={p.id}
                    role="switch"
                    aria-checked={p.quick_cash ? "true" : "false"}
                    aria-label={`Quick Cash ${p.nama_produk}`}>
                    <span class="thumb"></span>
                  </button>
                </td>
                <td style="padding:.5rem 1rem .5rem .5rem">
                  <div style="display:flex;gap:.2rem;justify-content:flex-end">
                    <button type="button" class="icon-btn edit"
                      data-id={p.id} data-nama={p.nama_produk}
                      data-beli={p.harga_beli} data-jual={p.harga_jual}
                      data-kat={p.kategori} data-quick={p.quick_cash}
                      aria-label={`Edit ${p.nama_produk}`}>
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                    </button>
                    <button type="button" class="icon-btn del"
                      data-id={p.id} data-nama={p.nama_produk}
                      aria-label={`Hapus ${p.nama_produk}`}>
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                    </button>
                  </div>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
      <div id="no-results" class="empty" style="display:none" role="status" aria-live="polite">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <h3>Tidak ditemukan</h3>
        <p>Coba kata kunci atau kategori lain.</p>
      </div>
    </div>
  </div>

  <!-- ── CARD VIEW ── -->
  <div id="view-card" style="display:none">
    <div class="card-grid" id="card-grid">
      {produk.map(p => {
        const m = margin(p.harga_beli, p.harga_jual);
        const u = p.harga_jual - p.harga_beli;
        const bCls = m === null ? 'badge-k' : m >= 20 ? 'badge-g' : m >= 10 ? 'badge-y' : 'badge-r';
        const imgUrl = `${PUBLIC_SUPABASE_URL}/storage/v1/object/public/${STORAGE_BUCKET}/${p.id}.webp`;
        return (
          <div class="prod-card"
               data-id={p.id}
               data-nama={p.nama_produk.toLowerCase()}
               data-kat={p.kategori}
               data-nama-asli={p.nama_produk}
               data-beli={p.harga_beli}
               data-jual={p.harga_jual}
               data-quick={p.quick_cash}
               data-created={p.created_at}
               data-updated={p.updated_at}
               data-img={imgUrl}>
            <div class="card-img-wrap thumb-wrap" data-id={p.id}
                 title="Klik untuk ganti foto" tabindex="0" role="button"
                 aria-label={`Ganti foto ${p.nama_produk}`}>
              <img
                  class="card-prod-img"
                  src={imgUrl}
                  alt={p.nama_produk}
                  loading="lazy"
                  decoding="async"
                  onload="this.classList.add('loaded')"
                  onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
                />
              <div class="card-img-placeholder" style="display:none;align-items:center;justify-content:center;width:100%;height:100%;position:absolute;inset:0;background:var(--cream)">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" style="color:#d1c9be"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="m3 9 4-4 4 4 4-5 6 7"/></svg>
              </div>
              <div class="thumb-overlay thumb-overlay-card" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
                <span style="font-size:.65rem;font-weight:600;margin-top:.25rem">Ganti Foto</span>
              </div>
            </div>
            <div class="card-body card-body-clickable" role="button" tabindex="0" aria-label={`Lihat detail ${p.nama_produk}`} title="Klik untuk detail">
              <div class="card-name">{p.nama_produk}</div>
              <div class="card-price">{rp(p.harga_jual)}</div>
              <div class="card-meta">
                <span class="badge badge-k">{p.kategori}</span>
                <span class={`badge ${bCls}`}>{m !== null ? `${m}%` : '—'}</span>
                {p.quick_cash && <span class="badge badge-qc">QC</span>}
              </div>
            </div>
            <div class="card-footer">
              <span style="font-size:.68rem;color:var(--muted)">Beli: {rp(p.harga_beli)}</span>
              <div style="display:flex;gap:.2rem">
                <button type="button" class="icon-btn edit btn-sm"
                  title="Klik untuk edit"
                  data-id={p.id} data-nama={p.nama_produk}
                  data-beli={p.harga_beli} data-jual={p.harga_jual}
                  data-kat={p.kategori} data-quick={p.quick_cash}
                  aria-label={`Edit ${p.nama_produk}`}>
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                </button>
                <button type="button" class="icon-btn del btn-sm"
                  data-id={p.id} data-nama={p.nama_produk}
                  title="Klik untuk hapus"
                  aria-label={`Hapus ${p.nama_produk}`}>
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                </button>
              </div>
            </div>
          </div>
        );
      })}
    </div>
    <div id="no-results-card" class="empty" style="display:none" role="status" aria-live="polite">
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <h3>Tidak ditemukan</h3>
      <p>Coba kata kunci atau kategori lain.</p>
    </div>
  </div>

  <!-- ══ MODAL DETAIL PRODUK ══ -->
  <div id="m-detail" class="overlay" role="dialog" aria-modal="true" aria-labelledby="m-detail-title">
    <div class="modal modal-detail">
      <button type="button" class="icon-btn close-modal detail-close-btn" data-m="detail" aria-label="Tutup">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
      <div class="detail-img-section">
        <img id="d-img" src="" alt="" class="detail-img" onerror="this.style.display='none';document.getElementById('d-img-placeholder').style.display='flex'" />
        <div id="d-img-placeholder" class="detail-img-placeholder" style="display:none">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="m3 9 4-4 4 4 4-5 6 7"/></svg>
        </div>
      </div>
      <div class="detail-body">
        <div class="detail-header">
          <div>
            <h2 id="m-detail-title" class="detail-title"></h2>
            <div class="detail-badges" id="d-badges"></div>
          </div>
        </div>
        <div class="detail-price-grid">
          <div class="detail-price-card">
            <span class="detail-price-label">Harga Jual</span>
            <span class="detail-price-value" id="d-jual"></span>
          </div>
          <div class="detail-price-card">
            <span class="detail-price-label">Harga Beli</span>
            <span class="detail-price-value detail-price-muted" id="d-beli"></span>
          </div>
          <div class="detail-price-card">
            <span class="detail-price-label">Keuntungan</span>
            <span class="detail-price-value" id="d-untung"></span>
          </div>
          <div class="detail-price-card">
            <span class="detail-price-label">Margin</span>
            <span class="detail-price-value" id="d-margin-val"></span>
          </div>
        </div>
        <div class="detail-meta-row">
          <div class="detail-meta-item">
            <span class="detail-meta-label">Dibuat</span>
            <span class="detail-meta-value" id="d-created"></span>
          </div>
          <div class="detail-meta-item">
            <span class="detail-meta-label">Diperbarui</span>
            <span class="detail-meta-value" id="d-updated"></span>
          </div>
          <div class="detail-meta-item">
            <span class="detail-meta-label">Quick Cash</span>
            <span class="detail-meta-value" id="d-qc"></span>
          </div>
        </div>
      </div>
      <div class="detail-footer">
        <button type="button" class="btn btn-ghost close-modal" data-m="detail">Tutup</button>
        <div style="display:flex;gap:.5rem">
          <button type="button" id="d-btn-edit" title"Klik untuk edit" class="btn btn-dark">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
            Edit
          </button>
          <button type="button" id="d-btn-hapus" class="btn" style="background:#fee2e2;color:#dc2626;border:1px solid #fecaca">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
            Hapus
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- ══ MODAL TAMBAH / EDIT ══ -->
  <div id="m-tambah" class="overlay" role="dialog" aria-modal="true" aria-labelledby="m-tambah-title">
    <div class="modal">
      <div class="modal-hd">
        <h2 id="m-tambah-title">Tambah Produk</h2>
        <button type="button" class="icon-btn close-modal" data-m="tambah" aria-label="Tutup">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
      <div class="modal-bd">
        <input type="hidden" id="edit-id" />
        <div style="margin-bottom:1rem">
          <label class="label">Foto Produk</label>
