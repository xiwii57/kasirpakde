---
// dashboard/produk.astro
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import "../../styles/produk.css";
import { createServiceClient, KATEGORI_LIST } from "../../lib/supabase";

const accessToken = Astro.cookies.get("sb-access-token");
if (!accessToken?.value) return Astro.redirect("/");

Astro.response.headers.set('Cache-Control', 's-maxage=60, stale-while-revalidate=300');

const nonce = (Astro.locals as App.Locals).nonce ?? "";
const sb    = createServiceClient();

const { data: produkRaw } = await sb
  .from("produk")
  .select("id, nama_produk, harga_beli, harga_jual, kategori, quick_cash, created_at, updated_at")
  .order("nama_produk");
const produk = produkRaw ?? [];

const PUBLIC_SUPABASE_URL      = import.meta.env.PUBLIC_SUPABASE_URL;
const PUBLIC_TURNSTILE_SITEKEY = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY as string;
const STORAGE_BUCKET = "produk-foto";

function rp(n: number) {
  return new Intl.NumberFormat("id-ID", { style: "currency", currency: "IDR", minimumFractionDigits: 0 }).format(n);
}
function margin(beli: number, jual: number) {
  if (!beli) return null;
  return Math.round(((jual - beli) / beli) * 100);
}
function fmtDate(s: string) {
  if (!s) return "—";
  return new Date(s).toLocaleDateString("id-ID", { day: "numeric", month: "short", year: "numeric" });
}
---

<Layout title="Daftar Produk" active="produk" nonce={nonce}>

<style nonce={nonce}>
  .page-title { font-family: 'DM Serif Display', serif; }
  .btn-danger-outline { color: #dc2626; border-color: #fecaca; }
  .td-img { padding: .5rem .75rem .5rem 1rem; }
  .td-actions { padding: .5rem 1rem .5rem .5rem; }
  .td-num-muted { font-variant-numeric: tabular-nums; color: var(--muted); font-size: .77rem; }
  .td-num-bold { font-variant-numeric: tabular-nums; font-weight: 700; font-size: .82rem; }
  .badge-qc-name { margin-left: .4rem; font-size: .58rem; }
  .table-actions-row { display: flex; gap: .2rem; justify-content: flex-end; }
  .card-overlay-label { font-size: .65rem; font-weight: 600; margin-top: .25rem; }
  .card-beli-label { font-size: .68rem; color: var(--muted); }
  .card-footer-actions { display: flex; gap: .2rem; }
  .card-img-ph-inner { display: none; align-items: center; justify-content: center; width: 100%; height: 100%; position: absolute; inset: 0; background: var(--cream); }
  .card-img-ph-icon { color: #d1c9be; }
  .d-none { display: none; }
  .btn-hapus-detail { background: #fee2e2; color: #dc2626; border: 1px solid #fecaca; }
  .detail-footer-actions { display: flex; gap: .5rem; }
  .modal-foto-box { max-width: 400px; }
  .foto-drop-preview { display: none; position: relative; }
  .foto-drop-img { max-width: 100%; max-height: 200px; border-radius: 6px; display: block; margin: 0 auto; }
  .btn-foto-clear { position: absolute; top: -8px; right: -8px; width: 22px; height: 22px; border-radius: 50%; background: #dc2626; color: #fff; border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: .7rem; }
  .dropzone-icon { color: var(--muted); margin: 0 auto; }
  .dropzone-hint { margin: .5rem 0 0; font-size: .8rem; }
  .dropzone-sub { font-size: .7rem; color: var(--muted); }

  /* ── Modal Import ── */
  .modal-import-box {
    max-width: 520px;
    max-height: 90vh;
    display: flex;
    flex-direction: column;
  }
  .modal-import-box .modal-bd {
    overflow-y: auto;
    flex: 1;
    overscroll-behavior: contain;
  }

  .import-info-box { padding: .6rem .85rem; background: #eff6ff; border: 1px solid #bfdbfe; border-radius: 4px; font-size: .75rem; color: #1e40af; margin-bottom: .9rem; }
  .import-template-row { display: flex; gap: .5rem; margin-top: .5rem; align-items: center; }
  .btn-template-dl { display: inline-flex; align-items: center; gap: .3rem; color: #1e40af; font-weight: 600; text-decoration: underline; background: none; border: none; cursor: pointer; padding: 0; font-size: inherit; font-family: inherit; }
  .import-sep { color: #93c5fd; }
  .csv-preview-table { width: 100%; font-size: .72rem; border-collapse: collapse; }
  .csv-preview-thead { background: var(--cream); position: sticky; top: 0; z-index: 1; }
  .csv-th { padding: .4rem .65rem; font-weight: 600; color: var(--muted); }
  .csv-th-center { text-align: center; width: 32px; }
  .csv-th-left   { text-align: left; }
  .csv-th-right  { text-align: right; }
  .mp-hint-box { display: none; padding: .5rem .75rem; border-radius: 4px; font-size: .75rem; background: var(--cream); margin-top: .5rem; }
  .hapus-icon-wrap { width: 44px; height: 44px; background: #fee2e2; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 1rem; }
  .hapus-title { font-size: .92rem; font-weight: 700; margin-bottom: .35rem; }
  .hapus-desc { font-size: .8rem; color: var(--muted); }
  .hapus-nama-produk { color: var(--ink); }
  .hapus-massal-modal { max-width: 440px; display: flex; flex-direction: column; max-height: 90vh; }
  .hapus-massal-modal .modal-bd { overflow-y: auto; overscroll-behavior: contain; }
  .hapus-massal-title { color: #dc2626; }
  .hapus-massal-warning { display: flex; gap: .6rem; align-items: flex-start; padding: .65rem .85rem; background: #fef2f2; border: 1px solid #fecaca; border-radius: 6px; margin-bottom: 1rem; }
  .hapus-massal-warn-ico { flex-shrink: 0; margin-top: .05rem; }
  .hapus-massal-warn-txt { font-size: .75rem; color: #991b1b; margin: 0; }
  .btn-hapus-massal-ok { background: #dc2626; color: #fff; opacity: .5; cursor: not-allowed; }
  .hm-confirm-kw { color: #dc2626; font-family: monospace; letter-spacing: .04em; }
  .foto-preview-box { width: 96px; height: 96px; border: 1.5px dashed var(--border); border-radius: 8px; overflow: hidden; flex-shrink: 0; display: flex; align-items: center; justify-content: center; background: var(--cream); }
  .foto-current { display: none; width: 100%; height: 100%; object-fit: cover; }
  .foto-placeholder { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: .35rem; color: var(--muted); }
  .foto-placeholder-txt { font-size: .72rem; }
  .foto-upload-wrap { display: flex; gap: 1rem; align-items: flex-start; }
  .foto-btn-col { display: flex; flex-direction: column; gap: .4rem; }
  .btn-hapus-foto { display: none; color: #dc2626; }
  .foto-hint { font-size: .67rem; color: var(--muted); margin-top: .25rem; }
  .field-foto { margin-bottom: 1rem; }
  .field-quick { display: flex; align-items: center; gap: .5rem; }
  .quick-label { font-size: .8rem; cursor: pointer; }
  .quick-checkbox { width: 16px; height: 16px; accent-color: var(--rust); cursor: pointer; }
  .hm-kat-wrap-hidden { display: none; }
  .hm-info-box { padding: .5rem .75rem; background: var(--cream); border-radius: 4px; font-size: .75rem; color: var(--muted); margin-bottom: .5rem; }
  .csv-preview-scroll { max-height: 300px; overflow-y: auto; border: 1px solid var(--border); border-radius: 4px; }
  .csv-preview-wrap { display: none; margin-top: .75rem; }
  .csv-count-txt { font-size: .75rem; font-weight: 600; color: var(--muted); margin-bottom: .4rem; }

  /* ── Turnstile wrapper ── */
  .hm-turnstile-wrap {
    display: flex;
    justify-content: center;
    margin: .75rem 0 .25rem;
    min-height: 65px;
  }
  .hm-turnstile-wrap:empty::after {
    content: 'Memuat verifikasi…';
    font-size: .72rem;
    color: var(--muted);
    align-self: center;
  }
</style>

  <a href="#main" class="skip">Lewati navigasi</a>

  <!-- ── TOP BAR ── -->
  <div class="topbar">
    <div class="topbar-title">
      <button
        type="button"
        onclick="window.openSidebar && window.openSidebar()"
        class="lg:hidden flex-shrink-0 w-8 h-8 flex items-center justify-center rounded-[4px] text-gray-500 hover:text-gray-800 hover:bg-gray-100 transition-colors"
        aria-label="Buka menu navigasi"
      >
        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
      <div>
        <h1 class="page-title">Daftar Produk</h1>
        <p><span id="count-lbl" aria-live="polite">{produk.length} produk</span></p>
      </div>
    </div>
    <div class="topbar-actions">
      <button type="button" id="btn-import" class="btn btn-ghost btn-sm" aria-haspopup="dialog">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
        <span class="btn-label">Import</span>
      </button>
      <button type="button" id="btn-mass" class="btn btn-ghost btn-sm" aria-haspopup="dialog">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
        <span class="btn-label">Sesuaikan Harga</span>
      </button>
      <button type="button" id="btn-hapus-massal" class="btn btn-ghost btn-sm btn-danger-outline" aria-haspopup="dialog">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="3 6 5 6 21 6"/>
          <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
          <path d="M10 11v6"/><path d="M14 11v6"/>
          <path d="M9 6V4h6v2"/>
        </svg>
        <span class="btn-label">Hapus Massal</span>
      </button>
      <button type="button" id="btn-tambah" class="btn btn-dark" aria-haspopup="dialog">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Tambah
      </button>
    </div>
  </div>

  <!-- ── SEARCH + FILTER ── -->
  <div class="searchbar">
    <div class="search-wrap">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input id="q" type="search" placeholder="Cari nama produk…" autocomplete="off" aria-label="Cari produk" />
    </div>
    <div class="kat-pills" role="group" aria-label="Filter kategori" id="kat-pills">
      <button type="button" class="kat-pill active" data-kat="">Semua</button>
      {KATEGORI_LIST.map(k => (
        <button type="button" class="kat-pill" data-kat={k}>{k}</button>
      ))}
    </div>
    <div class="view-toggle" role="group" aria-label="Tampilan">
      <button type="button" class="view-btn active" id="btn-table" aria-label="Tampilan tabel" aria-pressed="true">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
      </button>
      <button type="button" class="view-btn" id="btn-card" aria-label="Tampilan kartu" aria-pressed="false">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="15" x2="21" y2="15"/><line x1="9" y1="9" x2="9" y2="21"/></svg>
      </button>
    </div>
  </div>

  <!-- ── TABLE VIEW ── -->
  <div id="view-table">
    <div class="table-wrap">
      <table>
        <caption class="sr-only">{produk.length} produk tersedia</caption>
        <thead>
          <tr>
            <th style="width:44px"></th>
            <th>Nama Produk</th>
            <th>Kategori</th>
            <th class="r">Harga Beli</th>
            <th class="r">Harga Jual</th>
            <th class="r">Untung</th>
            <th class="r">Margin</th>
            <th class="c">Quick&nbsp;Cash</th>
            <th></th>
          </tr>
        </thead>
        <tbody id="tbody">
          {produk.length === 0 ? (
            <tr>
              <td colspan="9">
                <div class="empty">
                  <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
                  <h3>Belum ada produk</h3>
                  <p>Klik <strong>Tambah</strong> atau <strong>Import CSV</strong> untuk mulai.</p>
                </div>
              </td>
            </tr>
          ) : produk.map(p => {
            const m = margin(p.harga_beli, p.harga_jual);
            const u = p.harga_jual - p.harga_beli;
            const bCls = m === null ? 'badge-k' : m >= 20 ? 'badge-g' : m >= 10 ? 'badge-y' : 'badge-r';
            const imgUrl = `${PUBLIC_SUPABASE_URL}/storage/v1/object/public/${STORAGE_BUCKET}/${p.id}.webp`;
            return (
              <tr class="data-row"
                  data-id={p.id}
                  data-nama={p.nama_produk.toLowerCase()}
                  data-kat={p.kategori}
                  data-nama-asli={p.nama_produk}
                  data-beli={p.harga_beli}
                  data-jual={p.harga_jual}
                  data-quick={p.quick_cash}
                  data-created={p.created_at}
                  data-updated={p.updated_at}
                  data-img={imgUrl}>
                <td class="td-img">
                  <div class="thumb-wrap" data-id={p.id} title="Klik untuk ganti foto" tabindex="0" role="button" aria-label={`Ganti foto ${p.nama_produk}`}>
                    <img class="prod-thumb" src={imgUrl} alt={p.nama_produk} loading="lazy" decoding="async"
                      onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                    <div class="prod-thumb-placeholder d-none">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="m3 9 4-4 4 4 4-5 6 7"/></svg>
                    </div>
                    <div class="thumb-overlay" aria-hidden="true">
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
                    </div>
                  </div>
                </td>
                <td class="name name-clickable" tabindex="0" role="button" aria-label={`Lihat detail ${p.nama_produk}`} title="Klik untuk detail">
                  <span>{p.nama_produk}</span>
                  {p.quick_cash && <span class="badge badge-qc badge-qc-name">QC</span>}
                </td>
                <td><span class="badge badge-k">{p.kategori}</span></td>
                <td class="r td-num-muted">{rp(p.harga_beli)}</td>
                <td class="r td-num-bold">{rp(p.harga_jual)}</td>
                <td class="r td-num-muted">{rp(u)}</td>
                <td class="r"><span class={`badge ${bCls}`}>{m !== null ? `${m}%` : '—'}</span></td>
                <td class="c">
                  <button type="button"
                    class={`toggle ${p.quick_cash ? 'bg-rust' : ''}`}
                    style={`background:${p.quick_cash ? '#c84b1f' : '#d1d5db'}`}
                    data-id={p.id} role="switch"
                    aria-checked={p.quick_cash ? "true" : "false"}
                    aria-label={`Quick Cash ${p.nama_produk}`}>
                    <span class="thumb"></span>
                  </button>
                </td>
                <td class="td-actions">
                  <div class="table-actions-row">
                    <button type="button" class="icon-btn edit"
                      data-id={p.id} data-nama={p.nama_produk}
                      data-beli={p.harga_beli} data-jual={p.harga_jual}
                      data-kat={p.kategori} data-quick={p.quick_cash}
                      aria-label={`Edit ${p.nama_produk}`}>
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                    </button>
                    <button type="button" class="icon-btn del"
                      data-id={p.id} data-nama={p.nama_produk}
                      aria-label={`Hapus ${p.nama_produk}`}>
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                    </button>
                  </div>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
      <div id="no-results" class="empty d-none" role="status" aria-live="polite">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <h3>Tidak ditemukan</h3>
        <p>Coba kata kunci atau kategori lain.</p>
      </div>
    </div>
  </div>

  <!-- ── CARD VIEW ── -->
  <div id="view-card" class="d-none">
    <div class="card-grid" id="card-grid">
      {produk.map(p => {
        const m = margin(p.harga_beli, p.harga_jual);
        const u = p.harga_jual - p.harga_beli;
        const bCls = m === null ? 'badge-k' : m >= 20 ? 'badge-g' : m >= 10 ? 'badge-y' : 'badge-r';
        const imgUrl = `${PUBLIC_SUPABASE_URL}/storage/v1/object/public/${STORAGE_BUCKET}/${p.id}.webp`;
        return (
          <div class="prod-card"
               data-id={p.id} data-nama={p.nama_produk.toLowerCase()} data-kat={p.kategori}
               data-nama-asli={p.nama_produk} data-beli={p.harga_beli} data-jual={p.harga_jual}
               data-quick={p.quick_cash} data-created={p.created_at} data-updated={p.updated_at} data-img={imgUrl}>
            <div class="card-img-wrap thumb-wrap" data-id={p.id}
                 title="Klik untuk ganti foto" tabindex="0" role="button" aria-label={`Ganti foto ${p.nama_produk}`}>
              <img class="card-prod-img" src={imgUrl} alt={p.nama_produk} loading="lazy" decoding="async"
                onload="this.classList.add('loaded')"
                onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
              <div class="card-img-placeholder card-img-ph-inner">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="card-img-ph-icon"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="m3 9 4-4 4 4 4-5 6 7"/></svg>
              </div>
              <div class="thumb-overlay thumb-overlay-card" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
                <span class="card-overlay-label">Ganti Foto</span>
              </div>
            </div>
            <div class="card-body card-body-clickable" role="button" tabindex="0" aria-label={`Lihat detail ${p.nama_produk}`} title="Klik untuk detail">
              <div class="card-name">{p.nama_produk}</div>
              <div class="card-price">{rp(p.harga_jual)}</div>
              <div class="card-meta">
                <span class="badge badge-k">{p.kategori}</span>
                <span class={`badge ${bCls}`}>{m !== null ? `${m}%` : '—'}</span>
                {p.quick_cash && <span class="badge badge-qc">QC</span>}
              </div>
            </div>
            <div class="card-footer">
              <span class="card-beli-label">Beli: {rp(p.harga_beli)}</span>
              <div class="card-footer-actions">
                <button type="button" class="icon-btn edit btn-sm" title="Klik untuk edit"
                  data-id={p.id} data-nama={p.nama_produk} data-beli={p.harga_beli}
                  data-jual={p.harga_jual} data-kat={p.kategori} data-quick={p.quick_cash}
                  aria-label={`Edit ${p.nama_produk}`}>
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                </button>
