async function processQuickFoto(file){
  if(!file.type.startsWith('image/')){toast('File bukan gambar',false);return;}
  if(file.size>5*1024*1024){toast('Ukuran file maks 5 MB',false);return;}
  try{
    _fotoQuickBlob=await resizeToWebP(file,'resize-canvas-quick');
    document.getElementById('foto-drop-img').src=URL.createObjectURL(_fotoQuickBlob);
    document.getElementById('foto-drop-preview').style.display='block';
    document.getElementById('foto-drop-empty').style.display='none';
    document.getElementById('btn-upload-foto').disabled=false;
  }catch(e){ toast('Gagal memproses: '+e.message,false); }
}

document.getElementById('btn-upload-foto').addEventListener('click',async function(){
  var id=document.getElementById('foto-target-id').value;
  if(!id||!_fotoQuickBlob)return;
  this.disabled=true; this.textContent='Mengupload…';
  try{
    var fd=new FormData();
    fd.append('id',id);
    fd.append('file',new File([_fotoQuickBlob],'foto.webp',{type:'image/webp'}));
    var r=await fetch('/api/produk/foto',{method:'POST',body:fd,credentials:'same-origin'});
    var rd=await r.json().catch(function(){return{};});
    if(!r.ok) throw new Error(rd.error||'Upload gagal');
    var newSrc=String(rd.url);
    var tThumb=document.querySelector('tr.data-row[data-id="'+id+'"] .prod-thumb');
    if(tThumb){ tThumb.src=newSrc; tThumb.style.display=''; var tPh=tThumb.parentElement&&tThumb.parentElement.querySelector('.prod-thumb-placeholder'); if(tPh) tPh.style.display='none'; }
    var cThumb=document.querySelector('.prod-card[data-id="'+id+'"] .card-prod-img');
    if(cThumb){ cThumb.src=newSrc; cThumb.style.display='block'; var cPh=document.querySelector('.prod-card[data-id="'+id+'"] .card-img-placeholder'); if(cPh) cPh.style.display='none'; }
    var row2=document.querySelector('tr.data-row[data-id="'+id+'"]'); if(row2) row2.dataset.img=newSrc;
    var card2=document.querySelector('.prod-card[data-id="'+id+'"]'); if(card2) card2.dataset.img=newSrc;
    var dImg=document.getElementById('d-img');
    if(_detailId===id){ dImg.src=newSrc; dImg.style.display=''; document.getElementById('d-img-placeholder').style.display='none'; }
    toast('Foto berhasil diperbarui'); closeM('foto');
  }catch(e){ toast('Gagal: '+e.message,false); }
  finally{ this.disabled=false; this.textContent='Upload'; }
});

// ─── IMPORT CSV / XLSX ────────────────────────────────────────────────────────
// Parsing dilakukan server-side di /api/produk/parse-xlsx
// agar tidak perlu load library SheetJS dari CDN eksternal (konflik CSP).
var _csvData = [];
var dz = document.getElementById('dropzone');

dz.addEventListener('click', function () { document.getElementById('f-csv').click(); });
dz.addEventListener('keydown', function (e) { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); document.getElementById('f-csv').click(); } });
dz.addEventListener('dragover',  function (e) { e.preventDefault(); this.classList.add('over'); });
dz.addEventListener('dragleave', function ()  { this.classList.remove('over'); });
dz.addEventListener('drop', function (e) {
  e.preventDefault(); this.classList.remove('over');
  var f = e.dataTransfer && e.dataTransfer.files[0]; if (f) parseFile(f);
});
document.getElementById('f-csv').addEventListener('change', function () {
  if (this.files && this.files[0]) parseFile(this.files[0]);
});

// Kirim file ke server untuk di-parse — tidak ada library di browser
async function parseFile(file) {
  var name = file.name.toLowerCase();
  var validExt = name.endsWith('.csv') || name.endsWith('.xlsx') || name.endsWith('.xls');
  if (!validExt) { toast('Hanya .csv atau .xlsx yang didukung', false); return; }
  if (file.size === 0) { toast('File kosong', false); return; }
  if (file.size > 2 * 1024 * 1024) { toast('Ukuran file maks 2 MB', false); return; }

  // Tampilkan loading state
  var dz = document.getElementById('dropzone');
  var origHtml = dz.innerHTML;
  dz.innerHTML = '<p style="font-size:.8rem;color:var(--muted)">Memproses file…</p>';
  dz.style.pointerEvents = 'none';

  try {
    var fd = new FormData();
    fd.append('file', file);
    var r  = await fetch('/api/produk/parse-xlsx', {
      method: 'POST',
      body:   fd,
      credentials: 'same-origin'
      // Tidak set Content-Type — browser isi boundary multipart otomatis
    });
    var d  = await r.json().catch(function(){ return {}; });
    if (!r.ok) { toast(d.error || 'Gagal membaca file', false); return; }

    renderParsed(d.produk || [], d.duplicates || 0, d.skipped || 0);
  } catch (e) {
    toast('Gagal mengirim file: ' + e.message, false);
  } finally {
    dz.innerHTML = origHtml;
    dz.style.pointerEvents = '';
    // Re-attach event listener pada input karena innerHTML diganti
    var inp = dz.querySelector('#f-csv');
    if (inp) inp.addEventListener('change', function () { if (this.files && this.files[0]) parseFile(this.files[0]); });
  }
}

// Terima array produk yang sudah dinormalisasi dari server
function renderParsed(produk, dupCount, skipped) {
  _csvData = produk;

  var countEl = document.getElementById('csv-count');
  var info = produk.length + ' produk siap diimport';
  if (dupCount > 0)  info += ' · <span style="color:#92400e">⚠ ' + dupCount + ' duplikat dihapus</span>';
  if (skipped > 0)   info += ' · <span style="color:#dc2626">✕ ' + skipped + ' baris tidak valid dilewati</span>';
  countEl.innerHTML = info;

  var tb = document.getElementById('csv-tbody');

  // Header summary
  var headerInfo = '<tr style="background:#f0fdf4;border-bottom:2px solid #86efac">'
    + '<td colspan="6" style="padding:.4rem .65rem;font-size:.72rem;color:#15803d;font-weight:600">'
    + '✓ Preview ' + Math.min(produk.length, 20) + ' dari ' + produk.length + ' produk'
    + (produk.length > 20 ? ' (scroll untuk lihat semua)' : '')
    + '</td></tr>';

  tb.innerHTML = headerInfo + produk.slice(0, 50).map(function(r, i) {
    var margin = r.harga_beli > 0
      ? Math.round(((r.harga_jual - r.harga_beli) / r.harga_beli) * 100)
      : null;
    var mColor = margin === null ? '#9ca3af'
      : margin >= 20 ? '#15803d'
      : margin >= 10 ? '#92400e'
      : '#dc2626';
    var isAlt = i % 2 === 1;
    return '<tr style="border-bottom:1px solid var(--border);' + (isAlt ? 'background:#fafaf9' : '') + '">'
      + '<td style="padding:.35rem .5rem;text-align:center;color:#9ca3af;font-size:.68rem">' + (i+1) + '</td>'
      + '<td style="padding:.35rem .65rem;font-weight:500">'  + esc(r.nama_produk) + '</td>'
      + '<td style="padding:.35rem .65rem;text-align:right;color:var(--muted);font-size:.75rem">' + (r.harga_beli > 0 ? r.harga_beli.toLocaleString('id-ID') : '—') + '</td>'
      + '<td style="padding:.35rem .65rem;text-align:right;font-weight:600">' + r.harga_jual.toLocaleString('id-ID') + '</td>'
      + '<td style="padding:.35rem .65rem;text-align:center">'
        + (margin !== null
          ? '<span style="font-size:.68rem;font-weight:600;color:' + mColor + '">' + margin + '%</span>'
          : '<span style="color:#9ca3af;font-size:.68rem">—</span>')
      + '</td>'
      + '<td style="padding:.35rem .65rem">'
        + '<span style="font-size:.65rem;padding:.1rem .4rem;border-radius:3px;background:#f3f4f6;color:#374151">' + esc(r.kategori) + '</span>'
        + (r.quick_cash ? ' <span style="font-size:.62rem;padding:.1rem .35rem;border-radius:3px;background:#c84b1f;color:#fff">QC</span>' : '')
      + '</td>'
      + '</tr>';
  }).join('');

  if (produk.length > 50) {
    tb.innerHTML += '<tr><td colspan="6" style="padding:.5rem;text-align:center;color:var(--muted);font-size:.7rem;font-style:italic">'
      + '…dan ' + (produk.length - 50) + ' produk lainnya tidak ditampilkan</td></tr>';
  }

  document.getElementById('csv-preview').style.display = '';
  document.getElementById('btn-do-import').disabled = produk.length === 0;
}

document.getElementById('btn-do-import').addEventListener('click', async function () {
  if (!_csvData.length) return;
  this.disabled = true; this.textContent = 'Mengimport…';
  try {
    for (var i = 0; i < _csvData.length; i += 50) {
      await api('POST', '/api/produk/produk', _csvData.slice(i, i + 50));
    }
    toast(_csvData.length + ' produk diimport');
    closeM('import');
    setTimeout(function () { location.reload(); }, 600);
  } catch (e) { toast('Import gagal: ' + e.message, false); this.disabled = false; this.textContent = 'Import'; }
});

</script>
