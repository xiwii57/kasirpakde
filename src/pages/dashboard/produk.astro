  <!-- Script kecil: hanya inject config ke window, tidak ada logika -->
  <script define:vars={{ KATEGORI_LIST, PUBLIC_TURNSTILE_SITEKEY }} nonce={nonce}>
    window.__PRODUK_CFG__ = { KAT: KATEGORI_LIST, TS: PUBLIC_TURNSTILE_SITEKEY };
  </script>

  <!-- Script utama: tanpa define:vars agar tidak dieksekusi ulang oleh View Transitions -->
  <script nonce={nonce}>
  'use strict';
  var __cfg = window.__PRODUK_CFG__ || {};
  var KATEGORI_LIST            = __cfg.KAT || [];
  var PUBLIC_TURNSTILE_SITEKEY = __cfg.TS  || '';

  // ─── HELPERS ──────────────────────────────────────────────────────────────────
  function rp(n){ return new Intl.NumberFormat('id-ID',{style:'currency',currency:'IDR',minimumFractionDigits:0}).format(n); }
  function esc(s){ return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
  function fmtDate(s){
    if(!s)return '—';
    try{ return new Date(s).toLocaleDateString('id-ID',{day:'numeric',month:'short',year:'numeric'}); }
    catch(e){ return '—'; }
  }

  // ─── TOAST ────────────────────────────────────────────────────────────────────
  var _tt;
  function toast(msg, ok){
    var t=document.getElementById('toast'), ic=document.getElementById('t-icon');
    if(!t||!ic) return;
    document.getElementById('t-msg').textContent=msg;
    ic.style.color = ok===false?'#f87171':'#4ade80';
    ic.innerHTML   = ok===false ? '<line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>' : '<polyline points="20 6 9 17 4 12"/>';
    t.classList.add('show'); clearTimeout(_tt);
    _tt=setTimeout(function(){ t.classList.remove('show'); },3200);
  }

  // ─── API JSON ─────────────────────────────────────────────────────────────────
  async function api(method, path, body){
    var opts={
      method:method,
      credentials:'same-origin',
      headers:{'Content-Type':'application/json'},
      // body hanya dikirim jika ada payload
      ...(body!==undefined ? {body:JSON.stringify(body)} : {})
    };
    var r=await fetch(path,opts);
    var d=await r.json().catch(function(){return{};});
    if(!r.ok) throw new Error(d.error||r.statusText);
    return d;
  }

  // ─── FOTO RESIZE ─────────────────────────────────────────────────────────────
  var MAX_W=480, MAX_H=480, WEBP_Q=0.72;
  var _resizeImg=null;

  function resizeToWebP(file, canvasId){
    return new Promise(function(resolve,reject){
      if(!file){reject(new Error('File kosong'));return;}
      var reader=new FileReader();
      reader.onerror=function(){reject(new Error('Gagal membaca file'));};
      reader.onload=function(ev){
        _resizeImg=new Image();
        var img=_resizeImg;
        img.onerror=function(){ _resizeImg=null; reject(new Error('Format gambar tidak didukung')); };
        img.onload=function(){
          var ratio=Math.min(1,MAX_W/img.naturalWidth,MAX_H/img.naturalHeight);
          var tw=Math.round(img.naturalWidth*ratio), th=Math.round(img.naturalHeight*ratio);
          var cv=document.getElementById(canvasId);
          cv.width=tw; cv.height=th;
          cv.getContext('2d').drawImage(img,0,0,tw,th);
          cv.toBlob(function(b){
            _resizeImg=null;
            if(b&&b.size>0){resolve(b);return;}
            cv.toBlob(function(b2){ b2?resolve(b2):reject(new Error('Konversi canvas gagal')); },'image/jpeg',0.85);
          },'image/webp',WEBP_Q);
        };
        img.src=ev.target.result;
      };
      reader.readAsDataURL(file);
    });
  }

  /* ══════════════════════════════════════════════════════════════════════════
     INIT
  ══════════════════════════════════════════════════════════════════════════ */
  function initProduk() {

    if (!document.getElementById('btn-tambah')) return;

    // Abort & cleanup semua listener dari pemanggilan initProduk sebelumnya
    if (window.__produkAbortCtrl) window.__produkAbortCtrl.abort();
    window.__produkAbortCtrl = new AbortController();
    var sig = window.__produkAbortCtrl.signal;

    var _q='', _kat='';
    var _pendingFotoBlob=null, _fotoHapus=false;
    var _fotoQuickBlob=null;
    var _detailId='', _detailData={};
    var _hapusId='';
    var _csvData=[];
    var _pf=null;

    var _turnstileWidgetId = null;
    var _turnstileToken    = null;

    var FOCUSABLE='button:not([disabled]),[href],input:not([disabled]),select,[tabindex]:not([tabindex="-1"])';
    var ALL_MODALS=['detail','tambah','import','mass','hapus','hapus-massal','foto'];

    // ─── RESET IMPORT MODAL ──────────────────────────────────────────────────────
    function resetImportModal(){
      var dz=document.getElementById('dropzone');
      var previewWrap=document.getElementById('csv-preview');
      if(dz) dz.style.display='';
      if(previewWrap) previewWrap.style.display='none';
      _csvData=[];
      var btnImp=document.getElementById('btn-do-import');
      if(btnImp) btnImp.disabled=true;
      var fCsvEl=document.getElementById('f-csv');
      if(fCsvEl) fCsvEl.value='';
      var tb=document.getElementById('csv-tbody');
      if(tb) tb.innerHTML='';
    }

    // ─── MODAL ──────────────────────────────────────────────────────────────────
    function openM(id){
      _pf=document.activeElement;
      var m=document.getElementById('m-'+id);
      if(!m)return;
      m.classList.add('open'); document.body.style.overflow='hidden';
      var els=Array.from(m.querySelectorAll(FOCUSABLE));
      if(els.length) setTimeout(function(){els[0].focus();},40);
      m._kt=function(e){
        if(e.key!=='Tab'||!els.length)return;
        var f=els[0],l=els[els.length-1];
        if(e.shiftKey){if(document.activeElement===f){e.preventDefault();l.focus();}}
        else{if(document.activeElement===l){e.preventDefault();f.focus();}}
      };
      m.addEventListener('keydown',m._kt);
    }
    function closeM(id){
      var m=document.getElementById('m-'+id);
      if(!m)return;
      m.classList.remove('open'); document.body.style.overflow='';
      if(m._kt){m.removeEventListener('keydown',m._kt);m._kt=null;}
      if(_pf){_pf.focus();_pf=null;}
      if(id==='tambah') resetForm();
      if(id==='foto')   resetFotoModal();
      if(id==='hapus-massal') resetHapusMassal();
      if(id==='import') resetImportModal();
    }

    document.addEventListener('keydown',function(e){
      if(e.key!=='Escape')return;
      for(var i=0;i<ALL_MODALS.length;i++){
        var m=document.getElementById('m-'+ALL_MODALS[i]);
        if(m&&m.classList.contains('open')){ closeM(ALL_MODALS[i]); return; }
      }
    },{signal:sig});
    ALL_MODALS.forEach(function(id){
      var m=document.getElementById('m-'+id);
      if(!m)return;
      m.addEventListener('click',function(e){ if(e.target===this) closeM(id); });
    });
    document.querySelectorAll('.close-modal').forEach(function(b){
      b.addEventListener('click',function(){ closeM(this.dataset.m); });
    });

    // ─── OPEN MODAL BUTTONS ─────────────────────────────────────────────────────
    var btnTambah = document.getElementById('btn-tambah');
    var btnImport = document.getElementById('btn-import');
    var btnMass   = document.getElementById('btn-mass');
    var btnHapusMassal = document.getElementById('btn-hapus-massal');
    if(btnTambah) btnTambah.onclick=function(){openM('tambah');};
    if(btnImport) btnImport.onclick=function(){resetImportModal();openM('import');};
    if(btnMass)   btnMass.onclick=function(){openM('mass');};
    if(btnHapusMassal) btnHapusMassal.onclick=function(){
      resetHapusMassal();
      updateHmInfo();
      renderTurnstile();
      openM('hapus-massal');
    };

    // ─── TURNSTILE ───────────────────────────────────────────────────────────────
    function renderTurnstile(){
      var container = document.getElementById('hm-turnstile-container');
      if(!container) return;
      _turnstileToken = null;
      if(_turnstileWidgetId !== null && window.turnstile){
        try{ window.turnstile.remove(_turnstileWidgetId); } catch(e){}
        _turnstileWidgetId = null;
      }
      container.innerHTML = '';
      var attempts = 0;
      var interval = setInterval(function(){
        attempts++;
        if(window.turnstile){
          clearInterval(interval);
          _turnstileWidgetId = window.turnstile.render(container, {
            sitekey:  PUBLIC_TURNSTILE_SITEKEY,
            theme:    'light',
            size:     'normal',
            callback: function(token){ _turnstileToken = token; syncHapusMassalBtn(); },
            'expired-callback': function(){ _turnstileToken = null; syncHapusMassalBtn(); },
            'error-callback': function(){ _turnstileToken = null; syncHapusMassalBtn(); },
          });
        } else if(attempts >= 20){
          clearInterval(interval);
          container.innerHTML = '<p style="font-size:.72rem;color:#dc2626;text-align:center">Gagal memuat verifikasi. Muat ulang halaman.</p>';
        }
      }, 200);
    }

    function syncHapusMassalBtn(){
      var confirmed = (document.getElementById('hm-confirm')?.value ?? '').trim().toUpperCase() === 'HAPUS';
      var okBtn = document.getElementById('btn-hapus-massal-ok');
      if(!okBtn) return;
      var active = confirmed && !!_turnstileToken;
      okBtn.disabled = !active;
      okBtn.style.opacity = active ? '1' : '.5';
      okBtn.style.cursor  = active ? 'pointer' : 'not-allowed';
    }

    // ─── MODAL DETAIL ───────────────────────────────────────────────────────────
    function openDetail(data){
      _detailId=data.id; _detailData=data;
      var dImg=document.getElementById('d-img'), dPh=document.getElementById('d-img-placeholder');
      if(data.img){ dImg.src=data.img; dImg.alt=data.nama; dImg.style.display=''; dPh.style.display='none'; }
      else { dImg.style.display='none'; dPh.style.display='flex'; }
      document.getElementById('m-detail-title').textContent=data.nama;
      var m=data.beli>0?Math.round(((data.jual-data.beli)/data.beli)*100):null;
      document.getElementById('d-badges').innerHTML='<span class="badge badge-k">'+esc(data.kat)+'</span>'+(data.qc?'<span class="badge badge-qc">Quick Cash</span>':'');
      var untung=data.jual-data.beli;
      document.getElementById('d-jual').textContent=rp(data.jual);
      document.getElementById('d-beli').textContent=rp(data.beli);
      document.getElementById('d-untung').textContent=rp(untung);
      document.getElementById('d-untung').style.color=untung>0?'#15803d':'var(--muted)';
      var mEl=document.getElementById('d-margin-val');
      if(m!==null){ mEl.textContent=m+'%'; mEl.style.color=m>=20?'#15803d':m>=10?'#92400e':'#991b1b'; }
      else { mEl.textContent='—'; mEl.style.color='var(--muted)'; }
      document.getElementById('d-created').textContent=fmtDate(data.created);
      document.getElementById('d-updated').textContent=fmtDate(data.updated);
      document.getElementById('d-qc').textContent=data.qc?'Aktif ✓':'Tidak aktif';
      document.getElementById('d-qc').style.color=data.qc?'#15803d':'var(--muted)';
      openM('detail');
    }

    var dBtnEdit=document.getElementById('d-btn-edit');
    var dBtnHapus=document.getElementById('d-btn-hapus');
    if(dBtnEdit) dBtnEdit.addEventListener('click',function(){ closeM('detail'); var b=document.querySelector('.icon-btn.edit[data-id="'+_detailId+'"]'); if(b) b.click(); });
    if(dBtnHapus) dBtnHapus.addEventListener('click',function(){ closeM('detail'); var b=document.querySelector('.icon-btn.del[data-id="'+_detailId+'"]'); if(b) b.click(); });

    document.addEventListener('click',function(e){
      var cell=e.target.closest('.name-clickable'); if(!cell)return;
      var row=cell.closest('tr.data-row'); if(!row)return;
      openDetail({id:row.dataset.id,nama:row.dataset.namaAsli,kat:row.dataset.kat,beli:parseInt(row.dataset.beli)||0,jual:parseInt(row.dataset.jual)||0,qc:row.dataset.quick==='true',created:row.dataset.created,updated:row.dataset.updated,img:row.dataset.img});
    },{signal:sig});
    document.addEventListener('keydown',function(e){
      if(e.key!=='Enter'&&e.key!==' ')return;
      var cell=e.target.closest('.name-clickable'); if(!cell)return;
      var row=cell.closest('tr.data-row'); if(!row)return;
      e.preventDefault();
      openDetail({id:row.dataset.id,nama:row.dataset.namaAsli,kat:row.dataset.kat,beli:parseInt(row.dataset.beli)||0,jual:parseInt(row.dataset.jual)||0,qc:row.dataset.quick==='true',created:row.dataset.created,updated:row.dataset.updated,img:row.dataset.img});
    },{signal:sig});
    document.addEventListener('click',function(e){
      var body=e.target.closest('.card-body-clickable'); if(!body)return;
      var card=body.closest('.prod-card'); if(!card)return;
      openDetail({id:card.dataset.id,nama:card.dataset.namaAsli,kat:card.dataset.kat,beli:parseInt(card.dataset.beli)||0,jual:parseInt(card.dataset.jual)||0,qc:card.dataset.quick==='true',created:card.dataset.created,updated:card.dataset.updated,img:card.dataset.img});
    },{signal:sig});
    document.addEventListener('keydown',function(e){
      if(e.key!=='Enter'&&e.key!==' ')return;
      var body=e.target.closest('.card-body-clickable'); if(!body)return;
      var card=body.closest('.prod-card'); if(!card)return;
      e.preventDefault();
      openDetail({id:card.dataset.id,nama:card.dataset.namaAsli,kat:card.dataset.kat,beli:parseInt(card.dataset.beli)||0,jual:parseInt(card.dataset.jual)||0,qc:card.dataset.quick==='true',created:card.dataset.created,updated:card.dataset.updated,img:card.dataset.img});
    },{signal:sig});

    // ─── FILTER ─────────────────────────────────────────────────────────────────
    function applyFilter(){
      var q=_q.trim().toLowerCase(), kat=_kat, vis=0;
      document.querySelectorAll('#tbody tr.data-row').forEach(function(r){
        var show=(!q||r.dataset.nama.indexOf(q)!==-1)&&(!kat||r.dataset.kat===kat);
        r.classList.toggle('tr-hidden',!show);
        if(show) vis++;
      });
      document.querySelectorAll('#card-grid .prod-card').forEach(function(c){
        var show=(!q||c.dataset.nama.indexOf(q)!==-1)&&(!kat||c.dataset.kat===kat);
        c.classList.toggle('card-hidden',!show);
      });
      var lbl=document.getElementById('count-lbl');
      if(lbl) lbl.textContent=vis+' produk';
      var nr=document.getElementById('no-results'), nrc=document.getElementById('no-results-card');
      if(nr)  nr.style.display=vis===0?'':'none';
      if(nrc) nrc.style.display=vis===0?'':'none';
    }
    var qEl=document.getElementById('q');
    if(qEl) qEl.addEventListener('input',function(){ _q=this.value; applyFilter(); });
    var katPills=document.getElementById('kat-pills');
    if(katPills) katPills.addEventListener('click',function(e){
      var btn=e.target.closest('.kat-pill'); if(!btn)return;
      _kat=btn.dataset.kat||'';
      document.querySelectorAll('.kat-pill').forEach(function(b){ b.classList.toggle('active',b.dataset.kat===_kat||(!b.dataset.kat&&!_kat)); });
      applyFilter();
    });

    // ─── VIEW TOGGLE ────────────────────────────────────────────────────────────
    var btnTable=document.getElementById('btn-table');
    var btnCard=document.getElementById('btn-card');
    if(btnTable) btnTable.addEventListener('click',function(){
      document.getElementById('view-table').classList.remove('d-none');
      document.getElementById('view-card').classList.add('d-none');
      this.classList.add('active'); btnCard.classList.remove('active');
      this.setAttribute('aria-pressed','true'); btnCard.setAttribute('aria-pressed','false');
      localStorage.setItem('kw-view','table');
    });
    if(btnCard) btnCard.addEventListener('click',function(){
      document.getElementById('view-card').style.display='';
      document.getElementById('view-table').style.display='none';
      this.classList.add('active'); btnTable.classList.remove('active');
      this.setAttribute('aria-pressed','true'); btnTable.setAttribute('aria-pressed','false');
      localStorage.setItem('kw-view','card');
    });
    if(localStorage.getItem('kw-view')==='card' && btnCard) btnCard.click();

    // ─── MARGIN PREVIEW ─────────────────────────────────────────────────────────
    function updMargin(){
      var b=parseInt(document.getElementById('f-beli').value)||0;
      var j=parseInt(document.getElementById('f-jual').value)||0;
      var h=document.getElementById('margin-hint');
      if(b>0&&j>0){
        var pct=Math.round(((j-b)/b)*100);
        h.textContent='Untung: Rp '+(j-b).toLocaleString('id-ID')+' ('+pct+'%)';
        h.style.color=pct<10?'#7f1d1d':pct<20?'#713f12':'#14532d';
        h.style.display='block';
      } else { h.style.display='none'; }
    }
    var fBeli=document.getElementById('f-beli'), fJual=document.getElementById('f-jual');
    if(fBeli) fBeli.addEventListener('input',updMargin);
    if(fJual) fJual.addEventListener('input',updMargin);

    // ─── FOTO HELPERS ────────────────────────────────────────────────────────────
    function setFotoPreview(blob){
      var img=document.getElementById('foto-current');
      img.src=URL.createObjectURL(blob); img.style.display='block';
      document.getElementById('foto-placeholder').style.display='none';
      document.getElementById('btn-hapus-foto').style.display='';
    }
    function clearFotoPreview(){
      var img=document.getElementById('foto-current');
      img.src=''; img.style.display='none';
      document.getElementById('foto-placeholder').style.display='flex';
      document.getElementById('btn-hapus-foto').style.display='none';
    }
    function loadFotoForEdit(id){
      var thumb=document.querySelector('tr.data-row[data-id="'+id+'"] .prod-thumb')||
                document.querySelector('.prod-card[data-id="'+id+'"] .card-prod-img');
      var img=document.getElementById('foto-current');
      if(thumb&&thumb.naturalWidth>0&&!thumb.dataset.error){
        img.src=thumb.src; img.style.display='block';
        document.getElementById('foto-placeholder').style.display='none';
        document.getElementById('btn-hapus-foto').style.display='';
      } else { clearFotoPreview(); }
    }
    function resetForm(){
      document.getElementById('edit-id').value='';
      document.getElementById('f-nama').value='';
      document.getElementById('f-beli').value='';
      document.getElementById('f-jual').value='';
      document.getElementById('f-kat').selectedIndex=0;
      document.getElementById('f-quick').checked=false;
      document.getElementById('m-tambah-title').textContent='Tambah Produk';
      document.getElementById('margin-hint').style.display='none';
      clearFotoPreview();
      _pendingFotoBlob=null; _fotoHapus=false;
    }
    function resetFotoModal(){
      _fotoQuickBlob=null;
      document.getElementById('foto-target-id').value='';
      document.getElementById('foto-drop-preview').style.display='none';
      document.getElementById('foto-drop-empty').style.display='';
      document.getElementById('btn-upload-foto').disabled=true;
      document.getElementById('f-foto-quick').value='';
    }

    var btnPilihFoto=document.getElementById('btn-pilih-foto');
    if(btnPilihFoto) btnPilihFoto.addEventListener('click',function(){ document.getElementById('f-foto').click(); });
    var fFoto=document.getElementById('f-foto');
    if(fFoto) fFoto.addEventListener('change',async function(){
      var file=this.files&&this.files[0]; if(!file) return;
      if(!file.type.startsWith('image/')){toast('File bukan gambar',false);return;}
      if(file.size>5*1024*1024){toast('Ukuran file maks 5 MB',false);return;}
      try{ _pendingFotoBlob=await resizeToWebP(file,'resize-canvas'); _fotoHapus=false; setFotoPreview(_pendingFotoBlob); }
      catch(e){ toast('Gagal memproses gambar: '+e.message,false); }
      this.value='';
    });
    var btnHapusFoto=document.getElementById('btn-hapus-foto');
    if(btnHapusFoto) btnHapusFoto.addEventListener('click',function(){ _pendingFotoBlob=null; _fotoHapus=true; clearFotoPreview(); });

    // ─── EDIT BTN ───────────────────────────────────────────────────────────────
    document.addEventListener('click',function(e){
      var btn=e.target.closest('.icon-btn.edit'); if(!btn)return;
      var id=btn.dataset.id;
      document.getElementById('edit-id').value=id;
      document.getElementById('f-nama').value=btn.dataset.nama;
      document.getElementById('f-beli').value=btn.dataset.beli;
      document.getElementById('f-jual').value=btn.dataset.jual;
      document.getElementById('f-kat').value=btn.dataset.kat;
      document.getElementById('f-quick').checked=btn.dataset.quick==='true';
      document.getElementById('m-tambah-title').textContent='Edit Produk';
      _pendingFotoBlob=null; _fotoHapus=false;
      loadFotoForEdit(id); updMargin(); openM('tambah');
    },{signal:sig});

    // ─── SIMPAN ─────────────────────────────────────────────────────────────────
    var btnSimpan=document.getElementById('btn-simpan');
    if(btnSimpan) btnSimpan.addEventListener('click',async function(){
      var id=document.getElementById('edit-id').value.trim();
      var nama=document.getElementById('f-nama').value.trim();
      var beli=parseInt(document.getElementById('f-beli').value)||0;
      var jual=parseInt(document.getElementById('f-jual').value)||0;
      var kat=document.getElementById('f-kat').value;
      var qc=document.getElementById('f-quick').checked;
      if(!nama){toast('Nama produk wajib diisi',false);document.getElementById('f-nama').focus();return;}
      if(jual<=0){toast('Harga jual harus > 0',false);document.getElementById('f-jual').focus();return;}
      this.disabled=true; this.textContent='Menyimpan…';
      try{
        var payload={nama_produk:nama,harga_beli:beli,harga_jual:jual,kategori:kat,quick_cash:qc};
        var savedId=id;
        if(id){ await api('PATCH','/api/produk/produk?id='+encodeURIComponent(id),payload); }
        else { var res=await api('POST','/api/produk/produk',payload); savedId=String(res.id); }
        var uploadedUrl=null;
        if(_pendingFotoBlob&&savedId){
          this.textContent='Mengupload foto…';
          var fd=new FormData();
          fd.append('id',savedId);
          fd.append('file',new File([_pendingFotoBlob],'foto.webp',{type:'image/webp'}));
          var fr=await fetch('/api/produk/foto',{method:'POST',body:fd,credentials:'same-origin'});
          var frd=await fr.json().catch(function(){return{};});
          if(!fr.ok) throw new Error(frd.error||'Upload foto gagal');
          uploadedUrl=String(frd.url);
        }
        if(_fotoHapus&&id){
          fetch('/api/produk/foto?id='+encodeURIComponent(id),{method:'DELETE',credentials:'same-origin'}).catch(function(){});
          uploadedUrl='';
        }
        if(uploadedUrl!==null&&savedId){
          var selectors=['tr.data-row[data-id="'+savedId+'"] .prod-thumb','.prod-card[data-id="'+savedId+'"] .card-prod-img'];
          selectors.forEach(function(sel){
            var el=document.querySelector(sel); if(!el)return;
            if(uploadedUrl){ el.src=uploadedUrl; el.style.display=''; var ph=el.parentElement&&el.parentElement.querySelector('.prod-thumb-placeholder,.card-img-placeholder'); if(ph) ph.style.display='none'; }
            else { el.style.display='none'; var ph2=el.parentElement&&el.parentElement.querySelector('.prod-thumb-placeholder,.card-img-placeholder'); if(ph2){ ph2.style.display='flex'; } }
          });
          var row=document.querySelector('tr.data-row[data-id="'+savedId+'"]'); if(row) row.dataset.img=uploadedUrl||'';
          var card=document.querySelector('.prod-card[data-id="'+savedId+'"]'); if(card) card.dataset.img=uploadedUrl||'';
        }
        toast(id?'Produk diupdate':'Produk ditambahkan');
        closeM('tambah');
        setTimeout(function(){location.reload();},600);
      }catch(e){ toast('Error: '+e.message,false); }
      finally{ this.disabled=false; this.textContent='Simpan'; }
    });
    if(fJual) fJual.addEventListener('keydown',function(e){ if(e.key==='Enter'){e.preventDefault();if(btnSimpan) btnSimpan.click();} });

    // ─── QUICK CASH TOGGLE ──────────────────────────────────────────────────────
    document.addEventListener('click',async function(e){
      var btn=e.target.closest('.toggle'); if(!btn)return;
      var id=btn.dataset.id, cur=btn.getAttribute('aria-checked')==='true', next=!cur;
      btn.setAttribute('aria-checked',String(next));
      btn.style.background=next?'#c84b1f':'#d1d5db';
      try{
        await api('PATCH','/api/produk/produk?id='+encodeURIComponent(id),{quick_cash:next});
        toast(next?'Quick Cash diaktifkan':'Quick Cash dinonaktifkan');
      }catch(e2){ btn.setAttribute('aria-checked',String(cur)); btn.style.background=cur?'#c84b1f':'#d1d5db'; toast('Gagal: '+e2.message,false); }
    },{signal:sig});

    // ─── HAPUS (satu produk) ────────────────────────────────────────────────────
    document.addEventListener('click',function(e){
      var btn=e.target.closest('.icon-btn.del'); if(!btn)return;
      _hapusId=btn.dataset.id;
      document.getElementById('hapus-nama').textContent=btn.dataset.nama;
      openM('hapus');
    },{signal:sig});
    var btnHapusOk=document.getElementById('btn-hapus-ok');
    if(btnHapusOk) btnHapusOk.addEventListener('click',async function(){
      if(!_hapusId)return;
      this.disabled=true; this.textContent='Menghapus…';
      try{
        await api('DELETE','/api/produk/produk?id='+encodeURIComponent(_hapusId));
        fetch('/api/produk/foto?id='+encodeURIComponent(_hapusId),{method:'DELETE',credentials:'same-origin'}).catch(function(){});
        toast('Produk dihapus'); closeM('hapus');
        var r=document.querySelector('tr.data-row[data-id="'+_hapusId+'"]');
        if(r){r.style.transition='opacity .18s';r.style.opacity='0';setTimeout(function(){r.remove();applyFilter();},200);}
        var c=document.querySelector('.prod-card[data-id="'+_hapusId+'"]');
        if(c){c.style.transition='opacity .18s,transform .18s';c.style.opacity='0';c.style.transform='scale(.92)';setTimeout(function(){c.remove();applyFilter();},200);}
        _hapusId='';
      }catch(e){ toast('Gagal: '+e.message,false); }
      finally{ this.disabled=false; this.textContent='Hapus'; }
    });

    // ─── HAPUS MASSAL ───────────────────────────────────────────────────────────
    function countProdukByMode(mode, kat){
      var rows=Array.from(document.querySelectorAll('#tbody tr.data-row'));
      if(mode==='all') return rows.length;
      return rows.filter(function(r){ return r.dataset.kat===kat; }).length;
    }
    function updateHmInfo(){
      var mode=document.getElementById('hm-mode').value;
      var kat=document.getElementById('hm-kat').value;
      var infoEl=document.getElementById('hm-info');
      var katWrap=document.getElementById('hm-kat-wrap');
      katWrap.style.display = mode==='kategori' ? 'block' : 'none';
      var count=countProdukByMode(mode,kat);
      if(count===0){
        infoEl.textContent=mode==='all'?'Tidak ada produk untuk dihapus.':'Tidak ada produk dalam kategori "'+kat+'".';
        infoEl.style.color='var(--muted)';
      } else {
        infoEl.innerHTML='⚠️ Akan menghapus <strong style="color:#dc2626">'+count+' produk</strong>'+(mode==='kategori'?' dalam kategori <strong>'+esc(kat)+'</strong>':' dari semua kategori')+'.';
        infoEl.style.color='#92400e';
      }
    }
    function resetHapusMassal(){
      document.getElementById('hm-mode').value='all';
      document.getElementById('hm-kat-wrap').style.display='none';
      document.getElementById('hm-confirm').value='';
      document.getElementById('hm-info').textContent='';
      _turnstileToken = null;
      var okBtn=document.getElementById('btn-hapus-massal-ok');
      if(okBtn){ okBtn.disabled=true; okBtn.style.opacity='.5'; okBtn.style.cursor='not-allowed'; }
    }

    var hmMode=document.getElementById('hm-mode');
    var hmKat=document.getElementById('hm-kat');
    var hmConfirm=document.getElementById('hm-confirm');
    if(hmMode) hmMode.addEventListener('change',function(){ updateHmInfo(); hmConfirm.value=''; syncHapusMassalBtn(); });
    if(hmKat) hmKat.addEventListener('change',function(){ updateHmInfo(); hmConfirm.value=''; syncHapusMassalBtn(); });
    if(hmConfirm) hmConfirm.addEventListener('input', syncHapusMassalBtn);

    var btnHapusMassalOk=document.getElementById('btn-hapus-massal-ok');
    if(btnHapusMassalOk) btnHapusMassalOk.addEventListener('click',async function(){
      if(this.disabled) return;
      if(!_turnstileToken){ toast('Selesaikan verifikasi terlebih dahulu',false); return; }
      var mode=document.getElementById('hm-mode').value;
      var kat=document.getElementById('hm-kat').value;
      this.disabled=true; this.textContent='Menghapus…'; this.style.opacity='.7';
      try{
        var url='/api/produk/produk?bulk='+mode;
        if(mode==='kategori') url+='&kategori='+encodeURIComponent(kat);
        var res=await api('DELETE', url, { turnstile_token: _turnstileToken });
        toast((res.deleted||0)+' produk berhasil dihapus');
        closeM('hapus-massal');
        setTimeout(function(){location.reload();},600);
      }catch(e){
        toast('Gagal: '+e.message,false);
        _turnstileToken=null;
        if(_turnstileWidgetId!==null && window.turnstile){
          try{ window.turnstile.reset(_turnstileWidgetId); }catch(err){}
        }
        syncHapusMassalBtn();
        this.disabled=false; this.textContent='Hapus Sekarang'; this.style.opacity='1';
      }
    });

    // ─── MODAL FOTO CEPAT ───────────────────────────────────────────────────────
    document.addEventListener('click',function(e){
      var wrap=e.target.closest('.thumb-wrap'); if(!wrap)return;
      if(e.target.closest('.icon-btn'))return;
      if(e.target.closest('.name-clickable'))return;
      if(e.target.closest('.card-body-clickable'))return;
      var id=wrap.dataset.id; if(!id)return;
      document.getElementById('foto-target-id').value=id;
      openM('foto');
    },{signal:sig});
    document.addEventListener('keydown',function(e){
      if(e.key!=='Enter'&&e.key!==' ')return;
      var wrap=e.target.closest('.thumb-wrap'); if(!wrap)return;
      if(e.target.closest('.name-clickable'))return;
      if(e.target.closest('.card-body-clickable'))return;
      e.preventDefault();
      var id=wrap.dataset.id; if(!id)return;
      document.getElementById('foto-target-id').value=id;
      openM('foto');
    },{signal:sig});

    async function processQuickFoto(file){
      if(!file.type.startsWith('image/')){toast('File bukan gambar',false);return;}
      if(file.size>5*1024*1024){toast('Ukuran file maks 5 MB',false);return;}
      try{
        _fotoQuickBlob=await resizeToWebP(file,'resize-canvas-quick');
        document.getElementById('foto-drop-img').src=URL.createObjectURL(_fotoQuickBlob);
        document.getElementById('foto-drop-preview').style.display='block';
        document.getElementById('foto-drop-empty').style.display='none';
        document.getElementById('btn-upload-foto').disabled=false;
      }catch(e){ toast('Gagal memproses: '+e.message,false); }
    }

    var fotoDrop=document.getElementById('foto-drop');
    if(fotoDrop){
      fotoDrop.addEventListener('click',function(e){ if(!e.target.closest('#btn-foto-clear')) document.getElementById('f-foto-quick').click(); });
      fotoDrop.addEventListener('keydown',function(e){ if(e.key==='Enter'||e.key===' '){e.preventDefault();document.getElementById('f-foto-quick').click();} });
      fotoDrop.addEventListener('dragover',function(e){e.preventDefault();this.classList.add('over');});
      fotoDrop.addEventListener('dragleave',function(){this.classList.remove('over');});
      fotoDrop.addEventListener('drop',function(e){ e.preventDefault(); this.classList.remove('over'); var f=e.dataTransfer&&e.dataTransfer.files[0]; if(f) processQuickFoto(f); });
    }
    var fFotoQuick=document.getElementById('f-foto-quick');
    if(fFotoQuick) fFotoQuick.addEventListener('change',function(){ var f=this.files&&this.files[0]; if(f) processQuickFoto(f); this.value=''; });
    var btnFotoClear=document.getElementById('btn-foto-clear');
    if(btnFotoClear) btnFotoClear.addEventListener('click',function(e){
      e.stopPropagation(); _fotoQuickBlob=null;
      document.getElementById('foto-drop-preview').style.display='none';
      document.getElementById('foto-drop-empty').style.display='';
      document.getElementById('btn-upload-foto').disabled=true;
    });

    var btnUploadFoto=document.getElementById('btn-upload-foto');
    if(btnUploadFoto) btnUploadFoto.addEventListener('click',async function(){
      var id=document.getElementById('foto-target-id').value;
      if(!id||!_fotoQuickBlob)return;
      this.disabled=true; this.textContent='Mengupload…';
      try{
        var fd=new FormData();
        fd.append('id',id);
        fd.append('file',new File([_fotoQuickBlob],'foto.webp',{type:'image/webp'}));
        var r=await fetch('/api/produk/foto',{method:'POST',body:fd,credentials:'same-origin'});
        var rd=await r.json().catch(function(){return{};});
        if(!r.ok) throw new Error(rd.error||'Upload gagal');
        var newSrc=String(rd.url);
        var tThumb=document.querySelector('tr.data-row[data-id="'+id+'"] .prod-thumb');
        if(tThumb){ tThumb.src=newSrc; tThumb.style.display=''; var tPh=tThumb.parentElement&&tThumb.parentElement.querySelector('.prod-thumb-placeholder'); if(tPh) tPh.style.display='none'; }
        var cThumb=document.querySelector('.prod-card[data-id="'+id+'"] .card-prod-img');
        if(cThumb){ cThumb.src=newSrc; cThumb.style.display='block'; var cPh=document.querySelector('.prod-card[data-id="'+id+'"] .card-img-placeholder'); if(cPh) cPh.style.display='none'; }
        var row2=document.querySelector('tr.data-row[data-id="'+id+'"]'); if(row2) row2.dataset.img=newSrc;
        var card2=document.querySelector('.prod-card[data-id="'+id+'"]'); if(card2) card2.dataset.img=newSrc;
        var dImg2=document.getElementById('d-img');
        if(_detailId===id){ dImg2.src=newSrc; dImg2.style.display=''; document.getElementById('d-img-placeholder').style.display='none'; }
        toast('Foto berhasil diperbarui'); closeM('foto');
      }catch(e){ toast('Gagal: '+e.message,false); }
      finally{ this.disabled=false; this.textContent='Upload'; }
    });

    // ─── IMPORT CSV / XLSX ──────────────────────────────────────────────────────
    async function parseFile(file){
      var name=file.name.toLowerCase();
      var validExt=name.endsWith('.csv')||name.endsWith('.xlsx')||name.endsWith('.xls');
      if(!validExt){toast('Hanya .csv atau .xlsx yang didukung',false);return;}
      if(file.size===0){toast('File kosong',false);return;}
      if(file.size>2*1024*1024){toast('Ukuran file maks 2 MB',false);return;}

      var dz=document.getElementById('dropzone');
      dz.style.pointerEvents='none';
      dz.style.opacity='0.5';

      try{
        var fd=new FormData();
        fd.append('file',file);
        var r=await fetch('/api/produk/parse-xlsx',{method:'POST',body:fd,credentials:'same-origin'});
        var d=await r.json().catch(function(){return{};});
        if(!r.ok){
          console.error('[parseFile] Error:',r.status,d);
          toast(d.error||'Gagal membaca file (status '+r.status+')',false);
          return;
        }
        renderParsed(d.produk||[],d.duplicates||0,d.skipped||0,file.name);
      }catch(e){ toast('Gagal mengirim file: '+e.message,false); }
      finally{
        dz.style.pointerEvents='';
        dz.style.opacity='';
      }
    }

    function renderParsed(produk, dupCount, skipped, filename){
      _csvData=produk;

      // Sembunyikan dropzone, tampilkan area preview
      var dz=document.getElementById('dropzone');
      dz.style.display='none';
      var previewWrap=document.getElementById('csv-preview');
      previewWrap.style.display='';

      // Baris info + tombol ganti file
      var countEl=document.getElementById('csv-count');
      var info='<strong>'+esc(filename||'')+'</strong> — '+produk.length+' produk siap diimport';
      if(dupCount>0) info+=' · <span style="color:#92400e">⚠ '+dupCount+' duplikat dihapus</span>';
      if(skipped>0)  info+=' · <span style="color:#dc2626">✕ '+skipped+' baris dilewati</span>';
      info+=' <button type="button" id="btn-ganti-file" style="margin-left:.4rem;font-size:.72rem;color:#1e40af;background:none;border:none;cursor:pointer;text-decoration:underline;padding:0;font-family:inherit">Ganti file</button>';
      countEl.innerHTML=info;

      // Tombol ganti file → kembali ke dropzone
      var btnGanti=document.getElementById('btn-ganti-file');
      if(btnGanti) btnGanti.onclick=function(){
        dz.style.display='';
        previewWrap.style.display='none';
        _csvData=[];
        document.getElementById('btn-do-import').disabled=true;
        document.getElementById('f-csv').value='';
      };

      // Render tabel preview
      var tb=document.getElementById('csv-tbody');
      var headerRow='<tr style="background:#f0fdf4;border-bottom:2px solid #86efac">'
        +'<td colspan="6" style="padding:.4rem .65rem;font-size:.72rem;color:#15803d;font-weight:600">'
        +'✓ '+produk.length+' produk ditemukan'+(produk.length>50?' · menampilkan 50 pertama':'')
        +'</td></tr>';

      tb.innerHTML=headerRow+produk.slice(0,50).map(function(r,i){
        var margin=r.harga_beli>0?Math.round(((r.harga_jual-r.harga_beli)/r.harga_beli)*100):null;
        var mColor=margin===null?'#9ca3af':margin>=20?'#15803d':margin>=10?'#92400e':'#dc2626';
        var isAlt=i%2===1;
        return '<tr style="border-bottom:1px solid var(--border);'+(isAlt?'background:#fafaf9':'')+'">'
          +'<td style="padding:.35rem .5rem;text-align:center;color:#9ca3af;font-size:.68rem">'+(i+1)+'</td>'
          +'<td style="padding:.35rem .65rem;font-weight:500">'+esc(r.nama_produk)+'</td>'
          +'<td style="padding:.35rem .65rem;text-align:right;color:var(--muted);font-size:.75rem">'+(r.harga_beli>0?r.harga_beli.toLocaleString('id-ID'):'—')+'</td>'
          +'<td style="padding:.35rem .65rem;text-align:right;font-weight:600">'+r.harga_jual.toLocaleString('id-ID')+'</td>'
          +'<td style="padding:.35rem .65rem;text-align:center">'
            +(margin!==null?'<span style="font-size:.68rem;font-weight:600;color:'+mColor+'">'+margin+'%</span>':'<span style="color:#9ca3af;font-size:.68rem">—</span>')
          +'</td>'
          +'<td style="padding:.35rem .65rem">'
            +'<span style="font-size:.65rem;padding:.1rem .4rem;border-radius:3px;background:#f3f4f6;color:#374151">'+esc(r.kategori)+'</span>'
            +(r.quick_cash?' <span style="font-size:.62rem;padding:.1rem .35rem;border-radius:3px;background:#c84b1f;color:#fff">QC</span>':'')
          +'</td>'
          +'</tr>';
      }).join('');

      if(produk.length>50){
        tb.innerHTML+='<tr><td colspan="6" style="padding:.5rem;text-align:center;color:var(--muted);font-size:.7rem;font-style:italic">…dan '+(produk.length-50)+' produk lainnya</td></tr>';
      }

      document.getElementById('btn-do-import').disabled=produk.length===0;
    }

    var dz=document.getElementById('dropzone');
    if(dz){
      dz.addEventListener('click',function(){ document.getElementById('f-csv').click(); });
      dz.addEventListener('keydown',function(e){ if(e.key==='Enter'||e.key===' '){e.preventDefault();document.getElementById('f-csv').click();} });
      dz.addEventListener('dragover',function(e){e.preventDefault();this.classList.add('over');});
      dz.addEventListener('dragleave',function(){this.classList.remove('over');});
      dz.addEventListener('drop',function(e){ e.preventDefault();this.classList.remove('over'); var f=e.dataTransfer&&e.dataTransfer.files[0]; if(f) parseFile(f); });
    }
    var fCsv=document.getElementById('f-csv');
    if(fCsv) fCsv.addEventListener('change',function(){ if(this.files&&this.files[0]) parseFile(this.files[0]); });

    var btnDoImport=document.getElementById('btn-do-import');
    if(btnDoImport) btnDoImport.onclick=async function(){
      if(!_csvData.length)return;
      this.disabled=true; this.textContent='Mengimport…';
      try{
        for(var i=0;i<_csvData.length;i+=50){ await api('POST','/api/produk/produk',_csvData.slice(i,i+50)); }
        toast(_csvData.length+' produk diimport');
        closeM('import');
        setTimeout(function(){location.reload();},600);
      }catch(e){ toast('Import gagal: '+e.message,false); this.disabled=false; this.textContent='Import'; }
    };

    // ─── DRAG TO SCROLL (pills) ─────────────────────────────────────────────────
    var el=document.getElementById('kat-pills');
    if(el){
      var isDown=false, startX, scrollLeft;
      el.addEventListener('mousedown',function(e){ isDown=true; startX=e.pageX-el.offsetLeft; scrollLeft=el.scrollLeft; el.style.cursor='grabbing'; });
      el.addEventListener('mouseleave',function(){ isDown=false; el.style.cursor='grab'; });
      el.addEventListener('mouseup',function(){ isDown=false; el.style.cursor='grab'; });
      el.addEventListener('mousemove',function(e){ if(!isDown)return; e.preventDefault(); el.scrollLeft=scrollLeft-(e.pageX-el.offsetLeft-startX)*1.5; });
    }

    // ─── CHECK URL PARAMS ────────────────────────────────────────────────────────
    var urlParams=new URLSearchParams(window.location.search);
    if(urlParams.get('modal')==='tambah') openM('tambah');
    if(urlParams.get('filter')==='low_margin'){
      _kat='';
      document.querySelectorAll('#tbody tr.data-row').forEach(function(r){
        var beli=parseInt(r.dataset.beli)||0, jual=parseInt(r.dataset.jual)||0;
        var m=beli>0?((jual-beli)/beli):1;
        r.classList.toggle('tr-hidden',m>=0.10);
      });
    }

  } // end initProduk

  /* ══════════════════════════════════════════════════════════════════════
     BOOTSTRAP
  ══════════════════════════════════════════════════════════════════════ */
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initProduk, { once: true });
  } else {
    initProduk();
  }
  </script>

</Layout>
