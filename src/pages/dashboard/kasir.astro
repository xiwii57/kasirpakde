<script is:inline nonce={nonce}>
'use strict';

/* ══════════════════════════════════════════════════════════════════════════
   HELPERS
══════════════════════════════════════════════════════════════════════════ */
function rp(n) {
  return new Intl.NumberFormat('id-ID',{style:'currency',currency:'IDR',minimumFractionDigits:0}).format(n);
}
function esc(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
function timeStr(iso) {
  return new Date(iso).toLocaleTimeString('id-ID',{hour:'2-digit',minute:'2-digit'});
}
function dateStr(iso) {
  return new Date(iso).toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'});
}

/* ── Sound ─────────────────────────────────────────────────────────────── */
window.__playSuccess = function() {
  try {
    var ctx = new (window.AudioContext || window.webkitAudioContext)();
    [659.25, 830.61, 987.77].forEach(function(f, i) {
      var o = ctx.createOscillator(), g = ctx.createGain();
      o.connect(g); g.connect(ctx.destination);
      o.frequency.value = f; o.type = 'triangle';
      var t = ctx.currentTime + i * 0.13;
      g.gain.setValueAtTime(0, t);
      g.gain.linearRampToValueAtTime(0.35, t + 0.02);
      g.gain.exponentialRampToValueAtTime(0.001, t + 0.4);
      o.start(t); o.stop(t + 0.42);
    });
  } catch(e) {}
};

/* ── Toast ─────────────────────────────────────────────────────────────── */
var _tt;
function toast(msg, ok) {
  var t = document.getElementById('toast'), ic = document.getElementById('toast-ico');
  if (!t || !ic) return;
  document.getElementById('toast-msg').textContent = msg;
  ic.style.color = ok === false ? '#f87171' : '#4ade80';
  ic.innerHTML   = ok === false
    ? '<line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>'
    : '<polyline points="20 6 9 17 4 12"/>';
  t.classList.add('show');
  clearTimeout(_tt);
  _tt = setTimeout(function(){ t.classList.remove('show'); }, 3000);
}

/* ── API ───────────────────────────────────────────────────────────────── */
async function api(method, path, body) {
  var r = await fetch(path, {
    method: method,
    headers: {'Content-Type':'application/json'},
    body: body !== undefined ? JSON.stringify(body) : undefined,
    credentials: 'same-origin'
  });
  var d = await r.json().catch(function(){ return {}; });
  if (!r.ok) throw new Error(d.error || r.statusText);
  return d;
}

/* ── Denomination chips ────────────────────────────────────────────────── */
function buildDenomChips(total) {
  var denoms = [2000,5000,10000,20000,50000,100000];
  var chips  = denoms.filter(function(d){ return d >= total; });
  /* tambahkan pecahan pembulatan ke atas ke ribuan terdekat */
  var rounded = Math.ceil(total / 1000) * 1000;
  if (rounded !== total && !chips.includes(rounded)) chips.unshift(rounded);
  /* urutkan & buang duplikasi */
  chips = [...new Set(chips)].sort(function(a,b){ return a-b; }).slice(0,6);
  var wrap = document.getElementById('denom-chips-wrap');
  if (!wrap) return;
  wrap.innerHTML = chips.map(function(d){
    return '<button class="denom-chip" data-val="'+d+'">'+rp(d)+'</button>';
  }).join('');
  wrap.querySelectorAll('.denom-chip').forEach(function(btn){
    btn.addEventListener('click', function(){
      var inp = document.getElementById('cash-diterima-input');
      if (inp) { inp.value = this.dataset.val; inp.dispatchEvent(new Event('input')); }
      wrap.querySelectorAll('.denom-chip').forEach(function(b){ b.classList.remove('active'); });
      this.classList.add('active');
    });
  });
}

/* ── Realtime WebSocket ────────────────────────────────────────────────── */
function initRealtime(SUPABASE_URL, SUPABASE_ANON, onInsert) {
  window.__kasirWsCallback = onInsert;
  if (window.__kasirWsConnected) return;
  if (!SUPABASE_URL || !SUPABASE_ANON) return;
  window.__kasirWsConnected = true;

  var wsUrl = SUPABASE_URL.replace('https://','wss://') +
    '/realtime/v1/websocket?apikey=' + SUPABASE_ANON + '&vsn=1.0.0';

  function connect() {
    try {
      var ws = new WebSocket(wsUrl);
      ws.onopen = function() {
        ws.send(JSON.stringify({
          topic:'realtime:public:transaksi', event:'phx_join',
          payload:{config:{postgres_changes:[{event:'INSERT',schema:'public',table:'transaksi'}]}},
          ref:'1'
        }));
      };
      ws.onmessage = function(msg) {
        try {
          var d = JSON.parse(msg.data);
          if (d.event === 'phx_reply' && d.ref === 'heartbeat')
            ws.send(JSON.stringify({topic:'phoenix',event:'heartbeat',payload:{},ref:'hb'}));
          if (d.event === 'postgres_changes' || (d.payload && d.payload.type === 'INSERT'))
            if (window.__kasirWsCallback) window.__kasirWsCallback();
        } catch(e) {}
      };
      ws.onclose = function() { setTimeout(connect, 5000); };
      setInterval(function() {
        if (ws.readyState === WebSocket.OPEN)
          ws.send(JSON.stringify({topic:'phoenix',event:'heartbeat',payload:{},ref:'hb'}));
      }, 30000);
    } catch(e) { setTimeout(connect, 8000); }
  }
  connect();
}

/* ══════════════════════════════════════════════════════════════════════════
   INIT
══════════════════════════════════════════════════════════════════════════ */
function initKasir() {
  if (!document.getElementById('prod-grid')) return;

  var cfg = document.getElementById('app-config');
  var SUPABASE_URL  = cfg ? (cfg.dataset.sbUrl  || '') : '';
  var SUPABASE_ANON = cfg ? (cfg.dataset.sbAnon || '') : '';
  var BUCKET = 'produk-foto';

  var cart        = [];
  var activeKat   = 'semua';
  var searchQ     = '';
  var sheetOpen   = false;
  var _qrisTotal  = 0;
  var _histLoaded = false;
  var _imgLoaded  = new Set();

  /* diskon state */
  var diskon = { type: 'persen', value: 0 };  /* type: 'persen' | 'nominal' */

  /* last transaction state (for struk) */
  var _lastTrx = null;

  /* ── Sidebar ──────────────────────────────────────────────────────────── */
  var btnSidebar = document.getElementById('btn-open-sidebar');
  if (btnSidebar) btnSidebar.addEventListener('click', function(){ if (window.openSidebar) window.openSidebar(); });

  /* ── QRIS image ───────────────────────────────────────────────────────── */
  var qrisImg   = document.getElementById('qris-img');
  var qrisNoImg = document.getElementById('qris-no-img');
  if (qrisImg) {
    qrisImg.addEventListener('error', function(){ qrisImg.style.display='none'; if(qrisNoImg) qrisNoImg.style.display='flex'; });
    qrisImg.addEventListener('click', function(){ var lb=document.getElementById('qris-lightbox'); if(lb) lb.classList.add('open'); });
  }

  /* ── Lightbox ─────────────────────────────────────────────────────────── */
  var lightbox = document.getElementById('qris-lightbox');
  if (lightbox) lightbox.addEventListener('click', function(){ lightbox.classList.remove('open'); });
  var lbClose = document.getElementById('qris-lightbox-close');
  if (lbClose) lbClose.addEventListener('click', function(e){ e.stopPropagation(); if(lightbox) lightbox.classList.remove('open'); });

  /* ── Lazy images ─────────────────────────────────────────────────────── */
  function loadImages() {
    document.querySelectorAll('.prod-card:not(.card-hidden)').forEach(function(card){
      var id = card.dataset.id;
      if (_imgLoaded.has(id)) return;
      var thumb = card.querySelector('.prod-thumb');
      if (!thumb || thumb.querySelector('img')) return;
      _imgLoaded.add(id);
      var img = document.createElement('img');
      img.alt = card.dataset.namaAsli || '';
      img.loading='lazy'; img.decoding='async';
      img.onload  = function(){ img.classList.add('loaded'); var ph=thumb.querySelector('.prod-thumb-icon'); if(ph) ph.style.display='none'; };
      img.onerror = function(){ _imgLoaded.delete(id); };
      img.src = SUPABASE_URL+'/storage/v1/object/public/'+BUCKET+'/'+id+'.webp';
      thumb.insertBefore(img, thumb.querySelector('.prod-qty-badge'));
    });
  }

  /* ── Filter ──────────────────────────────────────────────────────────── */
  function applyFilter() {
    var q=searchQ.toLowerCase().trim(), vis=0;
    document.querySelectorAll('.prod-card').forEach(function(card){
      var ok=(activeKat==='semua'||card.dataset.kat===activeKat)&&(!q||card.dataset.nama.includes(q));
      card.classList.toggle('card-hidden',!ok);
      if(ok) vis++;
    });
    var el=document.getElementById('no-hasil');
    if(el) el.classList.toggle('show',vis===0);
    setTimeout(loadImages,40);
  }

  /* ── Sync badges ─────────────────────────────────────────────────────── */
  function syncCards() {
    document.querySelectorAll('.prod-card').forEach(function(card){
      var item=cart.find(function(i){ return i.id===card.dataset.id; });
      var badge=card.querySelector('.prod-qty-badge');
      card.classList.toggle('in-cart',!!item);
      if(badge){
        var prev=badge.textContent;
        badge.textContent=item?String(item.qty):'';
        if(item&&prev!==String(item.qty)){
          badge.classList.remove('pop'); void badge.offsetWidth; badge.classList.add('pop');
          setTimeout(function(){ badge.classList.remove('pop'); },250);
        }
      }
    });
  }

  /* ── Diskon calculation ──────────────────────────────────────────────── */
  function calcDiskon(subtotal) {
    if (!diskon.value || diskon.value <= 0) return 0;
    if (diskon.type === 'persen') {
      var pct = Math.min(diskon.value, 100);
      return Math.round(subtotal * pct / 100);
    }
    return Math.min(diskon.value, subtotal);
  }

  function getTotal() {
    var sub = cart.reduce(function(s,i){ return s+i.jual*i.qty; },0);
    return Math.max(0, sub - calcDiskon(sub));
  }

  /* ── Breakdown HTML ──────────────────────────────────────────────────── */
  function makeBreakdownHTML() {
    var sub  = cart.reduce(function(s,i){ return s+i.jual*i.qty; },0);
    var disc = calcDiskon(sub);
    var tot  = Math.max(0, sub - disc);
    if (!disc) return '';
    return '<div class="cart-summary-row"><span>Subtotal</span><span>'+rp(sub)+'</span></div>' +
           '<div class="cart-summary-row discount"><span>Diskon</span><span>−'+rp(disc)+'</span></div>' +
           '<div class="cart-summary-row total-final"><span>Total Bayar</span><span>'+rp(tot)+'</span></div>';
  }

  /* ── Cart HTML ───────────────────────────────────────────────────────── */
  function makeCartRows() {
    return cart.map(function(item,idx){
      return '<div class="cart-row">'+
        '<div class="cr-info"><div class="cr-name">'+esc(item.nama)+'</div>'+
        '<div class="cr-price">'+rp(item.jual)+' / item</div></div>'+
        '<div class="cr-qty">'+
          '<button class="qty-btn" data-a="dec" data-i="'+idx+'" aria-label="Kurangi">−</button>'+
          '<span class="qty-n">'+item.qty+'</span>'+
          '<button class="qty-btn" data-a="inc" data-i="'+idx+'" aria-label="Tambah">+</button>'+
        '</div>'+
        '<div class="cr-sub">'+rp(item.jual*item.qty)+'</div>'+
        '<button class="cr-del" data-a="del" data-i="'+idx+'" aria-label="Hapus">'+
          '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">'+
            '<line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>'+
        '</button></div>';
    }).join('');
  }

  function bindCartActions(container) {
    container.querySelectorAll('[data-a]').forEach(function(btn){
      btn.addEventListener('click', function(e){
        e.stopPropagation();
        var idx=parseInt(this.dataset.i), act=this.dataset.a;
        if(act==='inc')      cart[idx].qty++;
        else if(act==='dec'){ cart[idx].qty--; if(cart[idx].qty<=0) cart.splice(idx,1); }
        else if(act==='del') cart.splice(idx,1);
        renderAll();
      });
    });
  }

  function setList(listEl, emptyEl, html) {
    if(!listEl) return;
    listEl.querySelectorAll('.cart-row').forEach(function(r){ r.remove(); });
    if(!cart.length){ if(emptyEl) emptyEl.style.display=''; return; }
    if(emptyEl) emptyEl.style.display='none';
    var tmp=document.createElement('div');
    tmp.innerHTML=html;
    while(tmp.firstChild) listEl.appendChild(tmp.firstChild);
    bindCartActions(listEl);
  }

  /* ── Render ──────────────────────────────────────────────────────────── */
  function renderAll() {
    syncCards();
    var sub   = cart.reduce(function(s,i){ return s+i.jual*i.qty; },0);
    var disc  = calcDiskon(sub);
    var total = Math.max(0, sub - disc);
    var count = cart.length;
    var items = cart.reduce(function(s,i){ return s+i.qty; },0);
    var html  = makeCartRows();
    var bdHtml = makeBreakdownHTML();

    ['d','m'].forEach(function(p){
      var cnt=document.getElementById(p+'-count');
      var tot=document.getElementById(p+'-total');
      var itm=document.getElementById(p+'-items');
      var qr =document.getElementById(p+'-qris');
      var ca =document.getElementById(p+'-cash');
      var sa =document.getElementById(p+'-summary-area');
      var bd =document.getElementById(p+'-cart-breakdown');
      var dbadge=document.getElementById(p+'-diskon-badge');
      var dbadgeTxt=document.getElementById(p+'-diskon-badge-txt');

      if(cnt){ cnt.textContent=count; cnt.classList.toggle('live',count>0); }
      if(tot) tot.textContent=rp(total);
      if(itm) itm.textContent=items;
      if(qr)  qr.disabled=count===0;
      if(ca)  ca.disabled=count===0;
      if(sa)  sa.classList.toggle('hidden',count===0);
      if(bd)  bd.innerHTML=bdHtml;

      /* diskon badge */
      if(dbadge && dbadgeTxt){
        if(disc>0){
          dbadgeTxt.textContent = diskon.type==='persen'? diskon.value+'%' : '−'+rp(diskon.value);
          dbadge.classList.remove('hidden');
        } else {
          dbadge.classList.add('hidden');
        }
      }
    });

    setList(document.getElementById('d-list'), document.getElementById('d-empty'), html);
    setList(document.getElementById('m-list'), document.getElementById('m-empty'), html);

    var fabLbl=document.getElementById('fab-label');
    var fabBadge=document.getElementById('fab-badge');
    if(fabLbl)   fabLbl.textContent  =count>0?rp(total):'Keranjang';
    if(fabBadge){ fabBadge.textContent=items; fabBadge.style.display=items>0?'':'none'; }
  }

  /* ── Add to cart ─────────────────────────────────────────────────────── */
  function addToCart(id,nama,jual,beli){
    var ex=cart.find(function(i){ return i.id===id; });
    if(ex) ex.qty++; else cart.push({id:id,nama:nama,jual:+jual,beli:+beli,qty:1});
    renderAll();
  }

  /* ── Modal helpers ───────────────────────────────────────────────────── */
  function openModal(id){ var el=document.getElementById('modal-'+id); if(el) el.classList.add('open'); document.body.style.overflow='hidden'; }
  function closeModal(id){ var el=document.getElementById('modal-'+id); if(el) el.classList.remove('open'); if(!sheetOpen) document.body.style.overflow=''; }
  function openSheet(){
    var se=document.getElementById('cart-sheet'),bd=document.getElementById('sheet-backdrop');
    if(se) se.classList.add('open'); if(bd) bd.classList.add('visible');
    document.body.style.overflow='hidden'; sheetOpen=true;
  }
  function closeSheet(){
    var se=document.getElementById('cart-sheet'),bd=document.getElementById('sheet-backdrop');
    if(se) se.classList.remove('open'); if(bd) bd.classList.remove('visible');
    document.body.style.overflow=''; sheetOpen=false;
  }

  /* ── Nota (notes) toggle ─────────────────────────────────────────────── */
  function bindNotaToggle(btnId, areaId) {
    var btn = document.getElementById(btnId);
    var area = document.getElementById(areaId);
    if (!btn || !area) return;
    btn.addEventListener('click', function(){
      var hidden = area.classList.contains('hidden');
      area.classList.toggle('hidden', !hidden);
      if (!hidden) {
        /* cleared when closed */
        var inp = area.querySelector('textarea');
        /* keep value, just hide */
      }
    });
  }
  bindNotaToggle('d-nota-toggle', 'd-nota-area');
  bindNotaToggle('m-nota-toggle', 'm-nota-area');

  /* ── Diskon toggle & logic ───────────────────────────────────────────── */
  function bindDiskonToggle(btnId, panelId) {
    var btn   = document.getElementById(btnId);
    var panel = document.getElementById(panelId);
    if (!btn || !panel) return;
    btn.addEventListener('click', function(){
      var open = panel.classList.contains('open');
      panel.classList.toggle('open', !open);
      btn.classList.toggle('open', !open);
      var chevron = btn.querySelector('svg');
      if (chevron) chevron.style.transform = !open ? 'rotate(180deg)' : '';
    });
  }
  bindDiskonToggle('d-diskon-toggle', 'd-diskon-panel');
  bindDiskonToggle('m-diskon-toggle', 'm-diskon-panel');

  /* diskon type tabs — both panels share same state */
  document.querySelectorAll('.diskon-type-tab').forEach(function(tab){
    tab.addEventListener('click', function(){
      var target = this.dataset.target; /* 'd' or 'm' */
      var type   = this.dataset.type;
      diskon.type  = type;
      diskon.value = 0;
      /* update both panels visually */
      ['d','m'].forEach(function(p){
        document.querySelectorAll('[data-target="'+p+'"].diskon-type-tab').forEach(function(t){
          t.classList.toggle('active', t.dataset.type===type);
        });
        var suf = document.getElementById(p+'-diskon-suffix');
        var inp = document.getElementById(p+'-diskon-input');
        if(suf) suf.textContent = type==='persen'?'%':'';
        if(inp){ inp.value=''; inp.placeholder = type==='persen'?'0':'0'; }
      });
      renderAll();
    });
  });

  /* diskon input — sync between d & m */
  ['d','m'].forEach(function(p){
    var inp = document.getElementById(p+'-diskon-input');
    if(!inp) return;
    inp.addEventListener('input', function(){
      var v = parseFloat(this.value)||0;
      if(diskon.type==='persen') v=Math.min(v,100);
      diskon.value = v;
      /* sync sibling */
      var other = p==='d'?'m':'d';
      var otherInp = document.getElementById(other+'-diskon-input');
      if(otherInp && otherInp !== document.activeElement) otherInp.value = this.value;
      renderAll();
    });
  });

  /* ── Checkout ────────────────────────────────────────────────────────── */
  function getNota() {
    var dn = document.getElementById('d-nota-input');
    var mn = document.getElementById('m-nota-input');
    return (dn && dn.value.trim()) || (mn && mn.value.trim()) || '';
  }

  function doQris(){
    if(!cart.length) return;
    closeSheet();
    _qrisTotal = getTotal();
    document.getElementById('qris-total-disp').textContent = rp(_qrisTotal);
    openModal('qris');
  }

  function doCash(){
    if(!cart.length) return;
    closeSheet();
    var total = getTotal();
    document.getElementById('cash-disp').textContent = rp(total);
    var inp = document.getElementById('cash-diterima-input');
    if(inp){ inp.value=''; }
    /* reset kembalian box */
    var kb=document.getElementById('kembalian-box'),kv=document.getElementById('kembalian-val'),kh=document.getElementById('kembalian-hint');
    if(kb){ kb.className='kembalian-box idle'; }
    if(kv) kv.textContent='—';
    if(kh) kh.textContent='Masukkan nominal uang diterima';
    /* confirm button disabled until valid */
    var cf=document.getElementById('cash-confirm');
    if(cf) cf.disabled=true;
    buildDenomChips(total);
    openModal('cash');
  }

  async function saveTrx(total, metode, status, nota) {
    var items = cart.map(function(i){ return {produk_id:i.id,nama_produk:i.nama,harga_jual:i.jual,harga_beli:i.beli,qty:i.qty}; });
    var sub   = cart.reduce(function(s,i){ return s+i.jual*i.qty; },0);
    var disc  = calcDiskon(sub);
    return await api('POST','/dashboard/api/kasir/transaksi',{
      total:total, metode_bayar:metode, status:status, items:items,
      diskon: disc || undefined, catatan: nota || undefined
    });
  }

  /* ── Struk builder ───────────────────────────────────────────────────── */
  function buildStruk(trxData) {
    var now   = trxData ? new Date(trxData.created_at) : new Date();
    var items = trxData ? (trxData.items||[]) : cart.map(function(i){ return {nama_produk:i.nama,harga_jual:i.jual,qty:i.qty}; });
    var sub   = items.reduce(function(s,i){ return s+(i.harga_jual*i.qty); },0);
    var total = trxData ? trxData.total : getTotal();
    var disc  = sub - total;
    var metode = trxData ? trxData.metode_bayar : '—';
    var nota   = trxData ? (trxData.catatan||'') : getNota();
    var diterima = trxData ? (trxData.uang_diterima||0) : _lastTrx ? (_lastTrx.uang_diterima||0) : 0;
    var kembalian = diterima > 0 ? diterima - total : 0;

    var rows = items.map(function(i){
      return '<div class="struk-row"><span>'+esc(i.nama_produk)+' x'+i.qty+'</span><span>'+rp(i.harga_jual*i.qty)+'</span></div>';
    }).join('');

    var discRow = disc>0 ? '<div class="struk-row"><span>Diskon</span><span>−'+rp(disc)+'</span></div>' : '';
    var kemRow  = diterima>0 ?
      '<div class="struk-row"><span>Uang diterima</span><span>'+rp(diterima)+'</span></div>'+
      '<div class="struk-row"><span>Kembalian</span><span>'+rp(kembalian)+'</span></div>' : '';
    var notaRow = nota ? '<div style="font-size:.68rem;color:#6b7280;margin-top:4px">Catatan: '+esc(nota)+'</div>' : '';

    return '<div class="struk-title">Struk Pembelian</div>'+
      '<div class="struk-sub">'+now.toLocaleDateString('id-ID',{day:'2-digit',month:'long',year:'numeric'})+' '+now.toLocaleTimeString('id-ID',{hour:'2-digit',minute:'2-digit'})+'</div>'+
      '<hr class="struk-sep"/>'+
      rows+
      (disc>0?'<hr class="struk-sep"/>'+discRow:'')+''+
      '<hr class="struk-sep"/>'+
      '<div class="struk-total"><span>TOTAL</span><span>'+rp(total)+'</span></div>'+
      '<div class="struk-row" style="font-size:.72rem;color:#6b7280"><span>Metode</span><span>'+(metode==='qris'?'QRIS':'Cash')+'</span></div>'+
      kemRow+
      notaRow+
      '<hr class="struk-sep"/>'+
      '<div class="struk-footer">Terima kasih sudah berbelanja!</div>';
  }

  function showStruk(trxData) {
    var sc = document.getElementById('struk-content');
    if(sc) sc.innerHTML = buildStruk(trxData);
    openModal('struk');
  }

  /* ── Show sukses ─────────────────────────────────────────────────────── */
  function showSukses(total, metode, diterima) {
    window.__playSuccess && window.__playSuccess();
    document.getElementById('sukses-total').textContent  = rp(total);
    document.getElementById('sukses-metode').textContent = 'Metode: '+metode;

    /* kembalian di sukses modal */
    var kemWrap = document.getElementById('sukses-kembalian-wrap');
    var kemVal  = document.getElementById('sukses-kembalian-val');
    var kemHint = document.getElementById('sukses-kembalian-hint');
    if(kemWrap && kemVal){
      if(diterima && diterima > total){
        var kembalian = diterima - total;
        kemVal.textContent  = rp(kembalian);
        if(kemHint) kemHint.textContent = 'Dari '+rp(diterima)+' yang diterima';
        kemWrap.classList.remove('hidden');
      } else {
        kemWrap.classList.add('hidden');
      }
    }

    openModal('sukses');
    cart=[]; diskon={type:'persen',value:0};
    /* reset nota */
    ['d-nota-input','m-nota-input'].forEach(function(id){ var el=document.getElementById(id); if(el) el.value=''; });
    ['d-nota-area','m-nota-area'].forEach(function(id){ var el=document.getElementById(id); if(el) el.classList.add('hidden'); });
    ['d-diskon-input','m-diskon-input'].forEach(function(id){ var el=document.getElementById(id); if(el) el.value=''; });
    renderAll();
    loadHistory();
  }

  /* ── History ─────────────────────────────────────────────────────────── */
  async function loadHistory() {
    _histLoaded = true;
    try {
      var data = await api('GET','/dashboard/api/kasir/transaksi');
      var el   = document.getElementById('hist-list');
      var strip = document.getElementById('shift-strip');

      if(!data || !data.length){
        if(el) el.innerHTML='<div class="hist-placeholder">Belum ada transaksi hari ini</div>';
        if(strip) strip.classList.add('hidden');
      } else {
        /* shift stats */
        var totalOmset = data.reduce(function(s,t){ return s+t.total; },0);
        var totalQris  = data.filter(function(t){ return t.metode_bayar==='qris'; }).length;
        var totalCash  = data.filter(function(t){ return t.metode_bayar==='cash'; }).length;
        var sEl = function(id,txt){ var e=document.getElementById(id); if(e) e.textContent=txt; };
        sEl('shift-trx',   data.length);
        sEl('shift-omset', rp(totalOmset));
        sEl('shift-qris',  totalQris);
        sEl('shift-cash',  totalCash);
        if(strip) strip.classList.remove('hidden');

        if(el) el.innerHTML = data.map(function(trx){
          var isQ=trx.metode_bayar==='qris', itms=trx.transaksi_item||[];
          var summ=itms.slice(0,2).map(function(i){ return esc(i.nama_produk)+'×'+i.qty; }).join(', ');
          if(itms.length>2) summ+=' +'+(itms.length-2)+' lainnya';
          return '<div class="hist-row-item" data-trx-id="'+trx.id+'">'+
            '<div class="hri-top">'+
            '<span class="hri-amt">'+rp(trx.total)+'</span>'+
            '<div class="hri-meta"><span class="hri-badge '+(isQ?'badge-qris':'badge-cash')+'">'+(isQ?'QRIS':'Cash')+'</span>'+
            '<span class="hri-time">'+timeStr(trx.created_at)+'</span></div></div>'+
            (summ?'<div class="hri-prods">'+summ+'</div>':'')+
            (trx.catatan?'<div style="font-size:.63rem;color:#9ca3af;margin-top:2px">📝 '+esc(trx.catatan)+'</div>':'')+
            '<div class="hri-actions">'+
              '<button class="hri-void-btn" data-trx-id="'+trx.id+'" data-amt="'+trx.total+'">'+
                'Lihat Struk'+
              '</button>'+
            '</div>'+
            '</div>';
        }).join('');

        /* bind struk buttons */
        if(el) el.querySelectorAll('.hri-void-btn').forEach(function(btn){
          btn.addEventListener('click', function(){
            var trxId = this.dataset.trxId;
            var matched = data.find(function(t){ return String(t.id)===String(trxId); });
            if(matched){
              /* attach items from transaksi_item */
              var strucData = Object.assign({}, matched, {
                items: (matched.transaksi_item||[]).map(function(i){
                  return {nama_produk:i.nama_produk, harga_jual:i.harga_jual, qty:i.qty};
                })
              });
              showStruk(strucData);
            }
          });
        });
      }

      var st = document.getElementById('stat-today');
      var total = (data||[]).reduce(function(s,t){ return s+t.total; },0);
      if(st) st.textContent = rp(total);

    } catch(e) {
      var el2=document.getElementById('hist-list');
      if(el2) el2.innerHTML='<div class="hist-placeholder error">Gagal memuat histori</div>';
    }
  }

  function clearCart(){
    if(!cart.length || !confirm('Kosongkan keranjang?')) return;
    cart=[]; renderAll();
  }

  /* ══ EVENT LISTENERS ══════════════════════════════════════════════════ */

  /* QC Bar */
  var bar = document.getElementById('qc-bar');
  if(bar){
    var updateFade=function(){ var atEnd=bar.scrollLeft+bar.clientWidth>=bar.scrollWidth-4; var mask=atEnd?'none':'linear-gradient(to right,black 0%,black 85%,transparent 100%)'; bar.style.webkitMaskImage=mask; bar.style.maskImage=mask; };
    bar.addEventListener('scroll',updateFade,{passive:true}); updateFade();
    var isDn=false,stX,scL;
    bar.addEventListener('mousedown',function(e){ isDn=true; stX=e.pageX-bar.offsetLeft; scL=bar.scrollLeft; bar.style.cursor='grabbing'; });
    document.addEventListener('mouseup',function(){ isDn=false; bar.style.cursor=''; });
    bar.addEventListener('mousemove',function(e){ if(!isDn) return; e.preventDefault(); bar.scrollLeft=scL-(e.pageX-bar.offsetLeft-stX)*1.2; });
    bar.addEventListener('click',function(e){
      var btn=e.target.closest('.qc-item');
      if(!btn) return;
      addToCart(btn.dataset.id,btn.dataset.nama,btn.dataset.jual,btn.dataset.beli);
      toast('+ '+btn.dataset.nama);
    });
  }

  /* Search */
  var sp=document.getElementById('s-produk');
  if(sp) sp.addEventListener('input',function(){ searchQ=this.value; applyFilter(); });

  /* Kategori */
  var kb=document.getElementById('kat-bar');
  if(kb) kb.addEventListener('click',function(e){
    var btn=e.target.closest('.kat-btn');
    if(!btn) return;
    document.querySelectorAll('.kat-btn').forEach(function(b){ b.classList.remove('on'); b.setAttribute('aria-selected','false'); });
    btn.classList.add('on'); btn.setAttribute('aria-selected','true');
    activeKat=btn.dataset.kat; applyFilter();
  });

  /* Produk grid */
  var pg=document.getElementById('prod-grid');
  if(pg){
    pg.addEventListener('click',function(e){ var c=e.target.closest('.prod-card'); if(c) addToCart(c.dataset.id,c.dataset.namaAsli,c.dataset.jual,c.dataset.beli); });
    pg.addEventListener('keydown',function(e){
      if(e.key!=='Enter'&&e.key!==' ') return;
      var c=e.target.closest('.prod-card');
      if(c){ e.preventDefault(); addToCart(c.dataset.id,c.dataset.namaAsli,c.dataset.jual,c.dataset.beli); }
    });
  }

  /* Clear */
  var dc=document.getElementById('d-clear'); if(dc) dc.addEventListener('click',clearCart);
  var mc2=document.getElementById('m-clear'); if(mc2) mc2.addEventListener('click',clearCart);

  /* Mobile sheet */
  var fab=document.getElementById('cart-fab'); if(fab) fab.addEventListener('click',openSheet);
  var sc=document.getElementById('sheet-close'); if(sc) sc.addEventListener('click',closeSheet);
  var bd2=document.getElementById('sheet-backdrop'); if(bd2) bd2.addEventListener('click',closeSheet);
  var she=document.getElementById('cart-sheet');
  if(she){
    var sy=0,isd=false;
    she.addEventListener('touchstart',function(e){ sy=e.touches[0].clientY; isd=true; },{passive:true});
    she.addEventListener('touchend',function(e){ if(isd&&e.changedTouches[0].clientY-sy>80) closeSheet(); isd=false; },{passive:true});
  }

  /* QRIS */
  var dq=document.getElementById('d-qris'); if(dq) dq.addEventListener('click',doQris);
  var mq2=document.getElementById('m-qris'); if(mq2) mq2.addEventListener('click',doQris);
  var cq=document.getElementById('close-qris');
  var cqb=document.getElementById('close-qris-bottom');
  function hcq(){ closeModal('qris'); _qrisTotal=0; }
  if(cq)  cq.addEventListener('click',hcq);
  if(cqb) cqb.addEventListener('click',hcq);
  var qcb=document.getElementById('qris-confirm-btn');
  if(qcb) qcb.addEventListener('click',async function(){
    if(!_qrisTotal) return;
    this.disabled=true; this.textContent='Menyimpan…';
    try {
      await saveTrx(_qrisTotal,'qris','paid',getNota());
      _lastTrx = {total:_qrisTotal, metode_bayar:'qris', created_at:new Date().toISOString(), items:cart.map(function(i){ return {nama_produk:i.nama,harga_jual:i.jual,qty:i.qty}; })};
      closeModal('qris');
      showSukses(_qrisTotal,'QRIS',0);
      _qrisTotal=0;
    } catch(e){
      toast('Gagal: '+e.message,false); this.disabled=false; this.textContent='✓ Konfirmasi Sudah Bayar';
    }
  });

  /* Cash: uang diterima input */
  var cashInp = document.getElementById('cash-diterima-input');
  if(cashInp){
    cashInp.addEventListener('input', function(){
      var totalStr = document.getElementById('cash-disp').textContent;
      /* extract numeric from rp string */
      var total = getTotal();
      var diterima = parseFloat(this.value)||0;
      var kb2=document.getElementById('kembalian-box');
      var kv=document.getElementById('kembalian-val');
      var kh=document.getElementById('kembalian-hint');
      var cf=document.getElementById('cash-confirm');

      /* clear active chip */
      document.querySelectorAll('.denom-chip').forEach(function(b){ b.classList.toggle('active', +b.dataset.val===diterima); });

      if(diterima<=0){
        if(kb2) kb2.className='kembalian-box idle';
        if(kv) kv.textContent='—';
        if(kh) kh.textContent='Masukkan nominal uang diterima';
        if(cf) cf.disabled=true;
      } else if(diterima < total){
        var kurang = total-diterima;
        if(kb2) kb2.className='kembalian-box warn';
        if(kv) kv.textContent='Kurang '+rp(kurang);
        if(kh) kh.textContent='Uang belum cukup untuk menutup tagihan';
        if(cf) cf.disabled=true;
      } else {
        var kembalian=diterima-total;
        if(kb2) kb2.className='kembalian-box ok';
        if(kv) kv.textContent=rp(kembalian);
        if(kh) kh.textContent= kembalian===0 ? 'Uang pas — tidak ada kembalian' : 'Kembalikan ke pelanggan';
        if(cf) cf.disabled=false;
      }
    });
  }

  /* Cash exact button */
  var exactBtn=document.getElementById('cash-exact-btn');
  if(exactBtn) exactBtn.addEventListener('click',function(){
    var total=getTotal();
    var inp=document.getElementById('cash-diterima-input');
    if(inp){ inp.value=String(total); inp.dispatchEvent(new Event('input')); }
    document.querySelectorAll('.denom-chip').forEach(function(b){ b.classList.remove('active'); });
  });

  /* Cash close */
  var closeCashTop=document.getElementById('close-cash-top');
  var cashCancel=document.getElementById('cash-cancel');
  function closeCashModal(){ closeModal('cash'); }
  if(closeCashTop) closeCashTop.addEventListener('click',closeCashModal);
  if(cashCancel) cashCancel.addEventListener('click',closeCashModal);

  /* Cash confirm */
  var cf=document.getElementById('cash-confirm');
  if(cf) cf.addEventListener('click', async function(){
    var total=getTotal();
    var diterima=parseFloat(document.getElementById('cash-diterima-input').value)||0;
    this.disabled=true; this.textContent='Menyimpan…';
    try {
      _lastTrx = {total:total, metode_bayar:'cash', created_at:new Date().toISOString(), uang_diterima:diterima,
        items:cart.map(function(i){ return {nama_produk:i.nama,harga_jual:i.jual,qty:i.qty}; })};
      await saveTrx(total,'cash','paid',getNota());
      closeModal('cash'); showSukses(total,'Cash',diterima);
    } catch(e){ toast('Gagal: '+e.message,false); }
    finally{ this.disabled=false; this.textContent='Konfirmasi Lunas'; }
  });

  /* Desktop cash also */
  var dca=document.getElementById('d-cash'); if(dca) dca.addEventListener('click',doCash);
  var mca=document.getElementById('m-cash'); if(mca) mca.addEventListener('click',doCash);

  /* Sukses */
  var csBtn=document.getElementById('close-sukses');
  if(csBtn) csBtn.addEventListener('click',function(){ closeModal('sukses'); var s=document.getElementById('s-produk'); if(s) s.focus(); });

  var btnLihatStruk=document.getElementById('btn-lihat-struk');
  if(btnLihatStruk) btnLihatStruk.addEventListener('click',function(){
    closeModal('sukses');
    showStruk(_lastTrx);
  });

  /* Struk modal */
  var closeStruk=document.getElementById('close-struk');
  var closeStrukBot=document.getElementById('close-struk-bottom');
  if(closeStruk)    closeStruk.addEventListener('click',function(){ closeModal('struk'); });
  if(closeStrukBot) closeStrukBot.addEventListener('click',function(){ closeModal('struk'); });

  /* Print */
  var printBtn=document.getElementById('btn-print-struk');
  if(printBtn) printBtn.addEventListener('click',function(){
    var sc2=document.getElementById('struk-content');
    if(!sc2) return;
    var win=window.open('','_blank','width=400,height=600');
    if(!win) return;
    win.document.write('<html><head><title>Struk</title><style>body{font-family:monospace;font-size:13px;padding:16px;}.struk-row,.struk-total{display:flex;justify-content:space-between;}.struk-sep{border:none;border-top:1px dashed #ccc;margin:6px 0;}.struk-title{text-align:center;font-weight:700;}.struk-sub,.struk-footer{text-align:center;font-size:11px;color:#666;}</style></head><body>'+sc2.innerHTML+'</body></html>');
    win.document.close();
    win.focus();
    setTimeout(function(){ win.print(); },300);
  });

  /* Histori */
  var hb=document.getElementById('hist-btn');
  if(hb) hb.addEventListener('click',function(){
    var body=document.getElementById('hist-body'),chev=document.getElementById('hist-chev');
    var open=body.classList.contains('open');
    body.classList.toggle('open',!open);
    this.setAttribute('aria-expanded',String(!open));
    if(chev) chev.classList.toggle('open',!open);
    if(!open && !_histLoaded) loadHistory();
  });

  /* ESC */
  document.addEventListener('keydown',function(e){
    if(e.key!=='Escape') return;
    var lb=document.getElementById('qris-lightbox');
    if(lb&&lb.classList.contains('open')){ lb.classList.remove('open'); return; }
    ['struk','sukses','cash','qris'].forEach(function(id){
      var el=document.getElementById('modal-'+id);
      if(el&&el.classList.contains('open')) closeModal(id);
    });
  });

  /* Realtime */
  initRealtime(SUPABASE_URL, SUPABASE_ANON, function(){
    if(_histLoaded) loadHistory();
  });

  renderAll();
  setTimeout(loadImages,100);

} /* end initKasir */

/* ══ BOOTSTRAP ══ */
(function bootstrap(){
  if(document.readyState==='loading'){
    document.addEventListener('DOMContentLoaded',initKasir);
  } else {
    initKasir();
  }
})();
</script>

</Layout>
