---
// src/pages/kasir.astro
export const prerender = false;
import "../../styles/global.css";
import "../../styles/kasir.css";
import { createServiceClient } from "../../lib/supabase";
import Layout from "../../layouts/Layout.astro";

const accessToken = Astro.cookies.get("sb-access-token");
if (!accessToken?.value) return Astro.redirect("/");

const nonce = (Astro.locals as App.Locals).nonce ?? "";
const sb = createServiceClient();

const { data: produkRaw } = await sb
  .from("produk")
  .select("id, nama_produk, harga_jual, harga_beli, kategori, quick_cash")
  .order("nama_produk");

const produk = produkRaw ?? [];
const quickCashProduk = produk.filter((p) => p.quick_cash);

const PUBLIC_SUPABASE_URL      = import.meta.env.PUBLIC_SUPABASE_URL  as string;
const PUBLIC_SUPABASE_ANON_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY as string;

const QRIS_IMAGE_URL = '/qris.jpeg';

function rp(n: number) {
  return new Intl.NumberFormat("id-ID", {
    style: "currency", currency: "IDR", minimumFractionDigits: 0,
  }).format(n);
}

const kategoriList = [...new Set(produk.map(p => p.kategori).filter(Boolean))].sort();
---

<Layout title="Kasir" active="kasir" nonce={nonce}>

<!-- ═══════════════════════════════════════════════════════════════════════
     STYLES
════════════════════════════════════════════════════════════════════════ -->
<style nonce={nonce}>

  /* ── Wrapper utama ────────────────────────────────────────────── */
  .kasir-root {
    display: flex;
    flex-direction: column;
    height: 100%;
    min-height: 0;
    overflow: hidden;
  }

  /* ── Cart header: tidak ikut scroll ──────────────────────────── */
  .cart-header-fixed {
    flex-shrink: 0;
  }

  /* ── Hist toggle — inner span ─────────────────────────────────── */
  .hist-btn-inner {
    display: flex;
    align-items: center;
    gap: 5px;
  }

  /* ── Hist loading / empty / error placeholder ─────────────────── */
  .hist-placeholder {
    padding: 1.5rem;
    text-align: center;
    font-size: .69rem;
    color: #bbb;
  }
  .hist-placeholder.error { color: #f87171; }

  /* ── Sheet header: tombol aksi kanan ─────────────────────────── */
  .sheet-header-right {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  /* ── Sheet close button ───────────────────────────────────────── */
  .sheet-close-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--muted);
    padding: 4px;
    border-radius: 5px;
    display: flex;
    align-items: center;
    transition: background .1s;
  }
  .sheet-close-btn:hover { background: rgba(0,0,0,.06); }

  /* ── Mobile: empty state min-height ──────────────────────────── */
  .m-empty-state { min-height: 120px; }

  /* ── Mobile: cart footer border ───────────────────────────────── */
  .cart-footer-mobile { border-top: 1px solid var(--border); }

  /* ── Mobile: pay buttons row ──────────────────────────────────── */
  .cart-pay-btns-mobile { flex-direction: row; }

  /* ── Mobile: pay button sizing ────────────────────────────────── */
  .pay-btn-mobile { flex: 1; padding: 12px 8px; }

  /* ── QRIS modal sizing ────────────────────────────────────────── */
  .modal-qris-box  { max-width: 400px; }
  .modal-qris-head { padding: 16px 20px; }

  /* ── QRIS content column ──────────────────────────────────────── */
  .qris-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }

  /* ── QRIS total tagihan box ───────────────────────────────────── */
  .qris-total-box {
    width: 100%;
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
    border-radius: 8px;
    padding: 12px 14px;
    text-align: center;
  }
  .qris-total-label {
    font-size: .7rem;
    color: #16a34a;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .04em;
    margin-bottom: 2px;
  }
  .qris-total-val {
    font-size: 1.5rem;
    font-weight: 800;
    color: #15803d;
  }

  /* ── QRIS image ───────────────────────────────────────────────── */
  .qris-img {
    width: 100%;
    max-width: 280px;
    border-radius: 10px;
    border: 1px solid #e5e7eb;
    object-fit: contain;
    cursor: zoom-in;
  }

  /* ── QRIS no-image fallback ───────────────────────────────────── */
  .qris-no-img {
    display: none;
    flex-direction: column;
    padding: 24px;
    text-align: center;
    color: #9ca3af;
    font-size: .8rem;
    border: 1px dashed #d1d5db;
    border-radius: 10px;
    width: 100%;
    max-width: 280px;
  }
  .qris-no-img-icon  { margin: 0 auto 8px; display: block; }
  .qris-no-img-title { margin: 0 0 4px; font-weight: 600; color: #6b7280; }
  .qris-no-img-hint  { margin: 0; font-size: .72rem; }

  /* ── QRIS instruksi pembayaran ────────────────────────────────── */
  .qris-instruction {
    font-size: .75rem;
    color: #6b7280;
    line-height: 1.4;
  }

  /* ── QRIS modal footer ────────────────────────────────────────── */
  .qris-modal-footer {
    flex-shrink: 0;
    border-top: 1px solid #f3f4f6;
    background: rgba(249,250,251,.5);
    padding: 16px;
    display: flex;
    gap: 8px;
  }

  /* ── QRIS buttons ─────────────────────────────────────────────── */
  .qris-confirm-btn {
    flex: 1;
    padding: 12px;
    background: #000;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: .85rem;
    font-weight: 700;
    cursor: pointer;
    transition: background .2s, opacity .2s;
  }
  .qris-confirm-btn:hover    { background: #1a1a1a; }
  .qris-confirm-btn:disabled { opacity: .6; cursor: not-allowed; }

  .qris-cancel-btn {
    flex: 1;
    padding: 12px;
    background: #f3f4f6;
    color: #374151;
    border: none;
    border-radius: 8px;
    font-size: .85rem;
    font-weight: 600;
    cursor: pointer;
    transition: background .15s;
  }
  .qris-cancel-btn:hover { background: #e5e7eb; }

  /* ── Sukses / Cash modal sizing ───────────────────────────────── */
  .modal-sukses-box { max-width: 320px; }
  .modal-cash-box   { max-width: 360px; }

  /* ── QRIS Lightbox ────────────────────────────────────────────── */
  .qris-lightbox {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,.95);
    z-index: 9999;
    align-items: center;
    justify-content: center;
    cursor: zoom-out;
  }
  .qris-lightbox.open { display: flex; }

  .qris-lightbox-img {
    max-width: 92vw;
    max-height: 92vh;
    border-radius: 12px;
    object-fit: contain;
    pointer-events: none;
    box-shadow: 0 8px 40px rgba(0,0,0,.5);
  }

  .qris-lightbox-close {
    position: absolute;
    top: 16px;
    right: 16px;
    background: rgba(255,255,255,.15);
    backdrop-filter: blur(6px);
    border: 1px solid rgba(255,255,255,.2);
    border-radius: 50%;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #fff;
    transition: background .15s;
  }
  .qris-lightbox-close:hover { background: rgba(255,255,255,.25); }

  /* ── FAB badge: hidden by default ────────────────────────────── */
  .fab-badge-hidden { display: none; }

  /* ── Toast icon: flex-shrink ──────────────────────────────────── */
  .toast-ico { flex-shrink: 0; }

</style>

<!-- ══════════════════════════════════════════════════════════════════════
     APP CONFIG — Supabase credentials disimpan di data attribute pada
     elemen tersembunyi. Tidak menggunakan meta tag (mudah di-scrape)
     maupun define:vars (Astro inject wrapper script tanpa nonce → CSP
     violation). Data attribute hanya accessible via JS, tidak terindeks
     oleh scraper meta tag.
════════════════════════════════════════════════════════════════════════ -->
<div
  id="app-config"
  data-sb-url={PUBLIC_SUPABASE_URL}
  data-sb-anon={PUBLIC_SUPABASE_ANON_KEY}
  aria-hidden="true"
  style="display:none"
></div>

<!-- ══ MAIN LAYOUT ══ -->
<div class="kasir-root">
<div class="pos-wrap">

  <!-- LEFT: Products -->
  <div class="pos-left">

    <!-- Header -->
    <div class="pos-header">
      <button id="btn-open-sidebar"
        class="lg:hidden flex-shrink-0 w-8 h-8 flex items-center justify-center rounded text-gray-500 hover:bg-gray-100 transition-colors"
        aria-label="Menu">
        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>

      <h1 class="pos-brand">Kasir</h1>

      <div class="pos-search">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <label for="s-produk" class="sr-only">Cari produk</label>
        <input id="s-produk" type="search" placeholder="Cari produk…" autocomplete="off"/>
      </div>

      <!-- Desktop stat -->
      <div class="pos-stat">
        <span class="pos-stat-lbl">Omset hari ini</span>
        <span id="stat-today" class="pos-stat-val">—</span>
      </div>

      <!-- Mobile FAB -->
      <button class="cart-fab" id="cart-fab" aria-label="Buka keranjang">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        <span id="fab-label">Keranjang</span>
        <span class="cart-fab-badge fab-badge-hidden" id="fab-badge">0</span>
      </button>
    </div>

    <!-- Quick Cash -->
    {quickCashProduk.length > 0 && (
      <div class="qc-bar" id="qc-bar">
        <span class="qc-tag">⚡ Quick</span>
        <div class="qc-sep"></div>
        {quickCashProduk.map(p => (
          <button class="qc-item" type="button"
            data-id={p.id} data-nama={p.nama_produk}
            data-jual={p.harga_jual} data-beli={p.harga_beli}>
            <div class="qc-item-inner">
              <span>{p.nama_produk}</span>
              <small>{rp(p.harga_jual)}</small>
            </div>
          </button>
        ))}
      </div>
    )}

    <!-- Category -->
    <div class="kat-bar" id="kat-bar" role="tablist">
      <div class="kat-items-scroll">
        <button class="kat-btn on" data-kat="semua" role="tab" aria-selected="true">Semua</button>
        {kategoriList.map(k => (
          <button class="kat-btn" data-kat={k} role="tab" aria-selected="false">{k}</button>
        ))}
      </div>
    </div>

    <!-- Products -->
    <div class="prod-scroll">
      <div class="prod-grid" id="prod-grid" role="list">
        {produk.map(p => (
          <div
            class="prod-card"
            role="listitem" tabindex="0"
            data-id={p.id}
            data-nama={p.nama_produk.toLowerCase()}
            data-nama-asli={p.nama_produk}
            data-jual={p.harga_jual}
            data-beli={p.harga_beli}
            data-kat={p.kategori ?? ''}
            aria-label={`${p.nama_produk} — ${rp(p.harga_jual)}`}
          >
            <div class="prod-thumb">
              <svg class="prod-thumb-icon" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <path d="m3 9 4-4 4 4 4-5 6 7"/><circle cx="8.5" cy="7.5" r="1.5"/>
              </svg>
              <span class="prod-qty-badge" aria-hidden="true"></span>
            </div>
            <div>
              <div class="prod-name">{p.nama_produk}</div>
              <div class="prod-price">{rp(p.harga_jual)}</div>
            </div>
          </div>
        ))}
      </div>
      <div id="no-hasil">Produk tidak ditemukan.</div>
    </div>
  </div>

  <!-- RIGHT: Cart panel — desktop -->
  <div class="pos-right" id="cart-desktop">
    <div class="cart-header cart-header-fixed">
      <div class="cart-title">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        Keranjang
        <span class="cart-count" id="d-count">0</span>
      </div>
      <button class="btn-empty" id="d-clear">Kosongkan</button>
    </div>

    <div class="cart-items" id="d-list" aria-live="polite">
      <div class="cart-empty-state" id="d-empty">
        <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        <p>Keranjang kosong</p>
        <small>Ketuk produk untuk menambah</small>
      </div>
    </div>

    <div class="cart-footer">
      <div class="cart-total-row">
        <div>
          <span class="ct-lbl">Total</span>
          <div class="ct-val" id="d-total">Rp 0</div>
        </div>
        <div class="ct-items"><span id="d-items">0</span> item</div>
      </div>
      <div class="cart-pay-btns">
        <button class="pay-btn pay-qris" id="d-qris" disabled>
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
            <rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
          </svg>
          Bayar via QRIS
        </button>
        <button class="pay-btn pay-cash" id="d-cash" disabled>
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="6" width="20" height="12" rx="2"/>
            <circle cx="12" cy="12" r="2"/>
            <path d="M6 12h.01M18 12h.01"/>
          </svg>
          Cash / Manual
        </button>
      </div>

      <button class="hist-toggle" id="hist-btn" aria-expanded="false">
        <span class="hist-btn-inner">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
          </svg>
          Histori Hari Ini
        </span>
        <svg id="hist-chev" class="hist-chev" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <polyline points="18 15 12 9 6 15"/>
        </svg>
      </button>
      <div id="hist-body" class="hist-body">
        <div id="hist-list">
          <div class="hist-placeholder">Memuat…</div>
        </div>
      </div>
    </div>
  </div>
</div>
</div>

<!-- ══ MOBILE: Sheet backdrop ══ -->
<div id="sheet-backdrop" aria-hidden="true"></div>

<!-- ══ MOBILE: Cart bottom sheet ══ -->
<div id="cart-sheet" role="dialog" aria-modal="true" aria-label="Keranjang belanja">
  <div class="sheet-handle"></div>
  <div class="cart-header cart-header-fixed">
    <div class="cart-title">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
        <line x1="3" y1="6" x2="21" y2="6"/>
        <path d="M16 10a4 4 0 0 1-8 0"/>
      </svg>
      Keranjang
      <span class="cart-count" id="m-count">0</span>
    </div>
    <div class="sheet-header-right">
      <button class="btn-empty" id="m-clear">Kosongkan</button>
      <button id="sheet-close" class="sheet-close-btn" aria-label="Tutup keranjang">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
  </div>
  <div class="sheet-items" id="m-list" aria-live="polite">
    <div class="cart-empty-state m-empty-state" id="m-empty">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true">
        <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
        <line x1="3" y1="6" x2="21" y2="6"/>
        <path d="M16 10a4 4 0 0 1-8 0"/>
      </svg>
      <p>Keranjang kosong</p>
    </div>
  </div>
  <div class="cart-footer cart-footer-mobile">
    <div class="cart-total-row">
      <div>
        <span class="ct-lbl">Total</span>
        <div class="ct-val" id="m-total">Rp 0</div>
      </div>
      <div class="ct-items"><span id="m-items">0</span> item</div>
    </div>
    <div class="cart-pay-btns cart-pay-btns-mobile">
      <button class="pay-btn pay-qris pay-btn-mobile" id="m-qris" disabled>
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
          <rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
        </svg>
        QRIS
      </button>
      <button class="pay-btn pay-cash pay-btn-mobile" id="m-cash" disabled>
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="6" width="20" height="12" rx="2"/>
          <circle cx="12" cy="12" r="2"/>
          <path d="M6 12h.01M18 12h.01"/>
        </svg>
        Cash
      </button>
    </div>
  </div>
</div>

<!-- ══ MODAL: QRIS ══ -->
<div id="modal-qris" class="modal-wrap" role="dialog" aria-modal="true" aria-labelledby="mq-h">
  <div class="modal-box modal-qris-box flex flex-col max-h-[90vh] overflow-hidden !p-0">
    <div class="modal-head modal-qris-head !shrink-0 !static border-b border-gray-100">
      <h2 id="mq-h">Pembayaran QRIS</h2>
      <button id="close-qris" class="modal-close-btn" aria-label="Tutup">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
    <div class="flex-1 overflow-y-auto px-5 py-4 custom-scrollbar">
      <div class="qris-content">
        <div class="qris-total-box">
          <div class="qris-total-label">Total Tagihan</div>
          <div id="qris-total-disp" class="qris-total-val"></div>
        </div>
        <img id="qris-img" src={QRIS_IMAGE_URL} alt="QR Code QRIS" class="qris-img" />
        <div id="qris-no-img" class="qris-no-img">
          <svg class="qris-no-img-icon" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true">
            <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
            <rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
          </svg>
          <p class="qris-no-img-title">Foto QRIS belum tersedia</p>
          <p class="qris-no-img-hint">Simpan file di folder <code>public/qris.jpeg</code></p>
        </div>
        <div class="text-center space-y-2 pb-2">
          <p class="qris-instruction">
            1. Buka aplikasi e-wallet (Gopay/OVO/Dana) atau M-Banking.<br/>
            2. Scan QR di atas dan selesaikan pembayaran.<br/>
            3. Jika sudah, klik tombol konfirmasi di bawah.
          </p>
        </div>
      </div>
    </div>
    <div class="qris-modal-footer">
      <button id="qris-confirm-btn" class="qris-confirm-btn">
        ✓ Konfirmasi Sudah Bayar
      </button>
      <button id="close-qris-bottom" class="qris-cancel-btn">
        Batal
      </button>
    </div>
  </div>
</div>

<!-- ══ MODAL: Sukses ══ -->
<div id="modal-sukses" class="modal-wrap" role="alertdialog" aria-modal="true" aria-labelledby="ms-h">
  <div class="modal-box modal-sukses-box">
    <div class="success-wrap">
      <div class="success-ring">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      </div>
      <div class="success-h" id="ms-h">Transaksi Berhasil!</div>
      <p class="success-total">Total: <strong id="sukses-total"></strong></p>
      <p class="success-meta" id="sukses-metode"></p>
      <button class="btn-new-trx" id="close-sukses">Transaksi Baru</button>
    </div>
  </div>
</div>

<!-- ══ MODAL: Cash ══ -->
<div id="modal-cash" class="modal-wrap" role="alertdialog" aria-modal="true" aria-labelledby="mc-h">
  <div class="modal-box modal-cash-box">
    <div class="modal-head">
      <h2 id="mc-h">Konfirmasi Pembayaran Cash</h2>
    </div>
    <div class="cash-body">
      <p class="cash-notice">Pastikan pembayaran sudah diterima sebelum konfirmasi.</p>
      <div class="cash-amt-box">
        <span class="cash-amt-lbl">Total Tagihan</span>
        <div class="cash-amt-val" id="cash-disp"></div>
      </div>
    </div>
    <div class="cash-footer">
      <button class="btn-batal" id="cash-cancel">Batal</button>
      <button class="btn-lunas" id="cash-confirm">Konfirmasi Lunas</button>
    </div>
  </div>
</div>

<!-- ══ LIGHTBOX: QRIS Fullscreen ══ -->
<div id="qris-lightbox" class="qris-lightbox">
  <img src={QRIS_IMAGE_URL} alt="QR Code QRIS fullscreen" class="qris-lightbox-img" />
  <button id="qris-lightbox-close" class="qris-lightbox-close" aria-label="Tutup">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
      <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
    </svg>
  </button>
</div>

<!-- Toast -->
<div id="toast" role="status" aria-live="polite" aria-atomic="true">
  <svg id="toast-ico" class="toast-ico" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
    <polyline points="20 6 9 17 4 12"/>
  </svg>
  <span id="toast-msg"></span>
</div>

<script is:inline nonce={nonce}>
'use strict';

/* ══════════════════════════════════════════════════════════════════════════
   HELPERS — pure functions
══════════════════════════════════════════════════════════════════════════ */
function rp(n) {
  return new Intl.NumberFormat('id-ID',{style:'currency',currency:'IDR',minimumFractionDigits:0}).format(n);
}
function esc(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
function timeStr(iso) {
  return new Date(iso).toLocaleTimeString('id-ID',{hour:'2-digit',minute:'2-digit'});
}

/* ── Sound ─────────────────────────────────────────────────────────────── */
window.__playSuccess = function() {
  try {
    var ctx = new (window.AudioContext || window.webkitAudioContext)();
    [659.25, 830.61, 987.77].forEach(function(f, i) {
      var o = ctx.createOscillator(), g = ctx.createGain();
      o.connect(g); g.connect(ctx.destination);
      o.frequency.value = f; o.type = 'triangle';
      var t = ctx.currentTime + i * 0.13;
      g.gain.setValueAtTime(0, t);
      g.gain.linearRampToValueAtTime(0.35, t + 0.02);
      g.gain.exponentialRampToValueAtTime(0.001, t + 0.4);
      o.start(t); o.stop(t + 0.42);
    });
  } catch(e) {}
};

/* ── Toast ─────────────────────────────────────────────────────────────── */
var _tt;
function toast(msg, ok) {
  var t = document.getElementById('toast'), ic = document.getElementById('toast-ico');
  if (!t || !ic) return;
  document.getElementById('toast-msg').textContent = msg;
  ic.style.color = ok === false ? '#f87171' : '#4ade80';
  ic.innerHTML   = ok === false
    ? '<line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>'
    : '<polyline points="20 6 9 17 4 12"/>';
  t.classList.add('show');
  clearTimeout(_tt);
  _tt = setTimeout(function(){ t.classList.remove('show'); }, 3000);
}

/* ── API ───────────────────────────────────────────────────────────────── */
async function api(method, path, body) {
  var r = await fetch(path, {
    method: method,
    headers: {'Content-Type':'application/json'},
    body: body !== undefined ? JSON.stringify(body) : undefined,
    credentials: 'same-origin'
  });
  var d = await r.json().catch(function(){ return {}; });
  if (!r.ok) throw new Error(d.error || r.statusText);
  return d;
}

/* ══════════════════════════════════════════════════════════════════════════
   REALTIME WebSocket
   Guard via window.__kasirWsConnected — hanya connect SATU KALI selama
   tab terbuka.
══════════════════════════════════════════════════════════════════════════ */
function initRealtime(SUPABASE_URL, SUPABASE_ANON, onInsert) {
  window.__kasirWsCallback = onInsert;
  if (window.__kasirWsConnected) return;
  if (!SUPABASE_URL || !SUPABASE_ANON) return;
  window.__kasirWsConnected = true;

  var wsUrl = SUPABASE_URL.replace('https://','wss://') +
    '/realtime/v1/websocket?apikey=' + SUPABASE_ANON + '&vsn=1.0.0';

  function connect() {
    try {
      var ws = new WebSocket(wsUrl);
      ws.onopen = function() {
        ws.send(JSON.stringify({
          topic:'realtime:public:transaksi', event:'phx_join',
          payload:{config:{postgres_changes:[{event:'INSERT',schema:'public',table:'transaksi'}]}},
          ref:'1'
        }));
      };
      ws.onmessage = function(msg) {
        try {
          var d = JSON.parse(msg.data);
          if (d.event === 'phx_reply' && d.ref === 'heartbeat')
            ws.send(JSON.stringify({topic:'phoenix',event:'heartbeat',payload:{},ref:'hb'}));
          if (d.event === 'postgres_changes' || (d.payload && d.payload.type === 'INSERT'))
            if (window.__kasirWsCallback) window.__kasirWsCallback();
        } catch(e) {}
      };
      ws.onclose = function() { setTimeout(connect, 5000); };
      setInterval(function() {
        if (ws.readyState === WebSocket.OPEN)
          ws.send(JSON.stringify({topic:'phoenix',event:'heartbeat',payload:{},ref:'hb'}));
      }, 30000);
    } catch(e) { setTimeout(connect, 8000); }
  }
  connect();
}

/* ══════════════════════════════════════════════════════════════════════════
   INIT
══════════════════════════════════════════════════════════════════════════ */
function initKasir() {
  if (!document.getElementById('prod-grid')) return;

  /* ── Baca config dari data attribute — bukan meta tag ──────────────────
     Menghindari expose credentials di meta tag yang mudah di-scrape.
     data attribute hanya accessible via JS dan tidak terindeks scraper.   */
  var cfg = document.getElementById('app-config');
  var SUPABASE_URL  = cfg ? (cfg.dataset.sbUrl  || '') : '';
  var SUPABASE_ANON = cfg ? (cfg.dataset.sbAnon || '') : '';
  var BUCKET = 'produk-foto';

  var cart        = [];
  var activeKat   = 'semua';
  var searchQ     = '';
  var sheetOpen   = false;
  var _qrisTotal  = 0;
  var _histLoaded = false;
  var _imgLoaded  = new Set();

  /* ── Sidebar button ───────────────────────────────────────────────────── */
  var btnSidebar = document.getElementById('btn-open-sidebar');
  if (btnSidebar) {
    btnSidebar.addEventListener('click', function() {
      if (window.openSidebar) window.openSidebar();
    });
  }

  /* ── QRIS image: error fallback + lightbox open ───────────────────────── */
  var qrisImg   = document.getElementById('qris-img');
  var qrisNoImg = document.getElementById('qris-no-img');
  if (qrisImg) {
    qrisImg.addEventListener('error', function() {
      qrisImg.style.display = 'none';
      if (qrisNoImg) qrisNoImg.style.display = 'flex';
    });
    qrisImg.addEventListener('click', function() {
      var lb = document.getElementById('qris-lightbox');
      if (lb) lb.classList.add('open');
    });
  }

  /* ── Lightbox ─────────────────────────────────────────────────────────── */
  var lightbox = document.getElementById('qris-lightbox');
  if (lightbox) {
    lightbox.addEventListener('click', function() {
      lightbox.classList.remove('open');
    });
  }
  var lbClose = document.getElementById('qris-lightbox-close');
  if (lbClose) {
    lbClose.addEventListener('click', function(e) {
      e.stopPropagation();
      if (lightbox) lightbox.classList.remove('open');
    });
  }

  /* ── Lazy images ─────────────────────────────────────────────────────── */
  function loadImages() {
    document.querySelectorAll('.prod-card:not(.card-hidden)').forEach(function(card) {
      var id = card.dataset.id;
      if (_imgLoaded.has(id)) return;
      var thumb = card.querySelector('.prod-thumb');
      if (!thumb || thumb.querySelector('img')) return;
      _imgLoaded.add(id);
      var img = document.createElement('img');
      img.alt = card.dataset.namaAsli || '';
      img.loading = 'lazy'; img.decoding = 'async';
      img.onload  = function() {
        img.classList.add('loaded');
        var ph = thumb.querySelector('.prod-thumb-icon');
        if (ph) ph.style.display = 'none';
      };
      img.onerror = function() { _imgLoaded.delete(id); };
      img.src = SUPABASE_URL + '/storage/v1/object/public/' + BUCKET + '/' + id + '.webp';
      thumb.insertBefore(img, thumb.querySelector('.prod-qty-badge'));
    });
  }

  /* ── Filter ──────────────────────────────────────────────────────────── */
  function applyFilter() {
    var q = searchQ.toLowerCase().trim(), vis = 0;
    document.querySelectorAll('.prod-card').forEach(function(card) {
      var ok = (activeKat === 'semua' || card.dataset.kat === activeKat)
            && (!q || card.dataset.nama.includes(q));
      card.classList.toggle('card-hidden', !ok);
      if (ok) vis++;
    });
    var el = document.getElementById('no-hasil');
    if (el) el.classList.toggle('show', vis === 0);
    setTimeout(loadImages, 40);
  }

  /* ── Sync badges ─────────────────────────────────────────────────────── */
  function syncCards() {
    document.querySelectorAll('.prod-card').forEach(function(card) {
      var item  = cart.find(function(i){ return i.id === card.dataset.id; });
      var badge = card.querySelector('.prod-qty-badge');
      card.classList.toggle('in-cart', !!item);
      if (badge) {
        var prev = badge.textContent;
        badge.textContent = item ? String(item.qty) : '';
        if (item && prev !== String(item.qty)) {
          badge.classList.remove('pop');
          void badge.offsetWidth;
          badge.classList.add('pop');
          setTimeout(function(){ badge.classList.remove('pop'); }, 250);
        }
      }
    });
  }

  /* ── Cart HTML ───────────────────────────────────────────────────────── */
  function makeCartRows() {
    return cart.map(function(item, idx) {
      return '<div class="cart-row">' +
        '<div class="cr-info"><div class="cr-name">' + esc(item.nama) + '</div>' +
        '<div class="cr-price">' + rp(item.jual) + ' / item</div></div>' +
        '<div class="cr-qty">' +
          '<button class="qty-btn" data-a="dec" data-i="' + idx + '" aria-label="Kurangi">−</button>' +
          '<span class="qty-n">' + item.qty + '</span>' +
          '<button class="qty-btn" data-a="inc" data-i="' + idx + '" aria-label="Tambah">+</button>' +
        '</div>' +
        '<div class="cr-sub">' + rp(item.jual * item.qty) + '</div>' +
        '<button class="cr-del" data-a="del" data-i="' + idx + '" aria-label="Hapus">' +
          '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">' +
            '<line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>' +
        '</button></div>';
    }).join('');
  }

  function bindCartActions(container) {
    container.querySelectorAll('[data-a]').forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        e.stopPropagation();
        var idx = parseInt(this.dataset.i), act = this.dataset.a;
        if (act === 'inc')      cart[idx].qty++;
        else if (act === 'dec') { cart[idx].qty--; if (cart[idx].qty <= 0) cart.splice(idx,1); }
        else if (act === 'del') cart.splice(idx, 1);
        renderAll();
      });
    });
  }

  function setList(listEl, emptyEl, html) {
    if (!listEl) return;
    listEl.querySelectorAll('.cart-row').forEach(function(r){ r.remove(); });
    if (!cart.length) { if (emptyEl) emptyEl.style.display = ''; return; }
    if (emptyEl) emptyEl.style.display = 'none';
    var tmp = document.createElement('div');
    tmp.innerHTML = html;
    while (tmp.firstChild) listEl.appendChild(tmp.firstChild);
    bindCartActions(listEl);
  }

  /* ── Render ──────────────────────────────────────────────────────────── */
  function renderAll() {
    syncCards();
    var total = cart.reduce(function(s,i){ return s+i.jual*i.qty; },0);
    var count = cart.length;
    var items = cart.reduce(function(s,i){ return s+i.qty; },0);
    var html  = makeCartRows();

    ['d','m'].forEach(function(p) {
      var cnt = document.getElementById(p+'-count');
      var tot = document.getElementById(p+'-total');
      var itm = document.getElementById(p+'-items');
      var qr  = document.getElementById(p+'-qris');
      var ca  = document.getElementById(p+'-cash');
      if (cnt) { cnt.textContent = count; cnt.classList.toggle('live', count>0); }
      if (tot) tot.textContent = rp(total);
      if (itm) itm.textContent = items;
      if (qr)  qr.disabled  = count===0;
      if (ca)  ca.disabled  = count===0;
    });

    setList(document.getElementById('d-list'), document.getElementById('d-empty'), html);
    setList(document.getElementById('m-list'), document.getElementById('m-empty'), html);

    var fabLbl   = document.getElementById('fab-label');
    var fabBadge = document.getElementById('fab-badge');
    if (fabLbl)   fabLbl.textContent   = count>0 ? rp(total) : 'Keranjang';
    if (fabBadge) { fabBadge.textContent = items; fabBadge.style.display = items>0 ? '' : 'none'; }
  }

  /* ── Add to cart ─────────────────────────────────────────────────────── */
  function addToCart(id, nama, jual, beli) {
    var ex = cart.find(function(i){ return i.id===id; });
    if (ex) ex.qty++; else cart.push({id:id, nama:nama, jual:+jual, beli:+beli, qty:1});
    renderAll();
  }

  /* ── Modal / Sheet ───────────────────────────────────────────────────── */
  function openModal(id) {
    var el = document.getElementById('modal-'+id);
    if (el) el.classList.add('open');
    document.body.style.overflow = 'hidden';
  }
  function closeModal(id) {
    var el = document.getElementById('modal-'+id);
    if (el) el.classList.remove('open');
    if (!sheetOpen) document.body.style.overflow = '';
  }
  function openSheet() {
    var se = document.getElementById('cart-sheet'), bd = document.getElementById('sheet-backdrop');
    if (se) se.classList.add('open');
    if (bd) bd.classList.add('visible');
    document.body.style.overflow = 'hidden'; sheetOpen = true;
  }
  function closeSheet() {
    var se = document.getElementById('cart-sheet'), bd = document.getElementById('sheet-backdrop');
    if (se) se.classList.remove('open');
    if (bd) bd.classList.remove('visible');
    document.body.style.overflow = ''; sheetOpen = false;
  }

  /* ── Checkout ────────────────────────────────────────────────────────── */
  function doQris() {
    if (!cart.length) return;
    closeSheet();
    _qrisTotal = cart.reduce(function(s,i){ return s+i.jual*i.qty; },0);
    document.getElementById('qris-total-disp').textContent = rp(_qrisTotal);
    openModal('qris');
  }
  function doCash() {
    if (!cart.length) return;
    closeSheet();
    document.getElementById('cash-disp').textContent = rp(cart.reduce(function(s,i){ return s+i.jual*i.qty; },0));
    openModal('cash');
  }
  async function saveTrx(total, metode, status) {
    var items = cart.map(function(i){ return {produk_id:i.id,nama_produk:i.nama,harga_jual:i.jual,harga_beli:i.beli,qty:i.qty}; });
    await api('POST','/api/kasir/transaksi',{total:total,metode_bayar:metode,status:status,items:items});
  }
  function showSukses(total, metode) {
    window.__playSuccess && window.__playSuccess();
    document.getElementById('sukses-total').textContent  = rp(total);
    document.getElementById('sukses-metode').textContent = 'Metode: ' + metode;
    openModal('sukses');
    cart = []; renderAll(); loadHistory();
  }

  /* ── History ─────────────────────────────────────────────────────────── */
  async function loadHistory() {
    _histLoaded = true;
    try {
      var data = await api('GET','/api/kasir/transaksi');
      var el = document.getElementById('hist-list');
      if (!el) return;
      if (!data || !data.length) {
        el.innerHTML = '<div class="hist-placeholder">Belum ada transaksi hari ini</div>';
      } else {
        el.innerHTML = data.map(function(trx) {
          var isQ = trx.metode_bayar==='qris', itms = trx.transaksi_item||[];
          var summ = itms.slice(0,2).map(function(i){ return esc(i.nama_produk)+'×'+i.qty; }).join(', ');
          if (itms.length>2) summ += ' +'+(itms.length-2)+' lainnya';
          return '<div class="hist-row-item"><div class="hri-top">' +
            '<span class="hri-amt">'+rp(trx.total)+'</span>' +
            '<div class="hri-meta"><span class="hri-badge '+(isQ?'badge-qris':'badge-cash')+'">'+(isQ?'QRIS':'Cash')+'</span>' +
            '<span class="hri-time">'+timeStr(trx.created_at)+'</span></div></div>' +
            (summ?'<div class="hri-prods">'+summ+'</div>':'')+'</div>';
        }).join('');
      }
      var tot = (data||[]).reduce(function(s,t){ return s+t.total; },0);
      var st  = document.getElementById('stat-today');
      if (st) st.textContent = rp(tot);
    } catch(e) {
      var el2 = document.getElementById('hist-list');
      if (el2) el2.innerHTML = '<div class="hist-placeholder error">Gagal memuat histori</div>';
    }
  }

  function clearCart() {
    if (!cart.length || !confirm('Kosongkan keranjang?')) return;
    cart = []; renderAll();
  }

  /* ══ EVENT LISTENERS ══════════════════════════════════════════════════ */

  /* QC Bar */
  var bar = document.getElementById('qc-bar');
  if (bar) {
    var updateFade = function() {
      var atEnd = bar.scrollLeft + bar.clientWidth >= bar.scrollWidth - 4;
      var mask = atEnd ? 'none' : 'linear-gradient(to right,black 0%,black 85%,transparent 100%)';
      bar.style.webkitMaskImage = mask; bar.style.maskImage = mask;
    };
    bar.addEventListener('scroll', updateFade, {passive:true}); updateFade();
    var isDn=false, stX, scL;
    bar.addEventListener('mousedown', function(e){ isDn=true; stX=e.pageX-bar.offsetLeft; scL=bar.scrollLeft; bar.style.cursor='grabbing'; });
    document.addEventListener('mouseup', function(){ isDn=false; bar.style.cursor=''; });
    bar.addEventListener('mousemove', function(e){ if(!isDn) return; e.preventDefault(); bar.scrollLeft=scL-(e.pageX-bar.offsetLeft-stX)*1.2; });
    bar.addEventListener('click', function(e) {
      var btn = e.target.closest('.qc-item');
      if (!btn) return;
      addToCart(btn.dataset.id, btn.dataset.nama, btn.dataset.jual, btn.dataset.beli);
      toast('+ ' + btn.dataset.nama);
    });
  }

  /* Search */
  var sp = document.getElementById('s-produk');
  if (sp) sp.addEventListener('input', function(){ searchQ=this.value; applyFilter(); });

  /* Kategori */
  var kb = document.getElementById('kat-bar');
  if (kb) kb.addEventListener('click', function(e) {
    var btn = e.target.closest('.kat-btn');
    if (!btn) return;
    document.querySelectorAll('.kat-btn').forEach(function(b){ b.classList.remove('on'); b.setAttribute('aria-selected','false'); });
    btn.classList.add('on'); btn.setAttribute('aria-selected','true');
    activeKat = btn.dataset.kat; applyFilter();
  });

  /* Produk grid */
  var pg = document.getElementById('prod-grid');
  if (pg) {
    pg.addEventListener('click', function(e) {
      var c = e.target.closest('.prod-card');
      if (c) addToCart(c.dataset.id, c.dataset.namaAsli, c.dataset.jual, c.dataset.beli);
    });
    pg.addEventListener('keydown', function(e) {
      if (e.key!=='Enter'&&e.key!==' ') return;
      var c = e.target.closest('.prod-card');
      if (c) { e.preventDefault(); addToCart(c.dataset.id, c.dataset.namaAsli, c.dataset.jual, c.dataset.beli); }
    });
  }

  /* Clear */
  var dc = document.getElementById('d-clear'); if (dc) dc.addEventListener('click', clearCart);
  var mc = document.getElementById('m-clear'); if (mc) mc.addEventListener('click', clearCart);

  /* Mobile sheet */
  var fab = document.getElementById('cart-fab');       if (fab) fab.addEventListener('click', openSheet);
  var sc  = document.getElementById('sheet-close');    if (sc)  sc.addEventListener('click', closeSheet);
  var bd2 = document.getElementById('sheet-backdrop'); if (bd2) bd2.addEventListener('click', closeSheet);
  var she = document.getElementById('cart-sheet');
  if (she) {
    var sy=0, isd=false;
    she.addEventListener('touchstart', function(e){ sy=e.touches[0].clientY; isd=true; }, {passive:true});
    she.addEventListener('touchend',   function(e){ if(isd&&e.changedTouches[0].clientY-sy>80) closeSheet(); isd=false; }, {passive:true});
  }

  /* QRIS */
  var dq=document.getElementById('d-qris'); if(dq) dq.addEventListener('click',doQris);
  var mq=document.getElementById('m-qris'); if(mq) mq.addEventListener('click',doQris);
  var cq=document.getElementById('close-qris');
  var cqb=document.getElementById('close-qris-bottom');
  function hcq(){ closeModal('qris'); _qrisTotal=0; }
  if(cq)  cq.addEventListener('click',hcq);
  if(cqb) cqb.addEventListener('click',hcq);
  var qcb = document.getElementById('qris-confirm-btn');
  if (qcb) qcb.addEventListener('click', async function() {
    if (!_qrisTotal) return;
    this.disabled=true; this.textContent='Menyimpan…';
    try {
      await saveTrx(_qrisTotal,'qris','paid');
      closeModal('qris'); showSukses(_qrisTotal,'QRIS'); _qrisTotal=0;
    } catch(e) {
      toast('Gagal: '+e.message,false); this.disabled=false; this.textContent='✓ Konfirmasi Sudah Bayar';
    }
  });

  /* Cash */
  var dca=document.getElementById('d-cash'); if(dca) dca.addEventListener('click',doCash);
  var mca=document.getElementById('m-cash'); if(mca) mca.addEventListener('click',doCash);
  var cc=document.getElementById('cash-cancel');   if(cc) cc.addEventListener('click',function(){ closeModal('cash'); });
  var cf=document.getElementById('cash-confirm');
  if(cf) cf.addEventListener('click', async function() {
    var total=cart.reduce(function(s,i){return s+i.jual*i.qty;},0);
    this.disabled=true; this.textContent='Menyimpan…';
    try { await saveTrx(total,'cash','paid'); closeModal('cash'); showSukses(total,'Cash'); }
    catch(e){ toast('Gagal: '+e.message,false); }
    finally{ this.disabled=false; this.textContent='Konfirmasi Lunas'; }
  });

  /* Sukses */
  var cs=document.getElementById('close-sukses');
  if(cs) cs.addEventListener('click',function(){
    closeModal('sukses');
    var s=document.getElementById('s-produk'); if(s) s.focus();
  });

  /* Histori */
  var hb=document.getElementById('hist-btn');
  if(hb) hb.addEventListener('click',function(){
    var body=document.getElementById('hist-body'), chev=document.getElementById('hist-chev');
    var open=body.classList.contains('open');
    body.classList.toggle('open',!open);
    this.setAttribute('aria-expanded',String(!open));
    if(chev) chev.classList.toggle('open',!open);
    if(!open && !_histLoaded) loadHistory();
  });

  /* ESC */
  document.addEventListener('keydown', function(e) {
    if (e.key!=='Escape') return;
    var lb=document.getElementById('qris-lightbox');
    if (lb&&lb.classList.contains('open')) lb.classList.remove('open');
  });

  /* Realtime */
  initRealtime(SUPABASE_URL, SUPABASE_ANON, function() {
    if (_histLoaded) loadHistory();
  });

  renderAll();
  setTimeout(loadImages, 100);

} /* end initKasir */

/* ══════════════════════════════════════════════════════════════════════════
   BOOTSTRAP
   View Transitions dihapus — init hanya via DOMContentLoaded / readyState.
══════════════════════════════════════════════════════════════════════════ */
(function bootstrap() {
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initKasir);
  } else {
    initKasir();
  }
})();
</script>

</Layout>
