---
// src/pages/kasir.astro
export const prerender = false;
import "../../styles/global.css";
import "../../styles/kasir.css";
import { createServiceClient } from "../../lib/supabase";
import Layout from "../../layouts/Layout.astro";

const accessToken = Astro.cookies.get("sb-access-token");
if (!accessToken?.value) return Astro.redirect("/");

const nonce = (Astro.locals as App.Locals).nonce ?? "";
const sb = createServiceClient();

const { data: produkRaw } = await sb
  .from("produk")
  .select("id, nama_produk, harga_jual, harga_beli, kategori, quick_cash")
  .order("nama_produk");

const produk = produkRaw ?? [];
const quickCashProduk = produk.filter((p) => p.quick_cash);

const PUBLIC_SUPABASE_URL      = import.meta.env.PUBLIC_SUPABASE_URL  as string;
const PUBLIC_SUPABASE_ANON_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY as string;

const QRIS_IMAGE_URL = '/qris.jpeg';

function rp(n: number) {
  return new Intl.NumberFormat("id-ID", {
    style: "currency", currency: "IDR", minimumFractionDigits: 0,
  }).format(n);
}

const kategoriList = [...new Set(produk.map(p => p.kategori).filter(Boolean))].sort();
---

<Layout title="Kasir" active="kasir" nonce={nonce}>

<style>
  /* ── Wrapper utama ────────────────────────────────────────────── */
  .kasir-root {
    display: flex;
    flex-direction: column;
    height: 100%;
    min-height: 0;
    overflow: hidden;
  }

  /* ── Cart header: tidak ikut scroll ──────────────────────────── */
  .cart-header-fixed { flex-shrink: 0; }

  /* ── Hist toggle — inner span ─────────────────────────────────── */
  .hist-btn-inner { display: flex; align-items: center; gap: 5px; }

  /* ── Hist loading / empty / error placeholder ─────────────────── */
  .hist-placeholder { padding: 1.5rem; text-align: center; font-size: .69rem; color: #bbb; }
  .hist-placeholder.error { color: #f87171; }

  /* ── Sheet header: tombol aksi kanan ─────────────────────────── */
  .sheet-header-right { display: flex; align-items: center; gap: 8px; }

  /* ── Sheet close button ───────────────────────────────────────── */
  .sheet-close-btn {
    background: none; border: none; cursor: pointer;
    color: var(--muted); padding: 4px; border-radius: 5px;
    display: flex; align-items: center; transition: background .1s;
  }
  .sheet-close-btn:hover { background: rgba(0,0,0,.06); }

  /* ── Mobile: empty state min-height ──────────────────────────── */
  .m-empty-state { min-height: 120px; }

  /* ── Mobile: cart footer border ───────────────────────────────── */
  .cart-footer-mobile { border-top: 1px solid var(--border); }

  /* ── Mobile: pay buttons row ──────────────────────────────────── */
  .cart-pay-btns-mobile { flex-direction: row; }

  /* ── Mobile: pay button sizing ────────────────────────────────── */
  .pay-btn-mobile { flex: 1; padding: 12px 8px; }

  /* ── QRIS modal sizing ────────────────────────────────────────── */
  .modal-qris-box  { max-width: 400px; }
  .modal-qris-head { padding: 16px 20px; }

  /* ── QRIS content column ──────────────────────────────────────── */
  .qris-content { display: flex; flex-direction: column; align-items: center; gap: 12px; }

  /* ── QRIS total tagihan box ───────────────────────────────────── */
  .qris-total-box {
    width: 100%; background: #f0fdf4; border: 1px solid #bbf7d0;
    border-radius: 8px; padding: 12px 14px; text-align: center;
  }
  .qris-total-label { font-size: .7rem; color: #16a34a; font-weight: 600; text-transform: uppercase; letter-spacing: .04em; margin-bottom: 2px; }
  .qris-total-val   { font-size: 1.5rem; font-weight: 800; color: #15803d; }

  /* ── QRIS image ───────────────────────────────────────────────── */
  .qris-img { width: 100%; max-width: 280px; border-radius: 10px; border: 1px solid #e5e7eb; object-fit: contain; cursor: zoom-in; }

  /* ── QRIS no-image fallback ───────────────────────────────────── */
  .qris-no-img {
    display: none; flex-direction: column; padding: 24px; text-align: center;
    color: #9ca3af; font-size: .8rem; border: 1px dashed #d1d5db;
    border-radius: 10px; width: 100%; max-width: 280px;
  }
  .qris-no-img-icon  { margin: 0 auto 8px; display: block; }
  .qris-no-img-title { margin: 0 0 4px; font-weight: 600; color: #6b7280; }
  .qris-no-img-hint  { margin: 0; font-size: .72rem; }

  /* ── QRIS instruksi pembayaran ────────────────────────────────── */
  .qris-instruction { font-size: .75rem; color: #6b7280; line-height: 1.4; }

  /* ── QRIS modal footer ────────────────────────────────────────── */
  .qris-modal-footer {
    flex-shrink: 0; border-top: 1px solid #f3f4f6;
    background: rgba(249,250,251,.5); padding: 16px; display: flex; gap: 8px;
  }

  /* ── QRIS buttons ─────────────────────────────────────────────── */
  .qris-confirm-btn {
    flex: 1; padding: 12px; background: #000; color: #fff;
    border: none; border-radius: 8px; font-size: .85rem; font-weight: 700;
    cursor: pointer; transition: background .2s, opacity .2s;
  }
  .qris-confirm-btn:hover    { background: #1a1a1a; }
  .qris-confirm-btn:disabled { opacity: .6; cursor: not-allowed; }

  .qris-cancel-btn {
    flex: 1; padding: 12px; background: #f3f4f6; color: #374151;
    border: none; border-radius: 8px; font-size: .85rem; font-weight: 600;
    cursor: pointer; transition: background .15s;
  }
  .qris-cancel-btn:hover { background: #e5e7eb; }

  /* ── Sukses / Cash modal sizing ───────────────────────────────── */
  .modal-sukses-box { max-width: 360px; }
  .modal-cash-box   { max-width: 400px; }

  /* ── QRIS Lightbox ────────────────────────────────────────────── */
  .qris-lightbox {
    display: none; position: fixed; inset: 0; background: rgba(0,0,0,.95);
    z-index: 9999; align-items: center; justify-content: center; cursor: zoom-out;
  }
  .qris-lightbox.open { display: flex; }

  .qris-lightbox-img {
    max-width: 92vw; max-height: 92vh; border-radius: 12px;
    object-fit: contain; pointer-events: none; box-shadow: 0 8px 40px rgba(0,0,0,.5);
  }

  .qris-lightbox-close {
    position: absolute; top: 16px; right: 16px;
    background: rgba(255,255,255,.15); backdrop-filter: blur(6px);
    border: 1px solid rgba(255,255,255,.2); border-radius: 50%;
    width: 40px; height: 40px; display: flex; align-items: center;
    justify-content: center; cursor: pointer; color: #fff; transition: background .15s;
  }
  .qris-lightbox-close:hover { background: rgba(255,255,255,.25); }

  /* ── FAB badge: hidden by default ────────────────────────────── */
  .fab-badge-hidden { display: none; }

  /* ── Toast icon: flex-shrink ──────────────────────────────────── */
  .toast-ico { flex-shrink: 0; }

  /* ════════════════════════════════════════════════════════════════
     FITUR BARU: Cash Modal Enhanced
  ════════════════════════════════════════════════════════════════ */

  /* ── Cash modal: denomination chips ─────────────────────────── */
  .denom-chips {
    display: flex; flex-wrap: wrap; gap: 6px; margin-top: 4px;
  }
  .denom-chip {
    padding: 5px 10px; font-size: .72rem; font-weight: 600;
    border-radius: 20px; border: 1.5px solid #e5e7eb;
    background: #f9fafb; color: #374151; cursor: pointer;
    transition: all .15s; white-space: nowrap; line-height: 1;
  }
  .denom-chip:hover { border-color: #111; background: #111; color: #fff; }
  .denom-chip.active { border-color: #111; background: #111; color: #fff; }

  /* ── Kembalian display ────────────────────────────────────────── */
  .kembalian-box {
    border-radius: 10px; padding: 14px 16px;
    transition: background .2s, border-color .2s;
  }
  .kembalian-box.ok   { background: #f0fdf4; border: 1.5px solid #86efac; }
  .kembalian-box.warn { background: #fef2f2; border: 1.5px solid #fca5a5; }
  .kembalian-box.idle { background: #f9fafb; border: 1.5px solid #e5e7eb; }

  .kembalian-lbl {
    font-size: .68rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: .05em; margin-bottom: 3px;
  }
  .kembalian-box.ok   .kembalian-lbl { color: #16a34a; }
  .kembalian-box.warn .kembalian-lbl { color: #dc2626; }
  .kembalian-box.idle .kembalian-lbl { color: #9ca3af; }

  .kembalian-val {
    font-size: 1.45rem; font-weight: 800; line-height: 1;
  }
  .kembalian-box.ok   .kembalian-val { color: #15803d; }
  .kembalian-box.warn .kembalian-val { color: #dc2626; }
  .kembalian-box.idle .kembalian-val { color: #9ca3af; }

  .kembalian-hint { font-size: .69rem; color: #6b7280; margin-top: 3px; }

  /* ── Cash input styled ────────────────────────────────────────── */
  .cash-input-wrap {
    position: relative; display: flex; align-items: center;
  }
  .cash-input-prefix {
    position: absolute; left: 12px; font-size: .8rem;
    font-weight: 700; color: #6b7280; pointer-events: none;
  }
  .cash-input-field {
    width: 100%; padding: 10px 12px 10px 34px;
    font-size: 1.05rem; font-weight: 700; color: #111;
    border: 2px solid #e5e7eb; border-radius: 8px;
    background: #fff; outline: none; transition: border-color .15s;
    appearance: textfield; -moz-appearance: textfield;
  }
  .cash-input-field::-webkit-outer-spin-button,
  .cash-input-field::-webkit-inner-spin-button { -webkit-appearance: none; }
  .cash-input-field:focus { border-color: #111; }

  /* ── Cash exact button ────────────────────────────────────────── */
  .btn-exact {
    font-size: .72rem; font-weight: 600; color: #6b7280;
    background: none; border: none; cursor: pointer; padding: 0;
    text-decoration: underline; text-underline-offset: 2px;
  }
  .btn-exact:hover { color: #111; }

  /* ── Diskon section ───────────────────────────────────────────── */
  .diskon-toggle-btn {
    display: flex; align-items: center; gap: 5px;
    font-size: .72rem; font-weight: 600; color: #6b7280;
    background: none; border: none; cursor: pointer; padding: 0;
    transition: color .15s;
  }
  .diskon-toggle-btn:hover { color: #111; }
  .diskon-toggle-btn svg { transition: transform .2s; }
  .diskon-toggle-btn.open svg { transform: rotate(180deg); }

  .diskon-panel {
    display: none; flex-direction: column; gap: 8px;
    padding: 12px; background: #fafafa; border-radius: 8px;
    border: 1px solid #f0f0f0; margin-top: 4px;
  }
  .diskon-panel.open { display: flex; }

  .diskon-type-tabs {
    display: flex; gap: 4px; background: #f3f4f6;
    border-radius: 6px; padding: 2px;
  }
  .diskon-type-tab {
    flex: 1; padding: 5px; font-size: .7rem; font-weight: 600;
    border: none; background: none; border-radius: 5px; cursor: pointer;
    color: #6b7280; transition: all .15s;
  }
  .diskon-type-tab.active { background: #fff; color: #111; box-shadow: 0 1px 3px rgba(0,0,0,.1); }

  .diskon-input-wrap { position: relative; display: flex; align-items: center; }
  .diskon-input-suffix {
    position: absolute; right: 10px; font-size: .75rem;
    font-weight: 700; color: #6b7280; pointer-events: none;
  }
  .diskon-input {
    width: 100%; padding: 8px 30px 8px 10px;
    font-size: .9rem; font-weight: 700; color: #111;
    border: 1.5px solid #e5e7eb; border-radius: 7px;
    background: #fff; outline: none; transition: border-color .15s;
    appearance: textfield; -moz-appearance: textfield;
  }
  .diskon-input::-webkit-outer-spin-button,
  .diskon-input::-webkit-inner-spin-button { -webkit-appearance: none; }
  .diskon-input:focus { border-color: #111; }

  /* ── Catatan / note ────────────────────────────────────────────── */
  .nota-input {
    width: 100%; padding: 8px 10px; font-size: .78rem; color: #374151;
    border: 1.5px solid #e5e7eb; border-radius: 7px; background: #fff;
    outline: none; resize: none; line-height: 1.4; transition: border-color .15s;
    font-family: inherit;
  }
  .nota-input:focus { border-color: #111; }
  .nota-input::placeholder { color: #c4c4c4; }

  /* ── Ringkasan transaksi di cart ──────────────────────────────── */
  .cart-summary-row {
    display: flex; justify-content: space-between; align-items: center;
    padding: 3px 0; font-size: .72rem; color: #6b7280;
  }
  .cart-summary-row.discount { color: #dc2626; }
  .cart-summary-row.total-final {
    padding-top: 6px; margin-top: 2px;
    border-top: 1.5px dashed #e5e7eb;
    font-size: .82rem; font-weight: 700; color: #111;
  }
  .cart-summary-area {
    padding: 8px 12px; background: #f9fafb;
    border-top: 1px solid #f0f0f0; font-size: .72rem;
  }

  /* ── Shift summary strip ──────────────────────────────────────── */
  .shift-strip {
    display: flex; gap: 6px; padding: 8px 12px;
    background: #f0fdf4; border-top: 1px solid #bbf7d0;
    overflow-x: auto; flex-shrink: 0;
  }
  .shift-item {
    flex-shrink: 0; text-align: center;
    background: #fff; border: 1px solid #d1fae5;
    border-radius: 8px; padding: 6px 10px; min-width: 80px;
  }
  .shift-item-lbl { font-size: .6rem; font-weight: 600; color: #16a34a; text-transform: uppercase; letter-spacing: .04em; }
  .shift-item-val { font-size: .85rem; font-weight: 800; color: #065f46; margin-top: 1px; }

  /* ── Hist row: void / refund button ──────────────────────────── */
  .hri-actions { display: flex; gap: 4px; margin-top: 5px; }
  .hri-void-btn {
    font-size: .65rem; font-weight: 600; padding: 3px 8px;
    border-radius: 5px; border: 1px solid #fca5a5;
    background: #fff; color: #dc2626; cursor: pointer; transition: all .15s;
  }
  .hri-void-btn:hover { background: #fef2f2; }
  .hri-voided { opacity: .5; pointer-events: none; }

  /* ── Struk / receipt preview panel ───────────────────────────── */
  .modal-struk-box { max-width: 340px; }
  .struk-wrap {
    font-family: 'Courier New', monospace; font-size: .78rem;
    line-height: 1.6; padding: 16px; background: #fff;
    border: 1px solid #e5e7eb; border-radius: 8px;
  }
  .struk-title { text-align: center; font-weight: 700; font-size: .85rem; margin-bottom: 2px; }
  .struk-sub   { text-align: center; font-size: .68rem; color: #6b7280; margin-bottom: 8px; }
  .struk-sep   { border: none; border-top: 1px dashed #d1d5db; margin: 6px 0; }
  .struk-row   { display: flex; justify-content: space-between; }
  .struk-total { display: flex; justify-content: space-between; font-weight: 700; }
  .struk-footer { text-align: center; font-size: .68rem; color: #6b7280; margin-top: 6px; }

  .btn-print {
    flex: 1; padding: 11px; background: #111; color: #fff;
    border: none; border-radius: 8px; font-size: .83rem; font-weight: 700;
    cursor: pointer; transition: background .2s; display: flex;
    align-items: center; justify-content: center; gap: 6px;
  }
  .btn-print:hover { background: #333; }

  /* ── Sukses modal enhancements ────────────────────────────────── */
  .sukses-actions { display: flex; gap: 8px; margin-top: 12px; }
  .btn-new-trx    { flex: 1; }
  .btn-struk-small {
    padding: 10px 14px; background: #f3f4f6; color: #374151;
    border: none; border-radius: 8px; font-size: .8rem; font-weight: 600;
    cursor: pointer; transition: background .15s; display: flex;
    align-items: center; justify-content: center; gap: 5px;
  }
  .btn-struk-small:hover { background: #e5e7eb; }

  /* ── Modal struk footer ───────────────────────────────────────── */
  .struk-modal-footer {
    border-top: 1px solid #f3f4f6; padding: 14px 16px;
    display: flex; gap: 8px;
  }
  .btn-struk-close {
    flex: 1; padding: 11px; background: #f3f4f6; color: #374151;
    border: none; border-radius: 8px; font-size: .83rem; font-weight: 600;
    cursor: pointer; transition: background .15s;
  }
  .btn-struk-close:hover { background: #e5e7eb; }

  /* ── Diskon badge di cart total ──────────────────────────────── */
  .diskon-badge {
    display: inline-flex; align-items: center; gap: 3px;
    background: #fef2f2; border: 1px solid #fecaca;
    color: #dc2626; font-size: .65rem; font-weight: 700;
    padding: 1px 6px; border-radius: 10px;
  }

  /* ── Uang diterima label section ──────────────────────────────── */
  .cash-section-lbl {
    font-size: .68rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: .05em; color: #6b7280; margin-bottom: 5px;
  }
</style>

<div
  id="app-config"
  data-sb-url={PUBLIC_SUPABASE_URL}
  data-sb-anon={PUBLIC_SUPABASE_ANON_KEY}
  aria-hidden="true"
  class="hidden"
></div>

<!-- ══ MAIN LAYOUT ══ -->
<div class="kasir-root">
<div class="pos-wrap">

  <!-- LEFT: Products -->
  <div class="pos-left">

    <!-- Header -->
    <div class="pos-header">
      <button id="btn-open-sidebar"
        class="lg:hidden flex-shrink-0 w-8 h-8 flex items-center justify-center rounded text-gray-500 hover:bg-gray-100 transition-colors"
        aria-label="Menu">
        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>

      <h1 class="pos-brand">Kasir</h1>

      <div class="pos-search">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <label for="s-produk" class="sr-only">Cari produk</label>
        <input id="s-produk" type="search" placeholder="Cari produk…" autocomplete="off"/>
      </div>

      <!-- Desktop stat -->
      <div class="pos-stat">
        <span class="pos-stat-lbl">Omset hari ini</span>
        <span id="stat-today" class="pos-stat-val">—</span>
      </div>

      <!-- Mobile FAB -->
      <button class="cart-fab" id="cart-fab" aria-label="Buka keranjang">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        <span id="fab-label">Keranjang</span>
        <span class="cart-fab-badge fab-badge-hidden" id="fab-badge">0</span>
      </button>
    </div>

    <!-- Quick Cash -->
    {quickCashProduk.length > 0 && (
      <div class="qc-bar" id="qc-bar">
        <span class="qc-tag">⚡ Quick</span>
        <div class="qc-sep"></div>
        {quickCashProduk.map(p => (
          <button class="qc-item" type="button"
            data-id={p.id} data-nama={p.nama_produk}
            data-jual={p.harga_jual} data-beli={p.harga_beli}>
            <div class="qc-item-inner">
              <span>{p.nama_produk}</span>
              <small>{rp(p.harga_jual)}</small>
            </div>
          </button>
        ))}
      </div>
    )}

    <!-- Category -->
    <div class="kat-bar" id="kat-bar" role="tablist">
      <div class="kat-items-scroll">
        <button class="kat-btn on" data-kat="semua" role="tab" aria-selected="true">Semua</button>
        {kategoriList.map(k => (
          <button class="kat-btn" data-kat={k} role="tab" aria-selected="false">{k}</button>
        ))}
      </div>
    </div>

    <!-- Products -->
    <div class="prod-scroll">
      <div class="prod-grid" id="prod-grid" role="list">
        {produk.map(p => (
          <div
            class="prod-card"
            role="listitem" tabindex="0"
            data-id={p.id}
            data-nama={p.nama_produk.toLowerCase()}
            data-nama-asli={p.nama_produk}
            data-jual={p.harga_jual}
            data-beli={p.harga_beli}
            data-kat={p.kategori ?? ''}
            aria-label={`${p.nama_produk} — ${rp(p.harga_jual)}`}
          >
            <div class="prod-thumb">
              <svg class="prod-thumb-icon" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <path d="m3 9 4-4 4 4 4-5 6 7"/><circle cx="8.5" cy="7.5" r="1.5"/>
              </svg>
              <span class="prod-qty-badge" aria-hidden="true"></span>
            </div>
            <div>
              <div class="prod-name">{p.nama_produk}</div>
              <div class="prod-price">{rp(p.harga_jual)}</div>
            </div>
          </div>
        ))}
      </div>
      <div id="no-hasil">Produk tidak ditemukan.</div>
    </div>
  </div>

  <!-- RIGHT: Cart panel — desktop -->
  <div class="pos-right" id="cart-desktop">
    <div class="cart-header cart-header-fixed">
      <div class="cart-title">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        Keranjang
        <span class="cart-count" id="d-count">0</span>
      </div>
      <div class="flex items-center gap-2">
        <button id="d-nota-toggle" class="diskon-toggle-btn text-xs" title="Tambah catatan">
