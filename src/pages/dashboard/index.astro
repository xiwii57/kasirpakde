---
// src/pages/dashboard/index.astro
export const prerender = false;
import Layout from "../../layouts/Layout.astro";
import { createServiceClient } from "../../lib/supabase";
import "../../styles/global.css";
import "../../styles/dashboard.css";

// Auth guard — middleware sudah handle redirect, ini double-check
const accessToken = Astro.cookies.get("sb-access-token");
if (!accessToken?.value) return Astro.redirect("/");

const nonce = (Astro.locals as App.Locals).nonce ?? "";
const sb    = createServiceClient();
const PUBLIC_TURNSTILE_SITEKEY = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY as string;

// ── Time helpers ───────────────────────────────────────────────────────────
function toWIB(iso: string) {
  return new Date(new Date(iso).getTime() + 7 * 60 * 60 * 1000);
}
function pad2(n: number) { return String(n).padStart(2, "0"); }

const nowWIB = toWIB(new Date().toISOString());

// Awal hari ini WIB → UTC
const todayStart = new Date(nowWIB);
todayStart.setHours(0, 0, 0, 0);
const todayStartUTC = new Date(todayStart.getTime() - 7 * 60 * 60 * 1000);

// 7 & 30 hari lalu
const week7UTC   = new Date(todayStartUTC.getTime() - 6  * 24 * 60 * 60 * 1000);
const month30UTC = new Date(todayStartUTC.getTime() - 29 * 24 * 60 * 60 * 1000);

// ── Data fetching paralel ──────────────────────────────────────────────────
const [
  { data: produkList },
  { data: logList },
  { data: trxHariIni },
  { data: trx7Raw },
  { data: trx30Raw },
  { data: topItems },
] = await Promise.all([
  sb.from("produk").select("*").order("nama_produk"),
  sb.from("harga_log").select("*").order("changed_at", { ascending: false }).limit(10),
  sb.from("transaksi")
    .select("id, total, metode_bayar, created_at, transaksi_item(qty)")
    .eq("status", "paid")
    .gte("created_at", todayStartUTC.toISOString())
    .order("created_at", { ascending: false }),
  sb.from("transaksi")
    .select("id, total, metode_bayar, created_at")
    .eq("status", "paid")
    .gte("created_at", week7UTC.toISOString())
    .order("created_at", { ascending: true }),
  sb.from("transaksi")
    .select("id, total, metode_bayar, created_at")
    .eq("status", "paid")
    .gte("created_at", month30UTC.toISOString()),
  sb.from("transaksi_item")
    .select("produk_id, nama_produk, qty")
    .limit(300),
]);

const produk  = produkList  ?? [];
const logs    = logList     ?? [];
const hari    = trxHariIni  ?? [];
const trx7    = trx7Raw     ?? [];
const trx30   = trx30Raw    ?? [];

// ── Statistik produk ───────────────────────────────────────────────────────
const totalProduk    = produk.length;
const avgMargin      = produk.length
  ? Math.round(produk.reduce((s, p) => s + ((p.harga_jual - p.harga_beli) / (p.harga_beli || 1)) * 100, 0) / produk.length)
  : 0;
const lowMargin      = produk.filter(p => p.harga_beli > 0 && ((p.harga_jual - p.harga_beli) / p.harga_beli) < 0.10).length;
const quickCashCount = produk.filter(p => p.quick_cash).length;

// ── Statistik hari ini ────────────────────────────────────────────────────
const omsetHari  = hari.reduce((s, t) => s + t.total, 0);
const cashHari   = hari.filter(t => t.metode_bayar !== "qris").reduce((s, t) => s + t.total, 0);
const qrisHari   = hari.filter(t => t.metode_bayar === "qris").reduce((s, t) => s + t.total, 0);
const itemHari   = hari.reduce((s, t) => s + (t.transaksi_item ?? []).reduce((q: number, i: any) => q + i.qty, 0), 0);

// ── Statistik 30 hari ─────────────────────────────────────────────────────
const omset30    = trx30.reduce((s, t) => s + t.total, 0);
const cash30     = trx30.filter(t => t.metode_bayar !== "qris").reduce((s, t) => s + t.total, 0);
const qris30     = trx30.filter(t => t.metode_bayar === "qris").reduce((s, t) => s + t.total, 0);
const cashCnt30  = trx30.filter(t => t.metode_bayar !== "qris").length;
const qrisCnt30  = trx30.filter(t => t.metode_bayar === "qris").length;

// ── Grafik 7 hari ─────────────────────────────────────────────────────────
type Day7 = { label: string; date: string; omset: number; trx: number };
const days7: Day7[] = [];
for (let i = 6; i >= 0; i--) {
  const d   = new Date(todayStart); d.setDate(d.getDate() - i);
  const wib = new Date(d.getTime() + 7 * 60 * 60 * 1000);
  days7.push({
    label: `${pad2(wib.getDate())}/${pad2(wib.getMonth() + 1)}`,
    date:  `${wib.getFullYear()}-${pad2(wib.getMonth() + 1)}-${pad2(wib.getDate())}`,
    omset: 0,
    trx:   0,
  });
}
for (const t of trx7) {
  const w   = toWIB(t.created_at);
  const key = `${w.getFullYear()}-${pad2(w.getMonth() + 1)}-${pad2(w.getDate())}`;
  const day = days7.find(d => d.date === key);
  if (day) { day.omset += t.total; day.trx++; }
}
const maxOmset7  = Math.max(...days7.map(d => d.omset), 1);
const omsetWeek  = days7.reduce((s, d) => s + d.omset, 0);
const todayKey   = `${nowWIB.getFullYear()}-${pad2(nowWIB.getMonth() + 1)}-${pad2(nowWIB.getDate())}`;

const kemarinKey = (() => {
  const k = new Date(todayStart); k.setDate(k.getDate() - 1);
  const w = new Date(k.getTime() + 7 * 60 * 60 * 1000);
  return `${w.getFullYear()}-${pad2(w.getMonth() + 1)}-${pad2(w.getDate())}`;
})();
const omsetKemarin = days7.find(d => d.date === kemarinKey)?.omset ?? 0;
const vsKemarin    = omsetKemarin > 0
  ? Math.round(((omsetHari - omsetKemarin) / omsetKemarin) * 100)
  : null;

// ── Top Seller ────────────────────────────────────────────────────────────
const topMap = new Map<string, { nama: string; total: number }>();
(topItems ?? []).forEach(i => {
  const cur = topMap.get(i.produk_id ?? i.nama_produk) ?? { nama: i.nama_produk, total: 0 };
  cur.total += i.qty;
  topMap.set(i.produk_id ?? i.nama_produk, cur);
});
const topSellers = [...topMap.values()].sort((a, b) => b.total - a.total).slice(0, 5);

// ── Helpers ────────────────────────────────────────────────────────────────
function rp(n: number) {
  return new Intl.NumberFormat("id-ID", { style: "currency", currency: "IDR", minimumFractionDigits: 0 }).format(n);
}
function margin(beli: number, jual: number) {
  if (!beli) return 0;
  return Math.round(((jual - beli) / beli) * 100);
}
function timeStr(iso: string) {
  return toWIB(iso).toLocaleTimeString("id-ID", { hour: "2-digit", minute: "2-digit" });
}

const katColors: Record<string, string> = {
  Minuman: "kat-blue", Snack: "kat-yellow", Rokok: "kat-red",
  Sembako: "kat-green", Lainnya: "kat-gray",
};
const katBreakdown = ["Minuman","Snack","Rokok","Sembako","Lainnya"].map(kat => {
  const items = produk.filter((p: any) => p.kategori === kat);
  const avgM  = items.length
    ? Math.round(items.reduce((s: number, p: any) => s + margin(p.harga_beli, p.harga_jual), 0) / items.length)
    : 0;
  return { kat, count: items.length, avgM, colorKey: katColors[kat] ?? "kat-gray" };
});

const userEmail  = (Astro.locals as App.Locals).user?.email ?? "admin";
const hour       = new Date().getHours();
const salam      = hour < 11 ? "Selamat pagi" : hour < 15 ? "Selamat siang" : hour < 18 ? "Selamat sore" : "Selamat malam";
const tanggalStr = nowWIB.toLocaleDateString("id-ID", { weekday: "long", day: "numeric", month: "long", year: "numeric" });
---

<Layout title="Dashboard" active="dashboard" nonce={nonce}>

<style nonce={nonce}>

  /* ── Turnstile wrapper ── */
  .hm-turnstile-wrap {
    display: flex;
    justify-content: center;
    margin: .75rem 0 .25rem;
    min-height: 65px;
  }
  .hm-turnstile-wrap:empty::after {
    content: 'Memuat verifikasi…';
    font-size: .72rem;
    color: var(--muted);
    align-self: center;
  }

  /* ── Turnstile loading state ── */
  .ts-loading-msg {
    display: flex;
    align-items: center;
    gap: .5rem;
    font-size: .72rem;
    color: #9ca3af;
  }
  .ts-loading-spinner {
    width: 14px; height: 14px;
    border: 2px solid #e5e7eb;
    border-top-color: #c84b1f;
    border-radius: 50%;
    animation: ts-spin .7s linear infinite;
    flex-shrink: 0;
  }
  @keyframes ts-spin { to { transform: rotate(360deg); } }

  /* ── Turnstile error state ── */
  .ts-error-msg {
    display: flex;
    align-items: center;
    gap: .4rem;
    font-size: .7rem;
    color: #dc2626;
  }
  .ts-retry-btn {
    font-size: .68rem;
    font-weight: 600;
    color: #c84b1f;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    text-decoration: underline;
  }
  .ts-retry-btn:hover { color: #9a3412; }

  /* ── Verified state indicator ── */
  .ts-verified-msg {
    display: flex;
    align-items: center;
    gap: .4rem;
    font-size: .72rem;
    color: #15803d;
    font-weight: 600;
  }
  .ts-verified-icon {
    width: 16px; height: 16px;
    background: #dcfce7;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: .6rem;
    flex-shrink: 0;
  }

  /* ══ Modal ═══════════════════════════════════════════════════════════════ */
  .modal-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 50;
    background: rgba(0,0,0,.45);
    backdrop-filter: blur(2px);
  }
  .modal-box {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%,-50%);
    background: #fff;
    border-radius: 10px;
    width: min(440px, calc(100vw - 2rem));
    box-shadow: 0 20px 60px rgba(0,0,0,.18);
    overflow: hidden;
  }
  .modal-header {
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid rgba(15,13,11,.07);
    display: flex;
    align-items: center;
    gap: .75rem;
  }
  .modal-header-icon {
    width: 32px; height: 32px;
    border-radius: 8px;
    background: #fef2f2;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .modal-title {
    font-size: .9rem;
    font-weight: 700;
    color: #0f0d0b;
    margin: 0;
  }
  .modal-subtitle {
    font-size: .68rem;
    color: #9ca3af;
    margin: 1px 0 0;
  }
  .modal-close-btn {
    margin-left: auto;
    width: 28px; height: 28px;
    border: none; background: none;
    cursor: pointer;
    color: #9ca3af;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 6px;
    transition: background .12s, color .12s;
  }
  .modal-close-btn:hover { background: #f3f4f6; color: #374151; }

  .modal-body {
    padding: 1.375rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .modal-field-label {
    font-size: .7rem;
    font-weight: 600;
    color: #374151;
    display: block;
    margin-bottom: .5rem;
  }
  .radio-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: .5rem;
  }
  .radio-label {
    display: flex;
    align-items: center;
    gap: .5rem;
    padding: .6rem .75rem;
    border: 1.5px solid #e5e7eb;
    border-radius: 7px;
    cursor: pointer;
    transition: border-color .12s, background .12s;
  }
  .radio-label-text-bold { font-size: .75rem; font-weight: 600; color: #0f0d0b; }
  .radio-label-text      { font-size: .75rem; font-weight: 500; color: #374151; }

  .warning-box {
    background: #fef2f2;
    border: 1px solid #fecaca;
    border-radius: 7px;
    padding: .75rem 1rem;
    display: flex;
    gap: .5rem;
    align-items: flex-start;
  }
  .warning-icon { flex-shrink: 0; margin-top: 1px; }
  .warning-text { font-size: .7rem; color: #dc2626; margin: 0; line-height: 1.5; }

  .modal-footer {
    padding: 1rem 1.5rem;
    border-top: 1px solid rgba(15,13,11,.07);
    display: flex;
    gap: .625rem;
    justify-content: flex-end;
  }
  .btn-cancel {
    padding: .5rem 1rem;
    font-size: .78rem; font-weight: 600;
    border: 1.5px solid #e5e7eb;
    background: #fff; color: #374151;
    border-radius: 7px; cursor: pointer;
    transition: background .12s;
  }
  .btn-cancel:hover { background: #f9fafb; }
  .btn-danger {
    padding: .5rem 1.25rem;
    font-size: .78rem; font-weight: 700;
    border: none;
    background: #dc2626; color: #fff;
    border-radius: 7px; cursor: pointer;
    display: flex; align-items: center; gap: .4rem;
    transition: background .12s, opacity .12s;
  }
  .btn-danger:hover                          { background: #b91c1c; }
  .btn-danger:disabled                       { opacity: .45; cursor: not-allowed; background: #dc2626; }
  .btn-cancel:disabled                       { opacity: .6; cursor: not-allowed; }
  .spinner { display: none; }

  /* ══ Toast ═══════════════════════════════════════════════════════════════ */
  .toast {
    position: fixed;
    bottom: 1.5rem; right: 1.5rem;
    z-index: 100;
    display: none;
    padding: .75rem 1.125rem;
    border-radius: 8px;
    font-size: .78rem; font-weight: 600;
    box-shadow: 0 8px 24px rgba(0,0,0,.15);
    align-items: center; gap: .5rem;
    transition: opacity .2s;
    opacity: 0;
    pointer-events: none;
  }

  /* ══ Today cards ═════════════════════════════════════════════════════════ */
  .today-omset-label {
    font-size: .62rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: .07em;
    opacity: .45; margin-bottom: 5px;
  }
  .today-omset-value {
    font-size: 1.45rem; font-weight: 800; line-height: 1.1;
  }
  .today-omset-meta {
    display: flex; align-items: center; gap: 6px; margin-top: 5px;
  }
  .today-omset-sub { font-size: .65rem; opacity: .55; }

  .today-cash-label {
    font-size: .62rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: .07em;
    color: #15803d; margin-bottom: 5px;
  }
  .today-cash-value { font-size: 1.35rem; font-weight: 800; color: #14532d; line-height: 1.1; }
  .today-cash-sub   { font-size: .65rem; color: #16a34a; margin-top: 5px; }

  .today-qris-label {
    font-size: .62rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: .07em;
    color: #1d4ed8; margin-bottom: 5px;
  }
  .today-qris-value { font-size: 1.35rem; font-weight: 800; color: #1e3a8a; line-height: 1.1; }
  .today-qris-sub   { font-size: .65rem; color: #2563eb; margin-top: 5px; }

  .today-item-label {
    font-size: .62rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: .07em;
    color: #b45309; margin-bottom: 5px;
  }
  .today-item-value { font-size: 1.35rem; font-weight: 800; color: #78350f; line-height: 1.1; }
  .today-item-sub   { font-size: .65rem; color: #d97706; margin-top: 5px; }

  /* ══ vs-kemarin badge ════════════════════════════════════════════════════ */
  .badge-up   { font-size:.6rem;font-weight:700;padding:1px 5px;border-radius:99px;background:rgba(34,197,94,.2);color:#4ade80; }
  .badge-down { font-size:.6rem;font-weight:700;padding:1px 5px;border-radius:99px;background:rgba(248,113,113,.2);color:#f87171; }

  /* ══ Mini-chart bars ═════════════════════════════════════════════════════ */
  .mc-bar-today  { background: #c84b1f; }
  .mc-bar-normal { background: #f3d5cc; }

  /* ══ Tren section header ═════════════════════════════════════════════════ */
  .tren-header-right {
    display: flex; align-items: center; justify-content: space-between;
  }
  .tren-total-label { font-size: .68rem; color: #9ca3af; margin-top: 1px; }
  .tren-total-val   { font-weight: 600; color: #0f0d0b; }

  .mini-chart-pad { padding: 1.125rem 1.375rem .875rem; }

  /* ══ Transaksi terbaru ═══════════════════════════════════════════════════ */
  .trx-section-head {
    display: flex; align-items: center; justify-content: space-between;
  }
  .trx-count-note  { font-size: .62rem; color: #9ca3af; flex-shrink: 0; }
  .trx-empty       { font-size: .75rem; color: #9ca3af; text-align: center; padding: 2rem 1rem; }

  .trx-row-total   { font-size: .77rem; font-weight: 600; color: #0f0d0b; }
  .trx-row-time    { font-size: .62rem; color: #9ca3af; }

  /* ══ Ringkasan pembayaran ════════════════════════════════════════════════ */
  .pay-section-head {
    display: flex; align-items: center;
    justify-content: space-between;
  }
  .pay-method-row {
    display: flex; align-items: center; gap: 12px;
    padding: .85rem 1.375rem;
    border-bottom: 1px solid rgba(15,13,11,.05);
  }
  .pay-method-icon {
    width: 30px; height: 30px; border-radius: 6px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .pay-method-icon-green { background: #dcfce7; }
  .pay-method-icon-blue  { background: #dbeafe; }

  .pay-method-detail   { flex: 1; min-width: 0; }
  .pay-method-name-row { display: flex; justify-content: space-between; margin-bottom: 5px; }
  .pay-method-name         { font-size: .77rem; font-weight: 600; color: #0f0d0b; }
  .pay-method-amount-green { font-size: .77rem; font-weight: 700; color: #15803d; }
  .pay-method-amount-blue  { font-size: .77rem; font-weight: 700; color: #1d4ed8; }
  .pay-method-note         { font-size: .62rem; color: #9ca3af; margin-top: 3px; }

  .pay-total-row {
    padding: .8rem 1.375rem;
    background: #fdf9f6;
    display: flex; justify-content: space-between; align-items: center;
  }
  .pay-total-label { font-size: .72rem; color: #6b7280; font-weight: 500; }
  .pay-total-value { font-size: .95rem; font-weight: 800; color: #0f0d0b; }

  /* ══ Stat mini grid ══════════════════════════════════════════════════════ */
  .stat-mini-card { padding: 1.1rem 1.375rem; }
  .stat-mini-card-border-b { border-bottom: 1px solid rgba(15,13,11,.06); }
  .stat-mini-card-border-r { border-right: 1px solid rgba(15,13,11,.06); }

  .stat-mini-label {
    font-size: .62rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: .06em;
    color: #9ca3af; margin-bottom: 5px;
  }
  .stat-mini-val { font-size: 1.15rem; font-weight: 800; line-height: 1.15; }
  .stat-mini-sub { font-size: .62rem; color: #9ca3af; margin-top: 2px; }

  .stat-mini-color-primary { color: #0f0d0b; }
  .stat-mini-color-accent  { color: #c84b1f; }
  .stat-mini-color-green   { color: #15803d; }
  .stat-mini-color-blue    { color: #1d4ed8; }

  /* ══ Stat cards produk ═══════════════════════════════════════════════════ */
  .stat-top { display: flex; align-items: flex-start; justify-content: space-between; gap: .75rem; }

  .stat-label {
    font-size: .65rem; font-weight: 600;
    color: #9ca3af;
    text-transform: uppercase; letter-spacing: .05em;
  }
  .stat-value {
    font-size: 1.9rem; font-weight: 700;
    color: #0f0d0b;
    line-height: 1; margin-top: .5rem;
  }
  .stat-value-danger { color: #ef4444; }
  .stat-sub { font-size: .68rem; color: #9ca3af; margin-top: .375rem; }

  .stat-icon-wrap         { background: #fdf6f3; }
  .stat-icon-wrap-danger  { background: #fef2f2; }

  /* ══ Tabel produk ════════════════════════════════════════════════════════ */
  .prod-name-cell  { display: flex; align-items: center; gap: .5rem; }
  .prod-name-text  { font-weight: 500; color: #0f0d0b; }
  .quick-cash-dot  { width: 5px; height: 5px; border-radius: 50%; background: #c84b1f; flex-shrink: 0; display: inline-block; }

  .tabel-produk-empty { padding: 2.5rem 1.375rem; text-align: center; color: #9ca3af; font-size: .8rem; }
  .tabel-produk-link  { color: #c84b1f; font-weight: 600; }
  .tabel-produk-link:hover { text-decoration: underline; }

  /* ══ Top Seller ══════════════════════════════════════════════════════════ */
  .top-seller-row   { display: flex; align-items: center; gap: .6rem; }
  .top-seller-rank  { font-size: .65rem; font-weight: 700; color: #d1d5db; width: 1rem; text-align: right; flex-shrink: 0; }
  .top-seller-info  { flex: 1; min-width: 0; }
  .top-seller-name  { font-size: .77rem; font-weight: 500; color: #0f0d0b; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .top-seller-qty   { font-size: .7rem; font-weight: 600; color: #6b7280; flex-shrink: 0; }
  .top-seller-pad   { padding: .875rem 1.375rem; display: flex; flex-direction: column; gap: .7rem; }
  .top-seller-empty { font-size: .75rem; color: #9ca3af; text-align: center; padding: .75rem 0; }

  /* ══ Log perubahan harga ═════════════════════════════════════════════════ */
  .log-name      { font-size: .77rem; font-weight: 500; color: #0f0d0b; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .log-price-row { display: flex; align-items: center; gap: .5rem; margin-top: 2px; }
  .log-price-old { font-size: .65rem; color: #9ca3af; text-decoration: line-through; }
  .log-price-arrow { width: 9px; height: 9px; color: #d1d5db; flex-shrink: 0; }
  .log-price-new   { font-size: .65rem; font-weight: 700; color: #c84b1f; }
  .log-price-date  { font-size: .6rem; color: #d1d5db; margin-left: auto; flex-shrink: 0; }
  .log-empty       { font-size: .75rem; color: #9ca3af; text-align: center; padding: 1.25rem; }

  /* ══ Breakdown kategori ══════════════════════════════════════════════════ */
  .kat-card {
    text-align: center; padding: 1rem;
    border: 1px solid rgba(15,13,11,.07); border-radius: 6px;
    transition: box-shadow .15s, transform .15s;
  }
  .kat-card:hover { box-shadow: 0 4px 14px rgba(15,13,11,.08); transform: translateY(-2px); }
  .kat-count  { font-size: 1.7rem; font-weight: 700; color: #0f0d0b; margin: .5rem 0 0; }
  .kat-sub    { font-size: .65rem; color: #9ca3af; margin: 1px 0 .375rem; }
  .kat-margin { font-size: .68rem; font-weight: 600; color: #c84b1f; }
  .kat-grid-pad { padding: 1.125rem 1.375rem; }

  /* ══ Section head variants ═══════════════════════════════════════════════ */
  .section-head-col {
    flex-direction: column;
    align-items: flex-start;
    gap: 1px;
  }

  /* ══ Heading font ════════════════════════════════════════════════════════ */
  .dash-title { font-family: 'DM Serif Display', serif; }

  /* ══ Tabel — padding kolom pertama & terakhir ════════════════════════════ */
  .th-pad-left,  .td-pad-left  { padding-left:  1.375rem !important; }
  .th-pad-right, .td-pad-right { padding-right: 1.375rem !important; }
</style>

<!-- ── Modal Hapus Histori ────────────────────────────────────────────────── -->
<div id="modalHapus" class="modal-backdrop"
  role="dialog" aria-modal="true" aria-labelledby="modalHapusTitle">
  <div class="modal-box">

    <div class="modal-header">
      <div class="modal-header-icon">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
          <path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
        </svg>
      </div>
      <div>
        <h3 id="modalHapusTitle" class="modal-title">Hapus Histori</h3>
        <p class="modal-subtitle">Data yang dihapus tidak dapat dipulihkan</p>
      </div>
      <button id="modalHapusClose" class="modal-close-btn" aria-label="Tutup">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    <div class="modal-body">
      <div>
        <label class="modal-field-label">Hapus data apa?</label>
        <div class="radio-grid">
          <label id="lbl-transaksi" class="radio-label">
            <input type="radio" name="hapusType" value="transaksi" style="accent-color:#c84b1f" checked>
            <span class="radio-label-text-bold">Histori Transaksi</span>
          </label>
          <label id="lbl-harga_log" class="radio-label">
            <input type="radio" name="hapusType" value="harga_log" style="accent-color:#c84b1f">
            <span class="radio-label-text-bold">Log Perubahan Harga</span>
          </label>
        </div>
      </div>

      <div>
        <label class="modal-field-label">Rentang waktu</label>
        <div class="radio-grid">
          {[
            { val: "hari_ini", label: "Hari Ini" },
            { val: "7_hari",   label: "7 Hari Terakhir" },
            { val: "30_hari",  label: "30 Hari Terakhir" },
            { val: "semua",    label: "Semua Waktu" },
          ].map(r => (
            <label class="radio-label range-lbl">
              <input type="radio" name="hapusRange" value={r.val} style="accent-color:#c84b1f" checked={r.val === "hari_ini"}>
              <span class="radio-label-text">{r.label}</span>
            </label>
          ))}
        </div>
      </div>

      <div class="warning-box">
        <svg class="warning-icon" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
          <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
        </svg>
        <p id="hapusWarningText" class="warning-text">
          Histori transaksi hari ini akan dihapus permanen, termasuk seluruh item transaksi terkait.
        </p>
      </div>
    </div>

    <!-- ── Turnstile verification area ── -->
    <div class="hm-turnstile-wrap">
      <div id="hm-turnstile-container"></div>
    </div>

    <div class="modal-footer">
      <button id="hapusCancelBtn" class="btn-cancel">Batal</button>
      <button id="hapusKonfirmasiBtn" class="btn-danger" disabled>
        <svg id="hapusSpinner" class="spinner" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
        </svg>
        <span id="hapusBtnLabel">Hapus Sekarang</span>
      </button>
    </div>

  </div>
</div>

<!-- ── Toast Notifikasi ───────────────────────────────────────────────────── -->
<div id="toastNotif" class="toast" role="status" aria-live="polite">
  <span id="toastIcon"></span>
  <span id="toastText"></span>
</div>

<!-- ── Sticky Header ─────────────────────────────────────────────────────── -->
<div class="bg-white border-b border-black/[0.07] px-4 sm:px-6 lg:px-8 py-4
            flex items-center justify-between sticky top-0 z-20 fade-up">
  <div class="flex items-center gap-3">
    <button id="btnOpenSidebar"
      class="lg:hidden w-8 h-8 flex items-center justify-center rounded text-gray-500
             hover:text-gray-800 hover:bg-gray-100 transition-colors"
