      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
    <div>
      <h1 class="dash-title text-[1.2rem] leading-tight text-[#0f0d0b]">Dashboard</h1>
      <p class="text-[.7rem] text-gray-400 hidden sm:block">
        {salam}, <span class="font-medium text-gray-600">{userEmail.split("@")[0]}</span>
        <span class="text-gray-300 mx-1">·</span>
        <span>{tanggalStr}</span>
      </p>
    </div>
  </div>
  <div class="flex items-center gap-2">
    <button id="btnHapusHistori"
      class="flex items-center gap-1.5 px-3.5 py-2 border border-red-200 hover:border-red-400
             text-red-500 hover:text-red-700 hover:bg-red-50 text-[.78rem] font-semibold
             rounded transition-colors"
      aria-label="Hapus histori data">
      <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
        <path d="M10 11v6"/><path d="M14 11v6"/>
      </svg>
      <span class="hidden sm:inline">Hapus Histori</span>
    </button>
    <a href="/dashboard/produk?modal=tambah"
      class="flex items-center gap-1.5 px-3.5 py-2 bg-[#0f0d0b] hover:bg-[#c84b1f]
             text-white text-[.78rem] font-semibold rounded transition-colors">
      <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
      <span class="hidden sm:inline">Tambah Produk</span>
      <span class="sm:hidden">Tambah</span>
    </a>
  </div>
</div>

<!-- ── Konten ─────────────────────────────────────────────────────────────── -->
<div class="page-pad p-5 lg:p-7 space-y-5 max-w-[1400px] mx-auto">

  <!-- ① HARI INI ────────────────────────────────────────────────────────── -->
  <div class="fade-up d1">
    <p class="text-[.65rem] font-semibold text-gray-400 uppercase tracking-widest mb-2.5">Hari Ini</p>
    <div class="today-grid grid grid-cols-4 gap-3">

      <div class="today-card dark">
        <p class="today-omset-label">Omset</p>
        <p class="today-omset-value">{rp(omsetHari)}</p>
        <div class="today-omset-meta">
          <span class="today-omset-sub">{hari.length} transaksi · {itemHari} item</span>
          {vsKemarin !== null && (
            <span class={vsKemarin >= 0 ? "badge-up" : "badge-down"}>
              {vsKemarin >= 0 ? "+" : ""}{vsKemarin}%
            </span>
          )}
        </div>
      </div>

      <div class="today-card green">
        <p class="today-cash-label">Cash / Manual</p>
        <p class="today-cash-value">{rp(cashHari)}</p>
        <p class="today-cash-sub">{hari.filter(t => t.metode_bayar !== "qris").length} transaksi</p>
      </div>

      <div class="today-card blue">
        <p class="today-qris-label">QRIS · Statis</p>
        <p class="today-qris-value">{rp(qrisHari)}</p>
        <p class="today-qris-sub">{hari.filter(t => t.metode_bayar === "qris").length} transaksi</p>
      </div>

      <div class="today-card amber">
        <p class="today-item-label">Item Terjual</p>
        <p class="today-item-value">{itemHari}</p>
        <p class="today-item-sub">
          {hari.length > 0 ? `~${(itemHari / hari.length).toFixed(1)} item/trx` : "belum ada transaksi"}
        </p>
      </div>

    </div>
  </div>

  <!-- ② TREN 7 HARI + TRANSAKSI TERBARU ───────────────────────────────── -->
  <div class="trx-chart-grid grid grid-cols-5 gap-4 fade-up d2">

    <div class="col-span-3 section-card">
      <div class="section-head">
        <div>
          <h2>Tren Omset 7 Hari</h2>
          <p class="tren-total-label">
            Total minggu ini: <strong class="tren-total-val">{rp(omsetWeek)}</strong>
          </p>
        </div>
        <a href="/dashboard/analisis"
          class="text-[.72rem] font-semibold text-[#c84b1f] hover:underline whitespace-nowrap flex-shrink-0">
          Analisis lengkap →
        </a>
      </div>
      <div class="mini-chart-pad">
        <div class="mini-chart">
          {days7.map(d => {
            const pct     = (d.omset / maxOmset7) * 100;
            const isToday = d.date === todayKey;
            return (
              <div class={`mc-col${isToday ? " today" : ""}`} data-lbl={d.label}>
                <div class="mc-tip">{rp(d.omset)}<br/>{d.trx} trx</div>
                <div class={`mc-bar ${isToday ? "mc-bar-today" : "mc-bar-normal"}`}
                  style={`height:${pct > 0 ? Math.max(pct, 4) : 0}%`}>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </div>

    <div class="col-span-2 section-card" style="display:flex;flex-direction:column">
      <div class="section-head">
        <div>
          <h2>Transaksi Terbaru</h2>
          <p>Hari ini · {hari.length} total</p>
        </div>
        {hari.length > 8 && (
          <span class="trx-count-note">+{hari.length - 8} lainnya</span>
        )}
      </div>
      {hari.length === 0
        ? <p class="trx-empty">Belum ada transaksi hari ini</p>
        : hari.slice(0, 8).map(t => (
          <div class="trx-row">
            <div>
              <p class="trx-row-total">{rp(t.total)}</p>
              <p class="trx-row-time">{timeStr(t.created_at)}</p>
            </div>
            <span class={`trx-badge ${t.metode_bayar === "qris" ? "badge-qris" : "badge-cash"}`}>
              {t.metode_bayar === "qris" ? "QRIS" : "Cash"}
            </span>
          </div>
        ))
      }
    </div>

  </div>

  <!-- ③ RINGKASAN PEMBAYARAN 30 HARI ───────────────────────────────────── -->
  <div class="fade-up d3">
    <p class="text-[.65rem] font-semibold text-gray-400 uppercase tracking-widest mb-2.5">
      Ringkasan Pembayaran · 30 Hari Terakhir
    </p>
    <div class="pay-grid grid grid-cols-2 gap-4">

      <div class="section-card">
        <div class="section-head pay-section-head">
          <div><h2>Total per Metode Bayar</h2></div>
          <span class="trx-count-note">{trx30.length} transaksi</span>
        </div>

        <div class="pay-method-row">
          <div class="pay-method-icon pay-method-icon-green">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#15803d" stroke-width="2.5" aria-hidden="true">
              <rect x="2" y="6" width="20" height="12" rx="2"/><circle cx="12" cy="12" r="2"/>
            </svg>
          </div>
          <div class="pay-method-detail">
            <div class="pay-method-name-row">
              <span class="pay-method-name">Cash / Manual</span>
              <span class="pay-method-amount-green">{rp(cash30)}</span>
            </div>
            <div class="pay-bar-bg">
              <div class="pay-bar" style={`width:${omset30 > 0 ? (cash30/omset30)*100 : 0}%;background:#22c55e`}></div>
            </div>
            <p class="pay-method-note">
              {cashCnt30} transaksi · {omset30 > 0 ? Math.round((cash30/omset30)*100) : 0}%
            </p>
          </div>
        </div>

        <div class="pay-method-row">
          <div class="pay-method-icon pay-method-icon-blue">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#1d4ed8" stroke-width="2.5" aria-hidden="true">
              <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
              <rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
            </svg>
          </div>
          <div class="pay-method-detail">
            <div class="pay-method-name-row">
              <span class="pay-method-name">QRIS · Statis</span>
              <span class="pay-method-amount-blue">{rp(qris30)}</span>
            </div>
            <div class="pay-bar-bg">
              <div class="pay-bar" style={`width:${omset30 > 0 ? (qris30/omset30)*100 : 0}%;background:#3b82f6`}></div>
            </div>
            <p class="pay-method-note">
              {qrisCnt30} transaksi · {omset30 > 0 ? Math.round((qris30/omset30)*100) : 0}%
            </p>
          </div>
        </div>

        <div class="pay-total-row">
          <span class="pay-total-label">Total Omset 30 Hari</span>
          <span class="pay-total-value">{rp(omset30)}</span>
        </div>
      </div>

      <div class="section-card"
        style="display:grid;grid-template-columns:1fr 1fr;grid-template-rows:1fr 1fr">
        {[
          { lbl: "Total Transaksi", val: String(trx30.length), sub: "30 hari", colorClass: "stat-mini-color-primary" },
          { lbl: "Omset / Hari", val: rp(Math.round(omset30 / 30)), sub: "rata-rata harian", colorClass: "stat-mini-color-accent" },
          { lbl: "Nilai / Transaksi", val: trx30.length > 0 ? rp(Math.round(omset30 / trx30.length)) : "Rp 0", sub: "rata-rata per trx", colorClass: "stat-mini-color-primary" },
          { lbl: "Metode Dominan", val: cashCnt30 >= qrisCnt30 ? "Cash" : "QRIS", sub: cashCnt30 >= qrisCnt30 ? `${cashCnt30} dari ${trx30.length} trx` : `${qrisCnt30} dari ${trx30.length} trx`, colorClass: cashCnt30 >= qrisCnt30 ? "stat-mini-color-green" : "stat-mini-color-blue" },
        ].map((s, i) => (
          <div class={["stat-mini-card", i < 2 ? "stat-mini-card-border-b" : "", i % 2 === 0 ? "stat-mini-card-border-r" : ""].filter(Boolean).join(" ")}>
            <p class="stat-mini-label">{s.lbl}</p>
            <p class={`stat-mini-val ${s.colorClass}`}>{s.val}</p>
            <p class="stat-mini-sub">{s.sub}</p>
          </div>
        ))}
      </div>

    </div>
  </div>

  <!-- ④ STAT CARDS PRODUK ──────────────────────────────────────────────── -->
  <div class="stats-grid grid grid-cols-4 gap-3 fade-up d4">

    <div class="stat-card">
      <div class="stat-top">
        <div>
          <p class="stat-label">Total Produk</p>
          <p class="stat-value">{totalProduk}</p>
          <p class="stat-sub">item terdaftar</p>
        </div>
        <div class="stat-icon stat-icon-wrap">
          <svg class="w-4 h-4 text-[#c84b1f]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
          </svg>
        </div>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-top">
        <div>
          <p class="stat-label">Rata-rata Margin</p>
          <p class="stat-value">{avgMargin}%</p>
          <p class="stat-sub">dari semua produk</p>
        </div>
        <div class="stat-icon stat-icon-wrap">
          <svg class="w-4 h-4 text-[#c84b1f]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
          </svg>
        </div>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-top">
        <div>
          <p class="stat-label">Margin Rendah</p>
          <p class={`stat-value ${lowMargin > 0 ? "stat-value-danger" : ""}`}>{lowMargin}</p>
          <p class="stat-sub">
            {lowMargin > 0
              ? <a href="/dashboard/produk?filter=low_margin" class="text-red-500 hover:underline font-medium">perlu ditinjau →</a>
              : "semua aman"}
          </p>
        </div>
        <div class={`stat-icon ${lowMargin > 0 ? "stat-icon-wrap-danger" : "stat-icon-wrap"}`}>
          <svg class={`w-4 h-4 ${lowMargin > 0 ? "text-red-500" : "text-[#c84b1f]"}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
            <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
          </svg>
        </div>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-top">
        <div>
          <p class="stat-label">Quick Cash</p>
          <p class="stat-value">{quickCashCount}</p>
          <p class="stat-sub">tombol cepat aktif</p>
        </div>
        <div class="stat-icon stat-icon-wrap">
          <svg class="w-4 h-4 text-[#c84b1f]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
          </svg>
        </div>
      </div>
    </div>

  </div>

  <!-- ⑤ TABEL PRODUK + KOLOM KANAN ────────────────────────────────────── -->
  <div class="grid-main grid grid-cols-3 gap-5 fade-up d5">

    <div class="col-span-2 section-card">
      <div class="section-head">
        <div><h2>Daftar Produk</h2></div>
        <a href="/dashboard/produk" class="text-[.72rem] text-[#c84b1f] font-semibold hover:underline whitespace-nowrap">
          Lihat semua →
        </a>
      </div>
      <div class="overflow-x-auto">
        <table class="data-table">
          <thead>
            <tr>
              <th class="th-pad-left">Nama Produk</th>
              <th class="hide-xs">Kategori</th>
              <th>Harga Jual</th>
              <th class="th-pad-right">Margin</th>
            </tr>
          </thead>
          <tbody>
            {produk.slice(0, 8).map(p => {
              const m  = margin(p.harga_beli, p.harga_jual);
              const mc = m >= 20 ? "m-good" : m >= 10 ? "m-mid" : "m-low";
              return (
                <tr>
                  <td class="td-pad-left">
                    <div class="prod-name-cell">
                      {p.quick_cash && <span title="Quick Cash" class="quick-cash-dot"></span>}
                      <span class="prod-name-text">{p.nama_produk}</span>
                    </div>
                  </td>
                  <td class="hide-xs">
                    <span class={`${katColors[p.kategori] ?? "kat-gray"} inline-block px-2 py-0.5 rounded text-[.62rem] font-semibold`}>
                      {p.kategori}
                    </span>
                  </td>
                  <td class="prod-name-text">{rp(p.harga_jual)}</td>
                  <td class="td-pad-right">
                    <span class={`${mc} inline-block px-2 py-0.5 rounded text-[.63rem] font-bold`}>{m}%</span>
                  </td>
                </tr>
              );
            })}
            {produk.length === 0 && (
              <tr>
                <td colspan="4" class="tabel-produk-empty">
                  Belum ada produk.{" "}
                  <a href="/dashboard/produk?modal=tambah" class="tabel-produk-link">Tambah sekarang →</a>
                </td>
              </tr>
            )}
          </tbody>
        </table>
      </div>
    </div>

    <div class="col-right space-y-4">

      <div class="section-card">
        <div class="section-head section-head-col">
          <h2>Top Seller</h2>
          <p>Berdasarkan total qty terjual</p>
        </div>
        <div class="top-seller-pad">
          {topSellers.length === 0
            ? <p class="top-seller-empty">Belum ada data</p>
            : topSellers.map((t, i) => (
              <div class="top-seller-row">
                <span class="top-seller-rank">{i + 1}</span>
                <div class="top-seller-info">
                  <p class="top-seller-name">{t.nama}</p>
                  <div class="ts-bar-bg">
                    <div class="ts-bar" style={`width:${Math.min(100,(t.total/(topSellers[0]?.total||1))*100)}%`}></div>
                  </div>
                </div>
                <span class="top-seller-qty">{t.total}×</span>
              </div>
            ))
          }
        </div>
      </div>

      <div class="section-card">
        <div class="section-head section-head-col">
          <h2>Log Perubahan Harga</h2>
          <p>Riwayat terbaru</p>
        </div>
        {logs.length === 0
          ? <p class="log-empty">Belum ada perubahan harga</p>
          : logs.slice(0, 5).map(l => (
            <div class="log-item">
              <p class="log-name">{l.nama_produk}</p>
              <div class="log-price-row">
                <span class="log-price-old">{rp(l.harga_jual_lama ?? 0)}</span>
                <svg class="log-price-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                </svg>
                <span class="log-price-new">{rp(l.harga_jual_baru ?? 0)}</span>
                <span class="log-price-date">
                  {new Date(l.changed_at).toLocaleDateString("id-ID", { day: "2-digit", month: "short" })}
                </span>
              </div>
            </div>
          ))
        }
      </div>

    </div>
  </div>

  <!-- ⑥ BREAKDOWN KATEGORI ─────────────────────────────────────────────── -->
  <div class="section-card fade-up d6">
    <div class="section-head">
      <div><h2>Breakdown per Kategori</h2></div>
    </div>
    <div class="kat-grid-pad">
      <div class="kat-grid grid grid-cols-5 gap-3">
        {katBreakdown.map(({ kat, count, avgM, colorKey }) => (
          <div class="kat-card">
            <span class={`${colorKey} inline-block px-2.5 py-1 rounded text-[.6rem] font-bold uppercase tracking-wide`}>
              {kat}
            </span>
            <p class="kat-count">{count}</p>
            <p class="kat-sub">produk</p>
            <p class="kat-margin">{avgM}% margin</p>
          </div>
        ))}
      </div>
    </div>
  </div>

</div>

<!-- ── Inject site key aman ke window (tidak expose di HTML source langsung) ── -->
<script is:inline nonce={nonce} define:vars={{ PUBLIC_TURNSTILE_SITEKEY }}>
  window.__TS_SITEKEY = PUBLIC_TURNSTILE_SITEKEY;
</script>

<!-- ── Load Turnstile SDK (render=explicit agar kita kontrol kapan render) ── -->
<script src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit" async defer></script>

<!-- ── Script Modal Hapus Histori + Turnstile ─────────────────────────────── -->
<script is:inline nonce={nonce}>
(function () {
  "use strict";

  function initDashboard() {
    if (!document.getElementById("modalHapus")) return;

    var modal       = document.getElementById("modalHapus");
    var btnBuka     = document.getElementById("btnHapusHistori");
    var btnSidebar  = document.getElementById("btnOpenSidebar");
    var btnTutup    = document.getElementById("modalHapusClose");
    var btnBatal    = document.getElementById("hapusCancelBtn");
    var btnKonfirm  = document.getElementById("hapusKonfirmasiBtn");
    var spinner     = document.getElementById("hapusSpinner");
    var btnLabel    = document.getElementById("hapusBtnLabel");
    var warnText    = document.getElementById("hapusWarningText");
    var toast       = document.getElementById("toastNotif");
    var toastTxt    = document.getElementById("toastText");
    var toastIco    = document.getElementById("toastIcon");
    var tsWrap      = document.querySelector(".hm-turnstile-wrap");
    var tsContainer = document.getElementById("hm-turnstile-container");

    if (!modal || !btnBuka) return;

    // ── State Turnstile ────────────────────────────────────────────
    var _widgetId = null;
    var _token    = null;
    var _pollTimer = null;

    // ── Sidebar ────────────────────────────────────────────────────
    if (btnSidebar) {
      btnSidebar.addEventListener("click", function () {
        if (window.openSidebar) window.openSidebar();
      });
    }

    // ── Warning messages ───────────────────────────────────────────
    var WARN = {
      transaksi: {
        hari_ini:  "Histori transaksi hari ini akan dihapus permanen, termasuk seluruh item transaksi terkait.",
        "7_hari":  "Histori transaksi 7 hari terakhir akan dihapus permanen. Tindakan ini tidak dapat dibatalkan.",
        "30_hari": "Histori transaksi 30 hari terakhir akan dihapus permanen. Pastikan data sudah dicatat sebelum melanjutkan.",
        semua:     "⚠️ SELURUH histori transaksi akan dihapus permanen. Data tidak dapat dipulihkan sama sekali!",
      },
      harga_log: {
        hari_ini:  "Log perubahan harga hari ini akan dihapus permanen.",
        "7_hari":  "Log perubahan harga 7 hari terakhir akan dihapus permanen.",
        "30_hari": "Log perubahan harga 30 hari terakhir akan dihapus permanen.",
        semua:     "⚠️ SELURUH log perubahan harga akan dihapus permanen. Riwayat harga tidak dapat dipulihkan!",
      },
    };

    function getSelected(name) {
      var el = document.querySelector('[name="' + name + '"]:checked');
      return el ? el.value : null;
    }

    function updateWarning() {
      var type  = getSelected("hapusType")  || "transaksi";
      var range = getSelected("hapusRange") || "hari_ini";
      if (warnText && WARN[type] && WARN[type][range]) {
        warnText.textContent      = WARN[type][range];
        warnText.style.fontWeight = range === "semua" ? "700" : "400";
      }
    }

    function syncRadioStyles() {
      document.querySelectorAll('[name="hapusType"],[name="hapusRange"]').forEach(function (radio) {
        var lbl = radio.closest("label");
        if (!lbl) return;
        lbl.style.borderColor = radio.checked ? "#c84b1f" : "#e5e7eb";
        lbl.style.background  = radio.checked ? "#fdf6f3" : "#fff";
      });
      updateWarning();
    }

    // ── Toast ──────────────────────────────────────────────────────
    var toastTimer = null;
    function showToast(msg, ok) {
      if (!toast || !toastTxt || !toastIco) return;
      toastTxt.textContent      = msg;
      toastIco.textContent      = ok ? "✓" : "✕";
      toast.style.background    = ok ? "#0f0d0b" : "#dc2626";
      toast.style.color         = "#fff";
      toast.style.display       = "flex";
      toast.offsetHeight;
      toast.style.opacity       = "1";
      toast.style.pointerEvents = "auto";
      if (toastTimer) clearTimeout(toastTimer);
      toastTimer = setTimeout(function () {
        toast.style.opacity       = "0";
        toast.style.pointerEvents = "none";
        setTimeout(function () { toast.style.display = "none"; }, 220);
      }, 3500);
    }

    // ── Turnstile UI states ────────────────────────────────────────
    function setTsState(state) {
      // state: "loading" | "widget" | "verified" | "error"
      if (!tsContainer) return;

      if (state === "loading") {
        tsContainer.innerHTML =
          '<div class="ts-loading-msg">' +
            '<div class="ts-loading-spinner"></div>' +
            '<span>Memuat verifikasi…</span>' +
          '</div>';
        btnKonfirm.disabled = true;

      } else if (state === "widget") {
        tsContainer.innerHTML = "";
        // widget akan di-render ke dalam tsContainer oleh Turnstile SDK
        btnKonfirm.disabled = true;

      } else if (state === "verified") {
        // Tampilkan indikator sukses di bawah widget
        // (widget Turnstile sendiri sudah tampil centang, ini hanya pelengkap)
        btnKonfirm.disabled = false;

      } else if (state === "error") {
        tsContainer.innerHTML =
          '<div class="ts-error-msg">' +
            '<span>Verifikasi gagal.</span>' +
            '<button class="ts-retry-btn" id="tsRetryBtn">Coba lagi</button>' +
          '</div>';
        btnKonfirm.disabled = true;
        var retryBtn = document.getElementById("tsRetryBtn");
        if (retryBtn) retryBtn.addEventListener("click", function () { renderWidget(); });
      }
    }

    // ── Render Turnstile widget ────────────────────────────────────
    function renderWidget() {
      if (!tsContainer) return;

      // Hapus widget lama jika ada
      if (_widgetId !== null) {
        try { window.turnstile.remove(_widgetId); } catch (e) {}
        _widgetId = null;
        _token    = null;
      }

      setTsState("widget");

      _widgetId = window.turnstile.render(tsContainer, {
        sitekey: window.__TS_SITEKEY,
        theme:   "light",
        size:    "normal",

        callback: function (token) {
          _token = token;
          setTsState("verified");
        },

        "expired-callback": function () {
          _token = null;
          btnKonfirm.disabled = true;
          // Turnstile otomatis re-render token baru; tunggu callback lagi
        },

        "error-callback": function () {
          _token = null;
          setTsState("error");
        },
      });
    }

    // ── Tunggu SDK siap lalu render ────────────────────────────────
    function initTurnstile() {
      setTsState("loading");
      if (window.turnstile) {
        renderWidget();
        return;
      }
      // Poll sampai SDK load (max ~10 detik)
      var attempts = 0;
      _pollTimer = setInterval(function () {
        attempts++;
        if (window.turnstile) {
          clearInterval(_pollTimer);
          _pollTimer = null;
          renderWidget();
        } else if (attempts > 50) {
          clearInterval(_pollTimer);
          _pollTimer = null;
          setTsState("error");
        }
      }, 200);
    }

    // ── Bersihkan widget & timer saat modal ditutup ────────────────
    function destroyTurnstile() {
      if (_pollTimer) { clearInterval(_pollTimer); _pollTimer = null; }
      if (_widgetId !== null && window.turnstile) {
        try { window.turnstile.remove(_widgetId); } catch (e) {}
      }
      _widgetId = null;
      _token    = null;
      if (tsContainer) tsContainer.innerHTML = "";
      btnKonfirm.disabled = true;
    }

    // ── Buka / tutup modal ─────────────────────────────────────────
    function onEsc(e) { if (e.key === "Escape") tutupModal(); }

    function bukaModal() {
      modal.style.display = "block";
      syncRadioStyles();
      document.addEventListener("keydown", onEsc);
      setTimeout(function () { if (btnBatal) btnBatal.focus(); }, 50);
      initTurnstile(); // ← mulai Turnstile
    }

    function tutupModal() {
      modal.style.display = "none";
      document.removeEventListener("keydown", onEsc);
      destroyTurnstile(); // ← bersihkan Turnstile
    }

    btnBuka.addEventListener("click",  bukaModal);
    btnTutup.addEventListener("click", tutupModal);
    btnBatal.addEventListener("click", tutupModal);
    modal.addEventListener("click", function (e) {
      if (e.target === modal) tutupModal();
    });

    document.querySelectorAll('[name="hapusType"],[name="hapusRange"]').forEach(function (el) {
      el.addEventListener("change", syncRadioStyles);
    });

    // ── Eksekusi hapus ─────────────────────────────────────────────
    btnKonfirm.addEventListener("click", function () {
      var type  = getSelected("hapusType");
      var range = getSelected("hapusRange");
      if (!type || !range) return;

      // Wajib punya token Turnstile yang valid
      if (!_token) {
        showToast("Selesaikan verifikasi terlebih dahulu.", false);
        return;
      }

      if (range === "semua") {
        var label = type === "transaksi" ? "SELURUH histori transaksi" : "SELURUH log perubahan harga";
        if (!window.confirm("⚠️ Yakin ingin menghapus " + label + "?\n\nData tidak dapat dipulihkan!")) return;
      }

      btnKonfirm.disabled   = true;
      btnBatal.disabled     = true;
      spinner.style.display = "block";
      btnLabel.textContent  = "Menghapus...";

      fetch("/api/admin/hapus-histori", {
        method:      "DELETE",
        credentials: "same-origin",
        headers:     { "Content-Type": "application/json" },
        body: JSON.stringify({
          type:           type,
          range:          range,
          turnstileToken: _token,   // ← token dikirim ke server untuk diverifikasi
        }),
      })
      .then(function (res) {
        return res.json().then(function (data) {
          if (res.ok && data.ok) {
            tutupModal();
            var deleted   = data.deleted || 0;
            var typeLabel = type === "transaksi" ? "transaksi" : "log harga";
            showToast("✓ " + deleted + " " + typeLabel + " berhasil dihapus", true);
            setTimeout(function () { window.location.reload(); }, 1500);
          } else {
            showToast(data.error || "Gagal menghapus data.", false);
            // Reset Turnstile agar user bisa coba lagi dengan token baru
            destroyTurnstile();
            initTurnstile();
          }
        });
      })
      .catch(function () {
        showToast("Gagal terhubung ke server.", false);
        destroyTurnstile();
        initTurnstile();
      })
      .finally(function () {
        btnBatal.disabled     = false;
        spinner.style.display = "none";
        btnLabel.textContent  = "Hapus Sekarang";
        // btnKonfirm.disabled tetap true sampai Turnstile re-verify
      });
    });
  }

  // ── Bootstrap guard (ViewTransitions safe) ─────────────────────
  if (!window.__dashboardScriptMounted) {
    window.__dashboardScriptMounted = true;
    document.addEventListener("astro:page-load", initDashboard);
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initDashboard);
  } else {
    initDashboard();
  }

}());
</script>

</Layout>
