---
export const prerender = false;
import Layout from "../../layouts/Layout.astro";
import { createServiceClient } from "../../lib/supabase";
import "../../styles/global.css";
import "../../styles/dashboard.css";

// Auth guard — middleware sudah handle redirect, ini double-check
const accessToken = Astro.cookies.get("sb-access-token");
if (!accessToken?.value) return Astro.redirect("/");

const nonce = (Astro.locals as App.Locals).nonce ?? "";
const sb    = createServiceClient();

// ── Time helpers ───────────────────────────────────────────────────────────
function toWIB(iso: string) {
  return new Date(new Date(iso).getTime() + 7 * 60 * 60 * 1000);
}
function pad2(n: number) { return String(n).padStart(2, "0"); }

const nowWIB = toWIB(new Date().toISOString());

// Awal hari ini WIB → UTC
const todayStart = new Date(nowWIB);
todayStart.setHours(0, 0, 0, 0);
const todayStartUTC = new Date(todayStart.getTime() - 7 * 60 * 60 * 1000);

// 7 & 30 hari lalu
const week7UTC   = new Date(todayStartUTC.getTime() - 6  * 24 * 60 * 60 * 1000);
const month30UTC = new Date(todayStartUTC.getTime() - 29 * 24 * 60 * 60 * 1000);

// ── Data fetching paralel ──────────────────────────────────────────────────
const [
  { data: produkList },
  { data: logList },
  { data: trxHariIni },
  { data: trx7Raw },
  { data: trx30Raw },
  { data: topItems },
] = await Promise.all([
  sb.from("produk").select("*").order("nama_produk"),
  sb.from("harga_log").select("*").order("changed_at", { ascending: false }).limit(10),
  sb.from("transaksi")
    .select("id, total, metode_bayar, created_at, transaksi_item(qty)")
    .eq("status", "paid")
    .gte("created_at", todayStartUTC.toISOString())
    .order("created_at", { ascending: false }),
  sb.from("transaksi")
    .select("id, total, metode_bayar, created_at")
    .eq("status", "paid")
    .gte("created_at", week7UTC.toISOString())
    .order("created_at", { ascending: true }),
  sb.from("transaksi")
    .select("id, total, metode_bayar, created_at")
    .eq("status", "paid")
    .gte("created_at", month30UTC.toISOString()),
  sb.from("transaksi_item")
    .select("produk_id, nama_produk, qty")
    .limit(300),
]);

const produk  = produkList  ?? [];
const logs    = logList     ?? [];
const hari    = trxHariIni  ?? [];
const trx7    = trx7Raw     ?? [];
const trx30   = trx30Raw    ?? [];

// ── Statistik produk ───────────────────────────────────────────────────────
const totalProduk    = produk.length;
const avgMargin      = produk.length
  ? Math.round(produk.reduce((s, p) => s + ((p.harga_jual - p.harga_beli) / (p.harga_beli || 1)) * 100, 0) / produk.length)
  : 0;
const lowMargin      = produk.filter(p => p.harga_beli > 0 && ((p.harga_jual - p.harga_beli) / p.harga_beli) < 0.10).length;
const quickCashCount = produk.filter(p => p.quick_cash).length;

// ── Statistik hari ini ────────────────────────────────────────────────────
const omsetHari  = hari.reduce((s, t) => s + t.total, 0);
const cashHari   = hari.filter(t => t.metode_bayar !== "qris").reduce((s, t) => s + t.total, 0);
const qrisHari   = hari.filter(t => t.metode_bayar === "qris").reduce((s, t) => s + t.total, 0);
const itemHari   = hari.reduce((s, t) => s + (t.transaksi_item ?? []).reduce((q: number, i: any) => q + i.qty, 0), 0);

// ── Statistik 30 hari ─────────────────────────────────────────────────────
const omset30    = trx30.reduce((s, t) => s + t.total, 0);
const cash30     = trx30.filter(t => t.metode_bayar !== "qris").reduce((s, t) => s + t.total, 0);
const qris30     = trx30.filter(t => t.metode_bayar === "qris").reduce((s, t) => s + t.total, 0);
const cashCnt30  = trx30.filter(t => t.metode_bayar !== "qris").length;
const qrisCnt30  = trx30.filter(t => t.metode_bayar === "qris").length;

// ── Grafik 7 hari ─────────────────────────────────────────────────────────
type Day7 = { label: string; date: string; omset: number; trx: number };
const days7: Day7[] = [];
for (let i = 6; i >= 0; i--) {
  const d   = new Date(todayStart); d.setDate(d.getDate() - i);
  const wib = new Date(d.getTime() + 7 * 60 * 60 * 1000);
  days7.push({
    label: `${pad2(wib.getDate())}/${pad2(wib.getMonth() + 1)}`,
    date:  `${wib.getFullYear()}-${pad2(wib.getMonth() + 1)}-${pad2(wib.getDate())}`,
    omset: 0,
    trx:   0,
  });
}
for (const t of trx7) {
  const w   = toWIB(t.created_at);
  const key = `${w.getFullYear()}-${pad2(w.getMonth() + 1)}-${pad2(w.getDate())}`;
  const day = days7.find(d => d.date === key);
  if (day) { day.omset += t.total; day.trx++; }
}
const maxOmset7  = Math.max(...days7.map(d => d.omset), 1);
const omsetWeek  = days7.reduce((s, d) => s + d.omset, 0);
const todayKey   = `${nowWIB.getFullYear()}-${pad2(nowWIB.getMonth() + 1)}-${pad2(nowWIB.getDate())}`;

const kemarinKey = (() => {
  const k = new Date(todayStart); k.setDate(k.getDate() - 1);
  const w = new Date(k.getTime() + 7 * 60 * 60 * 1000);
  return `${w.getFullYear()}-${pad2(w.getMonth() + 1)}-${pad2(w.getDate())}`;
})();
const omsetKemarin = days7.find(d => d.date === kemarinKey)?.omset ?? 0;
const vsKemarin    = omsetKemarin > 0
  ? Math.round(((omsetHari - omsetKemarin) / omsetKemarin) * 100)
  : null;

// ── Top Seller ────────────────────────────────────────────────────────────
const topMap = new Map<string, { nama: string; total: number }>();
(topItems ?? []).forEach(i => {
  const cur = topMap.get(i.produk_id ?? i.nama_produk) ?? { nama: i.nama_produk, total: 0 };
  cur.total += i.qty;
  topMap.set(i.produk_id ?? i.nama_produk, cur);
});
const topSellers = [...topMap.values()].sort((a, b) => b.total - a.total).slice(0, 5);

// ── Helpers ────────────────────────────────────────────────────────────────
function rp(n: number) {
  return new Intl.NumberFormat("id-ID", { style: "currency", currency: "IDR", minimumFractionDigits: 0 }).format(n);
}
function margin(beli: number, jual: number) {
  if (!beli) return 0;
  return Math.round(((jual - beli) / beli) * 100);
}
function timeStr(iso: string) {
  return toWIB(iso).toLocaleTimeString("id-ID", { hour: "2-digit", minute: "2-digit" });
}

const katColors: Record<string, string> = {
  Minuman: "kat-blue", Snack: "kat-yellow", Rokok: "kat-red",
  Sembako: "kat-green", Lainnya: "kat-gray",
};
const katBreakdown = ["Minuman","Snack","Rokok","Sembako","Lainnya"].map(kat => {
  const items = produk.filter((p: any) => p.kategori === kat);
  const avgM  = items.length
    ? Math.round(items.reduce((s: number, p: any) => s + margin(p.harga_beli, p.harga_jual), 0) / items.length)
    : 0;
  return { kat, count: items.length, avgM, colorKey: katColors[kat] ?? "kat-gray" };
});

const userEmail  = (Astro.locals as App.Locals).user?.email ?? "admin";
const hour       = new Date().getHours();
const salam      = hour < 11 ? "Selamat pagi" : hour < 15 ? "Selamat siang" : hour < 18 ? "Selamat sore" : "Selamat malam";
const tanggalStr = nowWIB.toLocaleDateString("id-ID", { weekday: "long", day: "numeric", month: "long", year: "numeric" });
---

<Layout title="Dashboard" active="dashboard" nonce={nonce}>

<!-- ── Modal Hapus Histori ────────────────────────────────────────────────── -->
<div id="modalHapus"
  style="display:none;position:fixed;inset:0;z-index:50;background:rgba(0,0,0,.45);backdrop-filter:blur(2px)"
  role="dialog" aria-modal="true" aria-labelledby="modalHapusTitle">

  <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
              background:#fff;border-radius:10px;width:min(440px,calc(100vw - 2rem));
              box-shadow:0 20px 60px rgba(0,0,0,.18);overflow:hidden">

    <!-- Header -->
    <div style="padding:1.25rem 1.5rem;border-bottom:1px solid rgba(15,13,11,.07);display:flex;align-items:center;gap:.75rem">
      <div style="width:32px;height:32px;border-radius:8px;background:#fef2f2;display:flex;align-items:center;justify-content:center;flex-shrink:0">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
          <path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
        </svg>
      </div>
      <div>
        <h3 id="modalHapusTitle" style="font-size:.9rem;font-weight:700;color:#0f0d0b;margin:0">Hapus Histori</h3>
        <p style="font-size:.68rem;color:#9ca3af;margin:1px 0 0">Data yang dihapus tidak dapat dipulihkan</p>
      </div>
      <button id="modalHapusClose" aria-label="Tutup"
        style="margin-left:auto;width:28px;height:28px;border:none;background:none;cursor:pointer;
               color:#9ca3af;display:flex;align-items:center;justify-content:center;border-radius:6px"
        onmouseenter="this.style.background='#f3f4f6';this.style.color='#374151'"
        onmouseleave="this.style.background='none';this.style.color='#9ca3af'">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    <!-- Body -->
    <div style="padding:1.375rem 1.5rem;display:flex;flex-direction:column;gap:1rem">

      <!-- Pilih tipe -->
      <div>
        <label style="font-size:.7rem;font-weight:600;color:#374151;display:block;margin-bottom:.5rem">Hapus data apa?</label>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:.5rem">
          <label id="lbl-transaksi" style="display:flex;align-items:center;gap:.5rem;padding:.6rem .75rem;border:1.5px solid #e5e7eb;border-radius:7px;cursor:pointer;transition:all .12s">
            <input type="radio" name="hapusType" value="transaksi" style="accent-color:#c84b1f" checked>
            <span style="font-size:.75rem;font-weight:600;color:#0f0d0b">Histori Transaksi</span>
          </label>
          <label id="lbl-harga_log" style="display:flex;align-items:center;gap:.5rem;padding:.6rem .75rem;border:1.5px solid #e5e7eb;border-radius:7px;cursor:pointer;transition:all .12s">
            <input type="radio" name="hapusType" value="harga_log" style="accent-color:#c84b1f">
            <span style="font-size:.75rem;font-weight:600;color:#0f0d0b">Log Perubahan Harga</span>
          </label>
        </div>
      </div>

      <!-- Pilih range -->
      <div>
        <label style="font-size:.7rem;font-weight:600;color:#374151;display:block;margin-bottom:.5rem">Rentang waktu</label>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:.5rem">
          {[
            { val: "hari_ini", label: "Hari Ini" },
            { val: "7_hari",   label: "7 Hari Terakhir" },
            { val: "30_hari",  label: "30 Hari Terakhir" },
            { val: "semua",    label: "Semua Waktu" },
          ].map(r => (
            <label style="display:flex;align-items:center;gap:.5rem;padding:.6rem .75rem;border:1.5px solid #e5e7eb;border-radius:7px;cursor:pointer;transition:all .12s"
              class="range-lbl">
              <input type="radio" name="hapusRange" value={r.val} style="accent-color:#c84b1f" checked={r.val === "hari_ini"}>
              <span style="font-size:.75rem;font-weight:500;color:#374151">{r.label}</span>
            </label>
          ))}
        </div>
      </div>

      <!-- Warning box -->
      <div id="hapusWarning" style="background:#fef2f2;border:1px solid #fecaca;border-radius:7px;padding:.75rem 1rem;display:flex;gap:.5rem;align-items:flex-start">
        <svg style="flex-shrink:0;margin-top:1px" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
          <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
        </svg>
        <p id="hapusWarningText" style="font-size:.7rem;color:#dc2626;margin:0;line-height:1.5">
          Histori transaksi hari ini akan dihapus permanen, termasuk seluruh item transaksi terkait.
        </p>
      </div>

    </div>

    <!-- Footer -->
    <div style="padding:1rem 1.5rem;border-top:1px solid rgba(15,13,11,.07);display:flex;gap:.625rem;justify-content:flex-end">
      <button id="hapusCancelBtn"
        style="padding:.5rem 1rem;font-size:.78rem;font-weight:600;border:1.5px solid #e5e7eb;
               background:#fff;color:#374151;border-radius:7px;cursor:pointer;transition:all .12s"
        onmouseenter="this.style.background='#f9fafb'"
        onmouseleave="this.style.background='#fff'">
        Batal
      </button>
      <button id="hapusKonfirmasiBtn"
        style="padding:.5rem 1.25rem;font-size:.78rem;font-weight:700;border:none;
               background:#dc2626;color:#fff;border-radius:7px;cursor:pointer;
               display:flex;align-items:center;gap:.4rem;transition:background .12s"
        onmouseenter="this.style.background='#b91c1c'"
        onmouseleave="this.style.background='#dc2626'">
        <svg id="hapusSpinner" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="display:none" aria-hidden="true">
          <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
        </svg>
        <span id="hapusBtnLabel">Hapus Sekarang</span>
      </button>
    </div>

  </div>
</div>

<!-- ── Toast Notifikasi ───────────────────────────────────────────────────── -->
<div id="toastNotif"
  style="position:fixed;bottom:1.5rem;right:1.5rem;z-index:100;display:none;
         padding:.75rem 1.125rem;border-radius:8px;font-size:.78rem;font-weight:600;
         box-shadow:0 8px 24px rgba(0,0,0,.15);display:flex;align-items:center;gap:.5rem;
         transition:opacity .2s;opacity:0;pointer-events:none"
  role="status" aria-live="polite">
  <span id="toastIcon"></span>
  <span id="toastText"></span>
</div>

<!-- ── Sticky Header ────────────────────────────────────────────────────────── -->
<div class="bg-white border-b border-black/[0.07] px-4 sm:px-6 lg:px-8 py-4
            flex items-center justify-between sticky top-0 z-20 fade-up">
  <div class="flex items-center gap-3">
    <button onclick="window.openSidebar&&window.openSidebar()"
      class="lg:hidden w-8 h-8 flex items-center justify-center rounded text-gray-500
             hover:text-gray-800 hover:bg-gray-100 transition-colors"
      aria-label="Buka menu">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
    <div>
      <h1 style="font-family:'DM Serif Display',serif" class="text-[1.2rem] leading-tight text-[#0f0d0b]">Dashboard</h1>
      <p class="text-[.7rem] text-gray-400 hidden sm:block">
        {salam}, <span class="font-medium text-gray-600">{userEmail.split("@")[0]}</span>
        <span class="text-gray-300 mx-1">·</span>
        <span>{tanggalStr}</span>
      </p>
    </div>
  </div>
  <div class="flex items-center gap-2">
    <!-- Tombol Hapus Histori -->
    <button id="btnHapusHistori"
      class="flex items-center gap-1.5 px-3.5 py-2 border border-red-200 hover:border-red-400
             text-red-500 hover:text-red-700 hover:bg-red-50 text-[.78rem] font-semibold
             rounded transition-colors"
      aria-label="Hapus histori data">
      <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
        <path d="M10 11v6"/><path d="M14 11v6"/>
      </svg>
      <span class="hidden sm:inline">Hapus Histori</span>
    </button>
    <a href="/dashboard/produk?modal=tambah"
      class="flex items-center gap-1.5 px-3.5 py-2 bg-[#0f0d0b] hover:bg-[#c84b1f]
             text-white text-[.78rem] font-semibold rounded transition-colors">
      <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
      <span class="hidden sm:inline">Tambah Produk</span>
      <span class="sm:hidden">Tambah</span>
    </a>
  </div>
</div>

<!-- ── Konten ────────────────────────────────────────────────────────────────── -->
<div class="page-pad p-5 lg:p-7 space-y-5 max-w-[1400px] mx-auto">

  <!-- ①  HARI INI -->
  <div class="fade-up d1">
    <p class="text-[.65rem] font-semibold text-gray-400 uppercase tracking-widest mb-2.5">Hari Ini</p>
    <div class="today-grid grid grid-cols-4 gap-3">
      <div class="today-card dark">
        <p style="font-size:.62rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;opacity:.45;margin-bottom:5px">Omset</p>
        <p style="font-size:1.45rem;font-weight:800;line-height:1.1">{rp(omsetHari)}</p>
        <div style="display:flex;align-items:center;gap:6px;margin-top:5px">
          <span style="font-size:.65rem;opacity:.55">{hari.length} transaksi · {itemHari} item</span>
          {vsKemarin !== null && (
            <span style={`font-size:.6rem;font-weight:700;padding:1px 5px;border-radius:99px;${vsKemarin >= 0 ? 'background:rgba(34,197,94,.2);color:#4ade80' : 'background:rgba(248,113,113,.2);color:#f87171'}`}>
              {vsKemarin >= 0 ? "+" : ""}{vsKemarin}%
            </span>
          )}
        </div>
      </div>
      <div class="today-card green">
        <p style="font-size:.62rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:#15803d;margin-bottom:5px">Cash / Manual</p>
        <p style="font-size:1.35rem;font-weight:800;color:#14532d;line-height:1.1">{rp(cashHari)}</p>
        <p style="font-size:.65rem;color:#16a34a;margin-top:5px">{hari.filter(t=>t.metode_bayar!=="qris").length} transaksi</p>
      </div>
      <div class="today-card blue">
        <p style="font-size:.62rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:#1d4ed8;margin-bottom:5px">QRIS · Duitku</p>
        <p style="font-size:1.35rem;font-weight:800;color:#1e3a8a;line-height:1.1">{rp(qrisHari)}</p>
        <p style="font-size:.65rem;color:#2563eb;margin-top:5px">{hari.filter(t=>t.metode_bayar==="qris").length} transaksi</p>
      </div>
      <div class="today-card amber">
        <p style="font-size:.62rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:#b45309;margin-bottom:5px">Item Terjual</p>
        <p style="font-size:1.35rem;font-weight:800;color:#78350f;line-height:1.1">{itemHari}</p>
        <p style="font-size:.65rem;color:#d97706;margin-top:5px">
          {hari.length > 0 ? `~${(itemHari / hari.length).toFixed(1)} item/trx` : "belum ada transaksi"}
        </p>
      </div>
    </div>
  </div>

  <!-- ② TREN 7 HARI + TRANSAKSI TERBARU -->
  <div class="trx-chart-grid grid grid-cols-5 gap-4 fade-up d2">
    <div class="col-span-3 section-card">
      <div class="section-head">
        <div>
          <h2>Tren Omset 7 Hari</h2>
          <p>Total minggu ini: <strong style="color:#0f0d0b">{rp(omsetWeek)}</strong></p>
        </div>
        <a href="/dashboard/analisis"
          class="text-[.72rem] font-semibold text-[#c84b1f] hover:underline whitespace-nowrap flex-shrink-0">
          Analisis lengkap →
        </a>
      </div>
      <div style="padding:1.125rem 1.375rem .875rem">
        <div class="mini-chart">
          {days7.map(d => {
            const pct     = (d.omset / maxOmset7) * 100;
            const isToday = d.date === todayKey;
            return (
              <div class={`mc-col${isToday ? " today" : ""}`} data-lbl={d.label}>
                <div class="mc-tip">{rp(d.omset)}<br/>{d.trx} trx</div>
                <div class="mc-bar"
                  style={`height:${pct > 0 ? Math.max(pct, 4) : 0}%;background:${isToday ? "#c84b1f" : "#f3d5cc"}`}>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </div>
    <div class="col-span-2 section-card" style="display:flex;flex-direction:column">
      <div class="section-head">
        <div>
          <h2>Transaksi Terbaru</h2>
          <p>Hari ini · {hari.length} total</p>
        </div>
        {hari.length > 8 && (
          <span style="font-size:.62rem;color:#9ca3af;flex-shrink:0">+{hari.length - 8} lainnya</span>
        )}
      </div>
      {hari.length === 0
