---
export const prerender = false;
import AuthLayout from "../layouts/AuthLayout.astro";
import "../styles/global.css";
import "../styles/login.css";

const nonce = (Astro.locals as Record<string, unknown>).nonce as string ?? "";

if (import.meta.env.PROD && Astro.request.headers.get("x-forwarded-proto") === "http") {
  return Astro.redirect(`https://${Astro.url.host}${Astro.url.pathname}`, 301);
}

const accessToken  = Astro.cookies.get("sb-access-token");
const refreshToken = Astro.cookies.get("sb-refresh-token");
if (accessToken?.value && refreshToken?.value) {
  return Astro.redirect("/dashboard");
}

const error = Astro.url.searchParams.get("error");

const ALLOWED_ERRORS = new Set([
  "invalid_credentials",
  "too_many_requests",
  "turnstile_failed",
  "unauthorized",
  "session_expired",
  "server_error",
]);

const errorMessages: Record<string, string> = {
  invalid_credentials: "Email atau password tidak sesuai.",
  too_many_requests:   "Terlalu banyak percobaan. Coba lagi dalam 15 menit.",
  turnstile_failed:    "Verifikasi keamanan gagal. Silakan coba lagi.",
  unauthorized:        "Akses ditolak. Akun ini tidak memiliki izin admin.",
  session_expired:     "Sesi Anda telah berakhir. Silakan masuk kembali.",
  server_error:        "Terjadi kesalahan server. Coba beberapa saat lagi.",
};

const safeError = error && ALLOWED_ERRORS.has(error) ? error : null;
const errorMsg  = safeError ? errorMessages[safeError] : null;

const siteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
---

<AuthLayout title="Masuk" nonce={nonce}>

  <script
    slot="head"
    nonce={nonce}
    src="https://challenges.cloudflare.com/turnstile/v0/api.js"
    async
    defer
  ></script>

  <style>

  </style>

  <div class="card" role="main">

    <div class="card-accent"></div>

    <div class="card-body">

      <!-- Header -->
      <div class="header">
        <div class="header-logo" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white"
               stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
            <line x1="3" y1="6" x2="21" y2="6"/>
            <path d="M16 10a4 4 0 0 1-8 0"/>
          </svg>
        </div>
        <h1 class="header-title">Selamat datang</h1>
        <p class="header-sub">Masuk ke Dasbor Admin Kasir Warung</p>
        <p class="header-date" id="headerDate" aria-hidden="true"></p>
      </div>

      <!-- Error alert (server-side) -->
      {errorMsg && (
        <div class="error-alert" role="alert" aria-live="assertive" aria-atomic="true">
          <svg aria-hidden="true" width="15" height="15" viewBox="0 0 24 24"
               fill="none" stroke="currentColor" stroke-width="2.5"
               stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <line x1="12" y1="8" x2="12" y2="12"/>
            <line x1="12" y1="16" x2="12.01" y2="16"/>
          </svg>
          <span>{errorMsg}</span>
        </div>
      )}

      <!-- Form -->
      <form id="loginForm" action="/api/auth/login" method="POST"
            novalidate autocomplete="on" aria-label="Form masuk">
        <div class="field-group">

          <!-- Email -->
          <div class="field">
            <label for="email" class="field-label">Email</label>
            <div class="input-wrap">
              <input
                id="email"
                type="email"
                name="email"
                required
                autocomplete="email"
                inputmode="email"
                placeholder="admin@warung.com"
                maxlength="254"
                aria-required="true"
                aria-describedby="email-error"
                class="field-input"
              />
              <!-- leading icon — di bawah input agar z-index tidak masalah -->
              <span class="input-icon-lead" aria-hidden="true">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="4" width="20" height="16" rx="2"/>
                  <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                </svg>
              </span>
            </div>
            <span id="email-error" class="field-error" role="alert" aria-live="polite"></span>
          </div>

          <!-- Password -->
          <div class="field">
            <label for="password" class="field-label">Password</label>
            <div class="input-wrap">
              <input
                id="password"
                type="password"
                name="password"
                required
                autocomplete="current-password"
                placeholder="••••••••"
                maxlength="128"
                minlength="8"
                aria-required="true"
                aria-describedby="password-error"
                class="field-input has-toggle"
              />
              <!-- leading icon -->
              <span class="input-icon-lead" aria-hidden="true">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="11" width="18" height="11" rx="2"/>
                  <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
              </span>
              <!-- toggle button -->
              <button
                type="button"
                id="pwToggle"
                class="pw-toggle"
                aria-label="Tampilkan password"
                aria-controls="password"
                aria-pressed="false"
                tabindex="0"
              >
                <!-- Eye OPEN — ditampilkan saat password tersembunyi -->
                <svg id="iconEyeOpen" width="16" height="16" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round">
                  <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/>
                  <circle cx="12" cy="12" r="3"/>
                </svg>
                <!-- Eye CLOSED / slash — ditampilkan saat password terlihat -->
                <svg id="iconEyeClosed" width="16" height="16" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round"
                     style="display:none">
                  <path d="M9.88 9.88a3 3 0 1 0 4.24 4.24"/>
                  <path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68"/>
                  <path d="M6.61 6.61A13.526 13.526 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61"/>
                  <line x1="2" y1="2" x2="22" y2="22"/>
                </svg>
              </button>
            </div>
            <span id="password-error" class="field-error" role="alert" aria-live="polite"></span>
          </div>

          <!-- Turnstile -->
          <div class="turnstile-wrap">
            <div
              class="cf-turnstile"
              data-sitekey={siteKey}
              data-theme="light"
              data-size="normal"
              data-callback="onTurnstileSuccess"
              data-error-callback="onTurnstileError"
              data-expired-callback="onTurnstileExpired"
            ></div>
          </div>

          <!-- Submit -->
          <button type="submit" id="submitBtn" class="submit-btn" aria-busy="false">
            <span class="btn-content">
              <svg aria-hidden="true" width="15" height="15" viewBox="0 0 24 24"
                   fill="none" stroke="currentColor" stroke-width="2.25"
                   stroke-linecap="round" stroke-linejoin="round">
                <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
                <polyline points="10 17 15 12 10 7"/>
                <line x1="15" y1="12" x2="3" y2="12"/>
              </svg>
              Masuk ke Kasir
            </span>
            <span class="btn-spinner" aria-hidden="true"></span>
          </button>

        </div>
      </form>

    </div><!-- /card-body -->

    <!-- Footer -->
    <div class="card-footer">
      <svg aria-hidden="true" width="12" height="12" viewBox="0 0 24 24"
           fill="none" stroke="var(--muted)" stroke-width="2"
           stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
      </svg>
      <span class="footer-text">Akses terenkripsi SSL</span>
      <div class="admin-badge" aria-label="Khusus admin">
        <div class="badge-dot" aria-hidden="true"></div>
        <span class="badge-label">Admin Only</span>
      </div>
    </div>

  </div><!-- /card -->

  <script nonce={nonce} is:inline>
  (function () {
    "use strict";

    /* ── Tampilkan tanggal ─────────────────────────────── */
    var dateEl = document.getElementById("headerDate");
    if (dateEl) {
      dateEl.textContent = new Date().toLocaleDateString("id-ID", {
        weekday: "long", day: "numeric", month: "long", year: "numeric"
      });
    }

    /* ── Toggle password ───────────────────────────────── */
    var pwToggle    = document.getElementById("pwToggle");
    var pwInput     = document.getElementById("password");
    var iconOpen    = document.getElementById("iconEyeOpen");
    var iconClosed  = document.getElementById("iconEyeClosed");

    if (pwToggle && pwInput && iconOpen && iconClosed) {
      pwToggle.addEventListener("click", function () {
        // Cek tipe input SEBELUM diubah
        var isCurrentlyPassword = (pwInput.getAttribute("type") === "password");

        if (isCurrentlyPassword) {
          // Tampilkan teks password
          pwInput.setAttribute("type", "text");
          iconOpen.style.display   = "none";
          iconClosed.style.display = "";
          pwToggle.setAttribute("aria-label",   "Sembunyikan password");
          pwToggle.setAttribute("aria-pressed", "true");
        } else {
          // Sembunyikan password
          pwInput.setAttribute("type", "password");
          iconOpen.style.display   = "";
          iconClosed.style.display = "none";
          pwToggle.setAttribute("aria-label",   "Tampilkan password");
          pwToggle.setAttribute("aria-pressed", "false");
        }

        // Kembalikan fokus ke input agar UX mulus
        pwInput.focus();
      });
    }

    /* ── State Turnstile ───────────────────────────────── */
    var tsReady = false;
    window.onTurnstileSuccess = function () { tsReady = true; };
    window.onTurnstileError   = function () { tsReady = false; };
    window.onTurnstileExpired = function () { tsReady = false; };

    /* ── Helpers validasi ──────────────────────────────── */
    function isValidEmail(val) {
      return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(val);
    }

    function setFieldError(inputId, errorId, msg) {
      var inp = document.getElementById(inputId);
      var err = document.getElementById(errorId);
      if (!inp || !err) return;
      if (msg) {
        inp.classList.add("is-invalid");
        inp.setAttribute("aria-invalid", "true");
        err.textContent = msg;
        err.classList.add("show");
      } else {
        inp.classList.remove("is-invalid");
        inp.setAttribute("aria-invalid", "false");
        err.textContent = "";
        err.classList.remove("show");
      }
    }

    /* Bersihkan error saat mengetik */
    ["email", "password"].forEach(function (id) {
      var el = document.getElementById(id);
      if (el) {
        el.addEventListener("input", function () {
          setFieldError(id, id + "-error", "");
        });
      }
    });

    /* ── Submit ────────────────────────────────────────── */
    var form      = document.getElementById("loginForm");
    var submitBtn = document.getElementById("submitBtn");

    if (form && submitBtn) {
      form.addEventListener("submit", function (e) {
        e.preventDefault();

        var emailVal    = document.getElementById("email").value.trim();
        var passwordVal = document.getElementById("password").value;
        var tsRes       = document.querySelector('[name="cf-turnstile-response"]');
        var valid       = true;

        if (!emailVal) {
          setFieldError("email", "email-error", "Email wajib diisi.");
          valid = false;
        } else if (!isValidEmail(emailVal)) {
          setFieldError("email", "email-error", "Format email tidak valid.");
          valid = false;
        } else {
          setFieldError("email", "email-error", "");
        }

        if (!passwordVal) {
          setFieldError("password", "password-error", "Password wajib diisi.");
          valid = false;
        } else if (passwordVal.length < 8) {
          setFieldError("password", "password-error", "Password minimal 8 karakter.");
          valid = false;
        } else {
          setFieldError("password", "password-error", "");
        }

        if (!tsRes || !tsRes.value) {
          valid = false;
          var existing = form.querySelector(".turnstile-err");
          if (!existing) {
            var alertBox = document.createElement("div");
            alertBox.setAttribute("role", "alert");
            alertBox.setAttribute("aria-live", "assertive");
            alertBox.className = "error-alert turnstile-err";
            alertBox.style.marginTop = "0.5rem";
            alertBox.innerHTML =
              '<svg aria-hidden="true" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>' +
              '<span>Selesaikan verifikasi keamanan terlebih dahulu.</span>';
            form.appendChild(alertBox);
            setTimeout(function () { alertBox.remove(); }, 5000);
          }
        }

        if (!valid) return;

        submitBtn.disabled = true;
        submitBtn.classList.add("btn-loading");
        submitBtn.setAttribute("aria-busy", "true");
        form.submit();
      });
    }
  })();
  </script>

</AuthLayout>
