---
// src/pages/403.astro
import Layoutc from "../layouts/Layoutc.astro";
---

<Layoutc title="403 — Akses Ditolak">
  <div class="err-wrap">

    <!-- Lock pattern background -->
    <div class="err-bg-pattern" aria-hidden="true">
      {Array.from({length: 12}).map((_, i) => (
        <svg class="bg-lock" style={`--d:${i * 0.4}s`} viewBox="0 0 24 24" fill="none">
          <rect x="3" y="11" width="18" height="11" rx="2" stroke="currentColor" stroke-width="1.5"/>
          <path d="M7 11V7a5 5 0 0 1 10 0v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      ))}
    </div>

    <div class="err-content">

      <!-- Icon -->
      <div class="err-icon-wrap">
        <div class="err-icon-ring ring-3" aria-hidden="true"></div>
        <div class="err-icon-ring ring-2" aria-hidden="true"></div>
        <div class="err-icon-ring ring-1" aria-hidden="true"></div>
        <div class="err-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="11" width="18" height="11" rx="2"/>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            <circle cx="12" cy="16" r="1" fill="currentColor"/>
          </svg>
        </div>
      </div>

      <!-- Code -->
      <div class="err-number">403</div>

      <!-- Card -->
      <div class="err-card">
        <div class="err-card-header">
          <div class="err-status-dot"></div>
          <span>Akses Ditolak</span>
          <span class="err-card-code">FORBIDDEN</span>
        </div>
        <p class="err-card-msg">
          Kamu tidak punya izin untuk mengakses halaman ini. Pastikan kamu sudah login dengan akun yang benar.
        </p>
        <div class="err-card-meta">
          <span>
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            {new Date().toLocaleString('id-ID', {dateStyle:'medium', timeStyle:'short'})}
          </span>
          <span>HTTP 403</span>
        </div>
      </div>

      <!-- Actions -->
      <div class="err-actions">
        <a href="/" class="err-btn primary">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
          Ke Halaman Login
        </a>
        <button onclick="history.back()" class="err-btn secondary">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6"/>
          </svg>
          Kembali
        </button>
      </div>

    </div>
  </div>
</Layoutc>

<style>
  .err-wrap {
    position: relative;
    min-height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1rem;
    overflow: hidden;
    background: var(--bg);
  }

  /* Floating lock icons background */
  .err-bg-pattern {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .bg-lock {
    position: absolute;
    width: 28px; height: 28px;
    color: var(--border);
    animation: floatLock 8s ease-in-out infinite;
    animation-delay: var(--d, 0s);
  }
  .bg-lock:nth-child(1)  { left: 5%;  top: 10%; }
  .bg-lock:nth-child(2)  { left: 15%; top: 70%; }
  .bg-lock:nth-child(3)  { left: 25%; top: 30%; }
  .bg-lock:nth-child(4)  { left: 35%; top: 85%; }
  .bg-lock:nth-child(5)  { left: 50%; top: 8%;  }
  .bg-lock:nth-child(6)  { left: 60%; top: 60%; }
  .bg-lock:nth-child(7)  { left: 70%; top: 20%; }
  .bg-lock:nth-child(8)  { left: 80%; top: 75%; }
  .bg-lock:nth-child(9)  { left: 88%; top: 40%; }
  .bg-lock:nth-child(10) { left: 92%; top: 15%; }
  .bg-lock:nth-child(11) { left: 42%; top: 50%; }
  .bg-lock:nth-child(12) { left: 8%;  top: 50%; }
  @keyframes floatLock {
    0%,100% { transform: translateY(0) rotate(-5deg); opacity: 0.5; }
    50%      { transform: translateY(-14px) rotate(5deg); opacity: 1; }
  }

  /* Content */
  .err-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    max-width: 380px;
    width: 100%;
    animation: slideUp 0.55s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  @keyframes slideUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Icon with rings */
  .err-icon-wrap {
    position: relative;
    width: 90px; height: 90px;
    display: flex; align-items: center; justify-content: center;
  }
  .err-icon-ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1.5px solid var(--accent);
    animation: ringPulse 2.5s ease-out infinite;
  }
  .ring-2 { animation-delay: 0.5s; }
  .ring-3 { animation-delay: 1s; }
  @keyframes ringPulse {
    0%   { transform: scale(0.7); opacity: 0.8; }
    100% { transform: scale(1.6); opacity: 0; }
  }
  .err-icon {
    width: 64px; height: 64px;
    background: var(--card);
    border: 2px solid var(--border);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: var(--accent);
    box-shadow: 0 4px 20px rgba(200,75,31,.15);
    position: relative;
    z-index: 1;
  }

  /* Big number */
  .err-number {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: clamp(3.5rem, 14vw, 5.5rem);
    color: var(--dark);
    line-height: 1;
    letter-spacing: -0.04em;
    animation: slideUp 0.55s 0.05s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  /* Card */
  .err-card {
    width: 100%;
    background: var(--card);
    border: 1.5px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(17,17,16,.07);
    animation: slideUp 0.55s 0.1s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .err-card-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 11px 16px;
    background: #fef2ee;
    border-bottom: 1.5px solid #fbd5c8;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--accent);
  }
  .err-status-dot {
    width: 7px; height: 7px;
    background: var(--accent);
    border-radius: 50%;
    animation: dotBlink 1.2s ease-in-out infinite;
    flex-shrink: 0;
  }
  @keyframes dotBlink {
    0%,100% { opacity: 1; }
    50%      { opacity: 0.3; }
  }
  .err-card-code {
    margin-left: auto;
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--muted);
    background: var(--bg);
    padding: 2px 7px;
    border-radius: 4px;
    border: 1px solid var(--border);
  }
  .err-card-msg {
    padding: 14px 16px;
    font-size: 0.77rem;
    color: var(--sub);
    line-height: 1.6;
    margin: 0;
    border-bottom: 1px solid var(--border);
  }
  .err-card-meta {
    padding: 8px 16px;
    display: flex;
    justify-content: space-between;
    font-size: 0.63rem;
    color: var(--muted);
  }
  .err-card-meta span {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  /* Actions */
  .err-actions {
    display: flex;
    flex-direction: column;
    gap: 8px;
    width: 100%;
    animation: slideUp 0.55s 0.18s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .err-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 11px 20px;
    border-radius: 8px;
    font-size: 0.8rem;
    font-weight: 700;
    font-family: 'DM Sans', system-ui, sans-serif;
    cursor: pointer;
    text-decoration: none;
    border: none;
    transition: all 0.15s;
  }
  .err-btn.primary  { background: var(--dark); color: #fff; }
  .err-btn.primary:hover { background: var(--accent); }
  .err-btn.secondary {
    background: transparent;
    color: var(--dark);
    border: 2px solid var(--border);
  }
  .err-btn.secondary:hover { border-color: var(--accent); color: var(--accent); }
</style>
