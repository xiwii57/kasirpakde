---
import "../styles/global.css";

interface Props {
  title: string;
  nonce?: string;
}
const { title, nonce = "" } = Astro.props;
---
<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="referrer" content="no-referrer" />
  <title>{title} — Kasir Warung</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&display=swap" rel="stylesheet" />
  <slot name="head" />
</head>
<body style="font-family:'DM Sans',sans-serif" class="min-h-screen bg-[#f5f0e8]">
  <slot />
</body>
</html>
