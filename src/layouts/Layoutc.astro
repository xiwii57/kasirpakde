---
// src/layouts/Layoutc.astro
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title:   string;
  active?: string;   // untuk highlight nav di halaman lain (opsional, disimpan di <body> data attr)
  nonce?:  string;   // CSP nonce dari middleware
}

const { title, active = "", nonce = "" } = Astro.props;

const pageTitle = title ? `${title} — Karsip` : "Karsip";
---

<!doctype html>
<html lang="id" data-active={active}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="theme-color" content="#f5f1ec" />
  <meta name="color-scheme" content="light" />

  <meta name="robots" content="noindex, nofollow" />
  <title>{pageTitle}</title>

  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' rx='8' fill='%23c84b1f'/><text x='50%' y='56%' dominant-baseline='middle' text-anchor='middle' font-size='20' font-family='Georgia,serif' fill='white'>K</text></svg>" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;0,9..40,800;1,9..40,400&family=DM+Serif+Display:ital@0;1&display=swap"
  />

  <ViewTransitions nonce={nonce} />

  <style is:inline nonce={nonce}>
    /* ── Reset ───────────────────────────────── */
    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    /* ── Design tokens ───────────────────────── */
    :root {
      /* Brand */
      --accent:        #c84b1f;
      --accent-light:  rgba(200, 75, 31, 0.10);
      --accent-hover:  #b04118;

      /* Neutrals */
      --dark:          #111110;
      --bg:            #f5f1ec;
      --card:          #ffffff;
      --border:        #e5e0da;
      --text:          #111110;
      --sub:           #6b6560;
      --muted:         #9e9890;

      /* Typography */
      --sans:          'DM Sans', system-ui, -apple-system, sans-serif;
      --serif:         'DM Serif Display', Georgia, 'Times New Roman', serif;

      /* Spacing */
      --radius:        9px;
      --radius-sm:     6px;
      --radius-lg:     14px;

      /* Layout */
      --sidebar-w:     220px;
      --hdr:           52px;
    }

    /* ── Base ────────────────────────────────── */
    html {
      font-family:        var(--sans);
      font-size:          16px;
      line-height:        1.5;
      color:              var(--text);
      background-color:   var(--bg);
      -webkit-font-smoothing:  antialiased;
      -moz-osx-font-smoothing: grayscale;
      text-rendering:      optimizeLegibility;
      /* Full height tanpa overflow untuk layout POS */
      height: 100%;
      overflow: hidden;
    }

    body {
      height:   100%;
      overflow: hidden;
      display:  flex;
      flex-direction: column;
    }

    /* Slot utama mengisi sisa ruang */
    #app-root {
      flex:       1;
      min-height: 0;
      display:    flex;
      flex-direction: column;
      overflow:   hidden;
    }

    /* ── Typography helpers ───────────────────── */
    h1, h2, h3, h4 {
      font-family:    var(--serif);
      font-weight:    400;
      line-height:    1.2;
      color:          var(--dark);
      letter-spacing: -0.01em;
    }

    p { color: var(--sub); }

    a {
      color:           var(--accent);
      text-decoration: none;
    }
    a:hover { text-decoration: underline; }

    button, input, select, textarea {
      font-family: var(--sans);
    }

    img, svg { display: block; }

    /* ── Scrollbar global ─────────────────────── */
    ::-webkit-scrollbar          { width: 3px; height: 3px; }
    ::-webkit-scrollbar-track    { background: transparent; }
    ::-webkit-scrollbar-thumb    { background: #d5cec6; border-radius: 2px; }
    ::-webkit-scrollbar-thumb:hover { background: #bfb8b0; }
    * { scrollbar-width: thin; scrollbar-color: #d5cec6 transparent; }

    /* ── Focus visible ────────────────────────── */
    :focus-visible {
      outline:        2px solid var(--accent);
      outline-offset: 2px;
      border-radius:  3px;
    }

    /* ── Selection ────────────────────────────── */
    ::selection {
      background: var(--accent-light);
      color:      var(--dark);
    }

    /* ── Utility ──────────────────────────────── */
    .sr-only {
      position:   absolute;
      width:      1px;
      height:     1px;
      padding:    0;
      margin:     -1px;
      overflow:   hidden;
      clip:       rect(0, 0, 0, 0);
      white-space: nowrap;
      border:     0;
    }

    /* ── Reduced motion ───────────────────────── */
    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration:   0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration:  0.01ms !important;
        scroll-behavior:      auto !important;
      }
    }

    /* ── Page transition (fade in) ────────────── */
    @keyframes pageFadeIn {
      from { opacity: 0; }
      to   { opacity: 1; }
    }
    #app-root {
      animation: pageFadeIn 0.18s ease both;
    }
  </style>
</head>

<body>
  <div id="app-root">
    <slot />
  </div>
</body>
</html>
