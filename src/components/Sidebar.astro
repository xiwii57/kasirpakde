---
// src/components/Sidebar.astro
interface Props {
  active: "dashboard" | "produk" | "margin-rendah" | "analisis" | "kasir" | "piutang";
  nonce?: string;
}

const { active, nonce = "" } = Astro.props;

const userEmail = ((Astro.locals as any).user?.email ?? "") as string;
const shortName = userEmail ? userEmail.split("@")[0] : "";

const navItems = [
  {
    key: "dashboard",
    href: "/dashboard",
    label: "Dashboard",
    icon: `<rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>`,
  },
  {
    key: "produk",
    href: "/dashboard/produk",
    label: "Produk",
    icon: `<path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>`,
  },
  {
    key: "margin-rendah",
    href: "/dashboard/margin-rendah",
    label: "Margin Rendah",
    icon: `<path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>`,
  },
  {
    key: "analisis",
    href: "/dashboard/analisis",
    label: "Analisis",
    icon: `<line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>`,
  },
  {
    key: "piutang",
    href: "/dashboard/piutang",
    label: "Piutang",
    icon: `<path d="M12 2a10 10 0 1 0 0 20A10 10 0 0 0 12 2z"/><path d="M12 6v6l4 2"/>`,
  },
] as const;
---

<!-- ── Overlay ─────────────────────────────────────────────────────────────── -->
<div
  id="sidebar-overlay"
  class="sidebar-overlay"
  aria-hidden="true"
></div>

<!-- ── Sidebar ─────────────────────────────────────────────────────────────── -->
<aside
  id="sidebar"
  class="sidebar"
  aria-label="Navigasi utama"
>

  <!-- ── Logo ── -->
  <div class="sidebar-logo-bar">
    <a href="/dashboard" class="sidebar-logo-link" aria-label="Kasir Warung — Beranda">
      <div class="sidebar-logo-icon" aria-hidden="true">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
      </div>
      <div class="sidebar-logo-text">
        <div class="sidebar-logo-name">Kasir Warung</div>
        <div class="sidebar-logo-sub">Admin Portal</div>
      </div>
    </a>

    <!-- Tombol tutup mobile -->
    <button
      id="close-sidebar"
      class="sidebar-close-btn"
      aria-label="Tutup menu"
    >
      <svg width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>

  <!-- ── Nav ── -->
  <nav class="sidebar-nav" aria-label="Menu halaman">

    <p class="sidebar-section-label">Menu</p>

    <div class="sidebar-nav-list">
      {navItems.map(item => (
        <a
          href={item.href}
          class={`sidebar-nav-link ${active === item.key ? "is-active" : ""}`}
          aria-current={active === item.key ? "page" : undefined}
        >
          <svg
            width="14" height="14"
            viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
            class="sidebar-nav-icon"
            aria-hidden="true"
            set:html={item.icon}
          />
          <span class="sidebar-nav-label">{item.label}</span>
        </a>
      ))}
    </div>

    <!-- Divider + Sistem -->
    <div class="sidebar-divider-section" aria-hidden="true">
      <div class="sidebar-divider-line"></div>
      <p class="sidebar-section-label">Sistem</p>
    </div>

    <a
      href="/dashboard/kasir"
      class={`sidebar-nav-link ${active === "kasir" ? "is-active" : ""}`}
      aria-current={active === "kasir" ? "page" : undefined}
    >
      <svg
        width="14" height="14"
        viewBox="0 0 24 24" fill="none" stroke="currentColor"
        stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
        class="sidebar-nav-icon"
        aria-hidden="true"
      >
        <rect x="2" y="3" width="20" height="14" rx="2"/>
        <line x1="8" y1="21" x2="16" y2="21"/>
        <line x1="12" y1="17" x2="12" y2="21"/>
      </svg>
      <span class="sidebar-nav-label">Halaman Kasir</span>
    </a>

  </nav>

  <!-- ── User + Logout ── -->
  <div class="sidebar-footer">
    {userEmail && (
      <div class="sidebar-user-card">
        <div class="sidebar-user-row">
          <div class="sidebar-user-avatar">
            <span class="sidebar-user-initial">
              {shortName.charAt(0)}
            </span>
          </div>
          <div class="sidebar-user-info">
            <p class="sidebar-user-name">{shortName}</p>
            <p class="sidebar-user-email">{userEmail}</p>
          </div>
        </div>
      </div>
    )}

    <form action="/dashboard/api/auth/logout" method="POST">
      <button
        type="submit"
        class="sidebar-logout-btn"
        aria-label="Keluar dari akun"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="sidebar-logout-icon">
          <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
          <polyline points="16 17 21 12 16 7"/>
          <line x1="21" y1="12" x2="9" y2="12"/>
        </svg>
        Keluar
      </button>
    </form>
  </div>

</aside>

<style>
  /* ── Overlay ──────────────────────────────────────────────────── */
  .sidebar-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    z-index: 40;
    display: none;
    opacity: 0;
    transition: opacity 220ms ease;
    backdrop-filter: blur(3px);
  }
  .sidebar-overlay.hidden { display: none !important; }

  /* ── Sidebar container ────────────────────────────────────────── */
  .sidebar {
    width: 220px;
    background: #141210;
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
    height: 100dvh;
    overflow-y: auto;
    position: fixed;
    top: 0;
    left: 0;
    z-index: 50;
    transform: translateX(-100%);
    transition: transform 240ms cubic-bezier(0.4, 0, 0.2, 1);
    border-right: 1px solid rgba(255, 255, 255, 0.055);
    box-shadow: 4px 0 24px rgba(0, 0, 0, 0.4);
  }

  /* ── Logo bar ─────────────────────────────────────────────────── */
  .sidebar-logo-bar {
    padding: 1.125rem 1.25rem 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-shrink: 0;
  }

  .sidebar-logo-link {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    min-width: 0;
    text-decoration: none;
  }

  .sidebar-logo-icon {
    width: 30px;
    height: 30px;
    background: linear-gradient(135deg, #c84b1f 0%, #a83818 100%);
    border-radius: 8px;
    display: grid;
    place-items: center;
    flex-shrink: 0;
    box-shadow: 0 2px 8px rgba(200, 75, 31, 0.35);
  }

  .sidebar-logo-text { min-width: 0; }

  .sidebar-logo-name {
    color: #fff;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.1;
    font-family: 'DM Sans', sans-serif;
  }

  .sidebar-logo-sub {
    font-size: 0.6rem;
    color: rgba(255, 255, 255, 0.28);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-top: 2px;
    font-family: 'DM Mono', monospace;
  }

  /* ── Tombol tutup (mobile only) ───────────────────────────────── */
  .sidebar-close-btn {
    display: none;
    width: 28px;
    height: 28px;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.35);
    background: none;
    border: none;
    border-radius: 5px;
    cursor: pointer;
    transition: color 0.15s, background 0.15s;
    flex-shrink: 0;
  }
  .sidebar-close-btn:hover {
    color: rgba(255, 255, 255, 0.8);
    background: rgba(255, 255, 255, 0.07);
  }

  /* ── Nav ──────────────────────────────────────────────────────── */
  .sidebar-nav {
    flex: 1;
    padding: 0.875rem 0.75rem;
    overflow-y: auto;
  }

  .sidebar-section-label {
    padding: 0 0.625rem 0.5rem;
    font-size: 0.6rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.2);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-family: 'DM Mono', monospace;
    margin: 0;
  }

  .sidebar-nav-list {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  /* ── Nav link ─────────────────────────────────────────────────── */
  .sidebar-nav-link {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.5rem 0.625rem;
    border-radius: 6px;
    font-size: 0.8125rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.15s ease;
    letter-spacing: -0.01em;
    color: rgba(255, 255, 255, 0.4);
    background: transparent;
    box-shadow: none;
    position: relative;
  }
  .sidebar-nav-link:hover:not(.is-active) {
    color: rgba(255, 255, 255, 0.8);
    background: rgba(255, 255, 255, 0.05);
  }
  .sidebar-nav-link:hover:not(.is-active) .sidebar-nav-icon {
    color: rgba(255, 255, 255, 0.55);
  }

  /* State aktif */
  .sidebar-nav-link.is-active {
    color: #ffffff;
    background: rgba(200, 75, 31, 0.14);
    box-shadow: inset 2.5px 0 0 #c84b1f;
  }

  /* Dot indicator */
  .sidebar-nav-link.is-active::after {
    content: '';
    display: block;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #c84b1f;
    flex-shrink: 0;
    margin-left: auto;
  }

  /* ── Nav icon ─────────────────────────────────────────────────── */
  .sidebar-nav-icon {
    flex-shrink: 0;
    color: rgba(255, 255, 255, 0.28);
    transition: color 0.15s;
  }
  .sidebar-nav-link.is-active .sidebar-nav-icon {
    color: #c84b1f;
  }

  /* ── Nav label ────────────────────────────────────────────────── */
  .sidebar-nav-label {
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* ── Divider section ──────────────────────────────────────────── */
  .sidebar-divider-section {
    padding: 1rem 0.625rem 0.5rem;
  }

  .sidebar-divider-line {
    height: 1px;
    background: rgba(255, 255, 255, 0.06);
    margin-bottom: 0.75rem;
  }

  /* ── Footer (user + logout) ───────────────────────────────────── */
  .sidebar-footer {
    padding: 0.75rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    flex-shrink: 0;
  }

  .sidebar-user-card {
    padding: 0.5rem 0.625rem;
    margin-bottom: 0.375rem;
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  .sidebar-user-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .sidebar-user-avatar {
    width: 24px;
    height: 24px;
    border-radius: 5px;
    background: rgba(200, 75, 31, 0.2);
    border: 1px solid rgba(200, 75, 31, 0.3);
    display: grid;
    place-items: center;
    flex-shrink: 0;
  }

  .sidebar-user-initial {
    font-size: 0.6rem;
    font-weight: 700;
    color: #c84b1f;
    text-transform: uppercase;
  }

  .sidebar-user-info {
    min-width: 0;
    flex: 1;
  }

  .sidebar-user-name {
    font-size: 0.7rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.6);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    margin: 0;
  }

  .sidebar-user-email {
    font-size: 0.6rem;
    color: rgba(255, 255, 255, 0.22);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    margin: 0;
  }

  /* ── Logout button ────────────────────────────────────────────── */
  .sidebar-logout-btn {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.5rem 0.625rem;
    border-radius: 6px;
    font-size: 0.8rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.3);
    background: none;
    border: none;
    cursor: pointer;
    transition: color 0.15s, background 0.15s;
    text-align: left;
    letter-spacing: -0.01em;
    font-family: 'DM Sans', sans-serif;
  }
  .sidebar-logout-btn:hover {
    color: #f87171;
    background: rgba(239, 68, 68, 0.08);
  }

  .sidebar-logout-icon {
    flex-shrink: 0;
    color: rgba(255, 255, 255, 0.2);
    transition: color 0.15s;
  }
  .sidebar-logout-btn:hover .sidebar-logout-icon {
    color: #f87171;
  }

  /* ── Responsive ───────────────────────────────────────────────── */
  @media (min-width: 1024px) {
    .sidebar {
      transform: translateX(0) !important;
      position: sticky !important;
      box-shadow: none !important;
    }
    #sidebar-overlay    { display: none !important; }
    .sidebar-close-btn  { display: none !important; }
  }

  @media (max-width: 1023px) {
    .sidebar-close-btn { display: flex !important; }
  }
</style>

<script is:inline nonce={nonce}>
(function () {
  'use strict';

  // ── openSidebar / closeSidebar — global, cukup didefinisikan sekali
  window.openSidebar = function () {
    var sidebar = document.getElementById('sidebar');
    var overlay = document.getElementById('sidebar-overlay');
    if (!sidebar || !overlay) return;
    sidebar.style.transform = 'translateX(0)';
    overlay.classList.remove('hidden');
    requestAnimationFrame(function () { overlay.style.opacity = '1'; });
    document.body.style.overflow = 'hidden';
    var first = sidebar.querySelector('a[href]');
    if (first) setTimeout(function () { first.focus(); }, 250);
  };

  window.closeSidebar = function () {
    var sidebar = document.getElementById('sidebar');
    var overlay = document.getElementById('sidebar-overlay');
    if (!sidebar || !overlay) return;
    sidebar.style.transform = 'translateX(-100%)';
    overlay.style.opacity = '0';
    setTimeout(function () { overlay.classList.add('hidden'); }, 220);
    document.body.style.overflow = '';
  };

  // ── initSidebar — dipanggil sekali saat halaman load
  function initSidebar() {
    if (window.innerWidth < 1024) window.closeSidebar();

    var overlay = document.getElementById('sidebar-overlay');
    if (overlay && !overlay._sbInit) {
      overlay._sbInit = true;
      overlay.addEventListener('click', window.closeSidebar);
    }

    var closeBtn = document.getElementById('close-sidebar');
    if (closeBtn && !closeBtn._sbInit) {
      closeBtn._sbInit = true;
      closeBtn.addEventListener('click', window.closeSidebar);
    }
  }

  // ── ESC — satu listener global
  document.addEventListener('keydown', function (e) {
    if (e.key !== 'Escape') return;
    var sidebar = document.getElementById('sidebar');
    if (!sidebar) return;
    var t = sidebar.style.transform;
    if (t === 'translateX(0)' || t === 'translateX(0px)') window.closeSidebar();
  });

  // ── Resize
  window.addEventListener('resize', function () {
    if (window.innerWidth >= 1024) {
      var overlay = document.getElementById('sidebar-overlay');
      if (overlay) { overlay.classList.add('hidden'); overlay.style.opacity = '0'; }
      document.body.style.overflow = '';
    }
  });

  initSidebar();

}());
</script>
